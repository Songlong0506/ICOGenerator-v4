@model List<AiModel>
<div class="page-head"><div><h1>AI Models</h1><p>Manage and configure AI models used in your agents.</p></div><button class="btn primary" onclick="openModal('addModel')">＋ Add Model</button></div>
<input class="search" placeholder="Search models..." />
<div class="card table-card"><table><thead><tr><th>Model Name</th><th>Provider</th><th>Model ID</th><th>Context Window</th><th>Status</th><th>Default</th><th>Actions</th></tr></thead><tbody>
@foreach(var m in Model){<tr><td><b>@m.Name</b></td><td>@m.Provider</td><td>@m.ModelId</td><td>@m.ContextWindow.ToString("N0")</td><td><span class="badge green">@(m.IsActive ? "Active" : "Inactive")</span></td><td>@(m.IsDefault ? "★" : "-")</td><td>✎ ⋯</td></tr>}
</tbody></table></div>
<div id="addModel" class="modal-backdrop hidden"><form class="modal" asp-action="Create" method="post"><button type="button" class="x" onclick="closeModal('addModel')">×</button><h2>Add Model</h2><label>Model *</label><input name="Name" required placeholder="Qwen3.6 27B"/><label>Provider *</label><input name="Provider" value="LM Studio"/><label>Model ID *</label><input name="ModelId" required placeholder="qwen3.6-27b@q3_k_s"/><label>Endpoint *</label><input name="Endpoint" required value="http://127.0.0.1:1234/v1"/><label>ApiKey *</label><input name="ApiKey" value="lm-studio"/><label>Context Window</label><input name="ContextWindow" type="number" value="128000"/><label><input name="IsDefault" type="checkbox" value="true"/> Set as default</label><div class="modal-actions"><button type="button" class="btn" onclick="closeModal('addModel')">Cancel</button><button class="btn primary">Add Model</button></div></form></div>
