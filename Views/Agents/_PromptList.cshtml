@using ICOGenerator.Application.Agents
@model IReadOnlyList<AgentPromptItem>

@* Danh sách template prompt của một role (hoặc bucket Shared/General). Mỗi dòng link sang Prompt Studio
   (Detail) để xem/sửa theo phiên bản. Thay cho ô Instruction cũ trên trang Agents. *@
<div class="table-wrap">
    <table class="data-table">
        <thead>
            <tr>
                <th>Prompt</th>
                <th>Nguồn đang dùng</th>
                <th>Số phiên bản</th>
                <th>Sửa lần cuối</th>
                <th>Bởi</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="muted">Chưa có prompt nào cho mục này.</td></tr>
            }
            @foreach (var p in Model)
            {
                <tr>
                    <td>
                        <a class="prompt-key-link" asp-controller="Prompts" asp-action="Detail" asp-route-key="@p.PromptKey">
                            <code class="prompt-key">@p.DisplayName</code>
                        </a>
                        @if (p.IsInstruction)
                        {
                            <span class="badge blue" title="Chỉ dẫn cốt lõi của agent (instruction.md)">Instruction</span>
                        }
                        @if (!p.FileExists)
                        {
                            <span class="badge orange" title="File .md đã bị xoá khỏi repo — template chỉ còn sống bằng phiên bản DB">File đã xoá</span>
                        }
                    </td>
                    <td>
                        @if (p.ActiveVersionNumber is int active)
                        {
                            <span class="badge green" title="Bản DB đang thay nội dung file">DB v@(active)</span>
                        }
                        else
                        {
                            <span class="badge gray" title="Dùng nội dung file trong repo">File</span>
                        }
                    </td>
                    <td>@(p.VersionCount == 0 ? "—" : p.VersionCount.ToString())</td>
                    <td>
                        @if (p.LastChangedAt is DateTime lastAt)
                        {
                            <span class="prompt-time" data-utc="@lastAt.ToString("o")"></span>
                        }
                        else
                        {
                            <span class="muted">Chưa sửa bao giờ</span>
                        }
                    </td>
                    <td>@(p.LastChangedBy ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
