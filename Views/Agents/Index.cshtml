@using ICOGenerator.Application.Agents
@model List<Agent>
@{
    var sharedSelected = (ViewBag.SharedSelected as bool?) ?? false;
    var selected = ViewBag.Selected as Agent ?? (sharedSelected ? null : Model.FirstOrDefault());
    var tools = ViewBag.Tools as List<ToolDefinition> ?? new();
    var models = ViewBag.Models as List<AiModel> ?? new();
    var prompts = ViewBag.Prompts as IReadOnlyList<AgentPromptItem> ?? new List<AgentPromptItem>();
}

<div class="page-head">
    <div>
        <h1>Agents</h1>
    </div>
</div>

<div class="grid agents-grid">
    <section>
        <div class="card">
            <h3>All Agents (@Model.Count)</h3>

            @foreach (var a in Model)
            {
                <a class="agent-item @(!sharedSelected && selected?.Id == a.Id ? "active" : "")" asp-action="Index" asp-route-id="@a.Id">
                    <span class="circle" style="background:@a.Color"></span>
                    <div>
                        <b>@a.RoleKey.GetTitle()</b><br />
                    </div>
                </a>
            }

            @* Prompt không thuộc role agent nào (Shared/, Eval/, Design/) — gộp về một mục chung. *@
            <a class="agent-item @(sharedSelected ? "active" : "")" asp-action="Index" asp-route-shared="true">
                <span class="circle" style="background:#94a3b8"></span>
                <div>
                    <b>Shared / General</b><br />
                    <small>Prompt dùng chung</small>
                </div>
            </a>
        </div>
    </section>

    <section class="card detail">
        @if (sharedSelected)
        {
            <div class="agent-header">
                <span class="big-circle" style="background:#94a3b8"></span>
                <div>
                    <h2>Shared / General</h2>
                </div>
            </div>
            @await Html.PartialAsync("_PromptList", prompts)
        }
        else if (selected != null)
        {
            var enabledToolIds = selected.AgentTools.Select(x => x.ToolDefinitionId).ToHashSet();

            <form asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@selected.Id" />

                <div class="agent-header">
                    <button type="button" id="agentColorSwatch" class="big-circle color-swatch"
                            style="background:@selected.Color" title="Bấm để đổi màu" aria-label="Đổi màu agent">
                        <span class="color-swatch-icon" aria-hidden="true">🎨</span>
                    </button>
                    <input type="color" id="agentColorInput" name="Color" value="@selected.Color" class="visually-hidden" />
                    <div>
                        <h2>@selected.RoleKey.GetTitle()</h2>
                    </div>
                    <button type="submit" class="btn primary">Save Changes</button>
                </div>

                <div class="form-grid two">
                    <div>
                        <label>Model *</label>
                        <select name="AiModelId" required>
                            <option value="" disabled selected="@(selected.AiModelId == Guid.Empty)">-- Chọn model --</option>
                            @foreach (var m in models)
                            {
                                <option value="@m.Id" selected="@(selected.AiModelId == m.Id)">@m.ModelId</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label>Temperature</label>
                        <input type="number" step="0.1" min="0" max="2" name="Temperature" value="@selected.Temperature" />
                    </div>
                </div>

                <label>Description</label>
                <textarea name="Description" rows="3">@selected.Description</textarea>

                <div class="prompts-head">
                    <h3>Prompts</h3>
                </div>
                @await Html.PartialAsync("_PromptList", prompts)

                <div class="tools-head">
                    <h3>Tools</h3>
                    <span class="tools-counter"><b id="toolsSelectedCount">@enabledToolIds.Count</b> of @tools.Count selected</span>
                </div>

                <div class="tools-toolbar">
                    <div class="tools-search-wrap">
                        <input id="toolSearch" class="tools-search" type="text" placeholder="Search tools by name, description or method..." autocomplete="off" />
                    </div>
                </div>

                @* Selected summary bar — xem nhanh & bỏ chọn tool đã bật mà không phải cuộn tìm. *@
                <div class="tools-selected @(enabledToolIds.Count == 0 ? "is-empty" : "")" id="toolsSelected">
                    <span class="tools-selected-label">Đã chọn</span>
                    <div class="tools-selected-chips" id="toolsSelectedChips">
                        @foreach (var t in tools.Where(x => enabledToolIds.Contains(x.Id)).OrderBy(x => x.DisplayName))
                        {
                            <button type="button" class="sel-chip" data-tool-id="@t.Id" title="Bỏ chọn @t.DisplayName">
                                <span>@t.DisplayName</span>
                                <span class="sel-chip-x" aria-hidden="true">✕</span>
                            </button>
                        }
                    </div>
                    <span class="tools-selected-none">Chưa chọn tool nào.</span>
                </div>

                <div class="tools-bulk">
                    <button type="button" class="link-btn" data-bulk="expand">Expand all</button>
                    <span class="sep">·</span>
                    <button type="button" class="link-btn" data-bulk="collapse">Collapse all</button>
                    <span class="sep">·</span>
                    <button type="button" class="link-btn" data-bulk="clear">Clear selection</button>
                    <span class="tools-bulk-spacer"></span>
                    <label class="tools-sort">
                        <span>Sắp xếp</span>
                        <select id="toolSort">
                            <option value="name">Tên (A→Z)</option>
                            <option value="status">Trạng thái (đã bật lên trước)</option>
                        </select>
                    </label>
                </div>

                <div class="tools-scroll" id="toolsScroll">
                    @foreach (var group in tools.GroupBy(x => string.IsNullOrWhiteSpace(x.ServiceType) ? "Other" : x.ServiceType).OrderBy(g => g.Key))
                    {
                        var groupTools = group.OrderBy(x => x.DisplayName).ToList();
                        var groupEnabled = groupTools.Count(x => enabledToolIds.Contains(x.Id));
                        // Nhóm có tool đã bật thì mở sẵn để thấy ngay; nhóm rỗng thì thu gọn cho đỡ rối.
                        var collapsed = groupEnabled == 0;
                        <section class="tool-group @(collapsed ? "collapsed" : "")" data-group="@group.Key">
                            <header class="tool-group-head">
                                <button type="button" class="tool-group-toggle" aria-expanded="@((!collapsed).ToString().ToLowerInvariant())">
                                    <span class="chevron">▾</span>
                                    <b>@group.Key</b>
                                    <span class="tool-group-count"><span class="grp-enabled">@groupEnabled</span>/<span class="grp-total">@groupTools.Count</span></span>
                                </button>
                                <label class="group-select-all">
                                    <input type="checkbox" class="group-check" />
                                    <span>Select all</span>
                                </label>
                            </header>
                            <div class="tool-group-body">
                                @foreach (var t in groupTools)
                                {
                                    var enabled = enabledToolIds.Contains(t.Id);
                                    var search = $"{t.DisplayName} {t.Description} {t.ServiceType} {t.MethodName}".ToLowerInvariant();
                                    <label class="tool-row selectable @(enabled ? "enabled" : "")" data-search="@search" data-enabled="@enabled.ToString().ToLowerInvariant()" data-name="@t.DisplayName.ToLowerInvariant()" data-tool-id="@t.Id">
                                        <input class="tool-checkbox" type="checkbox" name="ToolDefinitionIds" value="@t.Id" checked="@enabled" />
                                        <span class="tool-row-main">
                                            <b class="tool-row-name">@t.DisplayName</b>
                                            <code class="tool-row-method">@t.ServiceType.@t.MethodName</code>
                                        </span>
                                        <span class="tool-row-desc" title="@t.Description">@t.Description</span>
                                        <span class="badge @(enabled ? "green" : "gray")">@(enabled ? "Enabled" : "Disabled")</span>
                                    </label>
                                }
                            </div>
                        </section>
                    }
                    <div class="tools-empty" id="toolsEmpty" hidden>No tools match your search.</div>
                </div>
            </form>
        }
    </section>
</div>

@section Scripts {
    <script src="~/js/agents.js" asp-append-version="true"></script>
    <script src="~/js/prompts.js" asp-append-version="true"></script>
}
