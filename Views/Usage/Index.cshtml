@using System.Globalization
@using ICOGenerator.Application.Usage
@model UsageOverviewVm

@functions {
    private static string Compact(long value) => value switch
    {
        >= 1_000_000_000 => (value / 1_000_000_000d).ToString("0.##", CultureInfo.InvariantCulture) + "B",
        >= 1_000_000 => (value / 1_000_000d).ToString("0.##", CultureInfo.InvariantCulture) + "M",
        >= 1_000 => (value / 1_000d).ToString("0.#", CultureInfo.InvariantCulture) + "K",
        _ => value.ToString("N0")
    };

    private static string MonthLabel(int year, int month) =>
        new DateTime(year, month, 1).ToString("MM/yyyy");

    private static double Percent(long part, long total) =>
        total == 0 ? 0 : Math.Round(part * 100d / total, 1);

    // Số tiền nhỏ (< 1 cent) hiển thị thêm chữ số để không bị làm tròn về $0.00.
    private static string Money(decimal v) =>
        v <= 0 ? "$0.00"
        : v < 0.01m ? "$" + v.ToString("0.####", CultureInfo.InvariantCulture)
        : "$" + v.ToString("N2", CultureInfo.InvariantCulture);

    private static string Unit(decimal v) => "$" + v.ToString("0.######", CultureInfo.InvariantCulture);
}

@section Styles {
    <link rel="stylesheet" href="~/css/usage.css" asp-append-version="true" />
}

<div class="page-head">
    <div>
        <h1>Usage</h1>
    </div>
</div>

<div class="usage-cards">
    <div class="card cost">
        <span>Total cost</span>
        <b>@Money(Model.TotalCost)</b>
        <small>@Compact(Model.TotalTokens) tokens · all time</small>
    </div>
    <div class="card cost">
        <span>This month</span>
        <b>@Money(Model.CurrentMonthCost)</b>
        <small>@DateTime.UtcNow.ToString("MM/yyyy") · @Compact(Model.CurrentMonthTokens) tokens</small>
    </div>
    <div class="card">
        <span>Total tokens</span>
        <b title="@Model.TotalTokens.ToString("N0")">@Compact(Model.TotalTokens)</b>
        <small>Prompt @Compact(Model.TotalPromptTokens) · Completion @Compact(Model.TotalCompletionTokens)</small>
    </div>
    <div class="card">
        <span>Model calls</span>
        <b>@Model.TotalCalls.ToString("N0")</b>
        <small>Across @Model.ProjectUsage.Count project(s)</small>
    </div>
</div>

@if (!Model.HasAnyPricing)
{
    <div class="pricing-hint">
        Chưa đặt đơn giá cho model nào, nên chi phí đang hiển thị $0. Vào
        <a asp-controller="Models" asp-action="Index">AI Models</a>
        để nhập <b>Input/Output price ($/1M tokens)</b> cho từng model.
    </div>
}

<div class="card usage-section">
    <div class="chart-head">
        <h2>Tokens per month</h2>
        <div class="legend">
            <span><i class="swatch-prompt"></i>Prompt</span>
            <span><i class="swatch-completion"></i>Completion</span>
        </div>
    </div>

    @{
        var maxMonthTokens = Math.Max(Model.MonthlyUsage.Max(x => x.TotalTokens), 1);
    }
    <div class="month-chart">
        @foreach (var m in Model.MonthlyUsage)
        {
            var promptHeight = m.PromptTokens * 100d / maxMonthTokens;
            var completionHeight = m.CompletionTokens * 100d / maxMonthTokens;
            <div class="month-col"
                 title="@MonthLabel(m.Year, m.Month): @m.TotalTokens.ToString("N0") tokens · @Money(m.Cost) (@m.CallCount calls)">
                <div class="month-value">@(m.TotalTokens > 0 ? Compact(m.TotalTokens) : "–")</div>
                <div class="month-bar">
                    <div class="seg-completion" style="height:@completionHeight.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                    <div class="seg-prompt" style="height:@promptHeight.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                </div>
                <div class="month-label">@MonthLabel(m.Year, m.Month)</div>
            </div>
        }
    </div>
</div>

<div class="card table-card usage-section">
    <div class="chart-head" style="padding:22px 28px 0">
        <h2>Cost by model</h2>
    </div>

    @if (Model.ModelUsage.Count == 0)
    {
        <div class="empty-state">No token usage recorded yet.</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Model</th>
                    <th>Unit price (in / out, $/1M)</th>
                    <th>Total Tokens</th>
                    <th>Prompt</th>
                    <th>Completion</th>
                    <th>Calls</th>
                    <th>Cost</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.ModelUsage)
                {
                    <tr>
                        <td>
                            <b>@m.ModelName</b>
                            @if (!string.IsNullOrWhiteSpace(m.ModelId) && m.ModelId != m.ModelName)
                            {
                                <small class="muted" style="display:block">@m.ModelId</small>
                            }
                        </td>
                        <td>
                            @if (m.HasPrice)
                            {
                                <span>@Unit(m.InputPricePerMillionTokens) / @Unit(m.OutputPricePerMillionTokens)</span>
                            }
                            else
                            {
                                <span class="muted">chưa đặt giá</span>
                            }
                        </td>
                        <td><b>@m.TotalTokens.ToString("N0")</b></td>
                        <td>@m.PromptTokens.ToString("N0")</td>
                        <td>@m.CompletionTokens.ToString("N0")</td>
                        <td>@m.CallCount.ToString("N0")</td>
                        <td class="cost-cell">@(m.HasPrice ? Money(m.Cost) : "–")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="card table-card usage-section">
    <div class="chart-head" style="padding:22px 28px 0">
        <h2>Usage by project</h2>
    </div>

    @if (Model.ProjectUsage.Count == 0)
    {
        <div class="empty-state">No token usage recorded yet.</div>
    }
    else
    {
        var maxProjectTokens = Math.Max(Model.ProjectUsage.Max(x => x.TotalTokens), 1);
        <table>
            <thead>
                <tr>
                    <th>Project</th>
                    <th style="width:25%">Share</th>
                    <th>Total Tokens</th>
                    <th>Prompt</th>
                    <th>Completion</th>
                    <th>Calls</th>
                    <th>Cost</th>
                    <th>Last Activity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.ProjectUsage)
                {
                    var width = p.TotalTokens * 100d / maxProjectTokens;
                    <tr>
                        <td><b>@p.ProjectName</b></td>
                        <td>
                            <div class="project-bar-track" title="@Percent(p.TotalTokens, Model.TotalTokens)% of all tokens">
                                <div class="project-bar-fill" style="width:@width.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                            </div>
                            <small class="muted">@Percent(p.TotalTokens, Model.TotalTokens)%</small>
                        </td>
                        <td><b>@p.TotalTokens.ToString("N0")</b></td>
                        <td>@p.PromptTokens.ToString("N0")</td>
                        <td>@p.CompletionTokens.ToString("N0")</td>
                        <td>@p.CallCount.ToString("N0")</td>
                        <td class="cost-cell">@Money(p.Cost)</td>
                        <td class="muted">@(p.LastCallAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "–")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>