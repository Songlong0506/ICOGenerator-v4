@model Project
@{
    ViewData["Title"] = "Requirements";
    // Trang Requirements chỉ hiển thị tài liệu DỄ HIỂU cho user thường: Product Brief. Bản kỹ thuật
    // (AI Design Spec) và tài liệu kỹ thuật nặng (BRD/SRS/FSD/UserStories) sống ở Agent Dashboard.
    var productBriefs = Model.Documents
        .Where(x => x.FileName == "ProductBrief.docx")
        .ToList();

    var versions = productBriefs
        .GroupBy(x => x.VersionName)
        .OrderByDescending(g => g.Key == "draft" ? int.MaxValue :
            int.TryParse(g.Key.Replace("V", ""), out var n) ? n : 0)
        .ToList();
    var selectedVersion = ViewBag.SelectedVersion?.ToString() ?? "draft";
    var conversations = Model.Conversations
        .OrderBy(x => x.CreatedAt)
        .ToList();
    var workflowRuns = Model.WorkflowRuns
        .OrderBy(x => x.CreatedAt)
        .ToList();
    var workflowStarted = TempData["WorkflowStarted"] != null;
    var autoScrollWorkflowRunId = workflowStarted
        ? workflowRuns.OrderByDescending(x => x.CreatedAt).Select(x => (Guid?)x.Id).FirstOrDefault()
        : null;
    var timelineItems = conversations
        .Select(x => new { Kind = "conversation", CreatedAt = x.CreatedAt, Conversation = (AgentConversation?)x, WorkflowRun = (WorkflowRun?)null })
        .Concat(workflowRuns.Select(x => new { Kind = "workflow", CreatedAt = x.CreatedAt, Conversation = (AgentConversation?)null, WorkflowRun = (WorkflowRun?)x }))
        .OrderBy(x => x.CreatedAt)
        .ToList();

    // Gộp tiến độ thành MỘT timeline thống nhất: các workflow run LIỀN KỀ trên timeline (không có
    // tin nhắn hội thoại xen giữa) thuộc cùng một hành trình — ví dụ "Requirement Design Spec V1"
    // rồi "Delivery Workflow V1" mà worker sinh ngay sau khi spec xong — nên gom vào MỘT panel:
    // một header, một badge, một banner, một feed sự kiện liên tục. Run "lead" (mới nhất trong nhóm)
    // quyết định trạng thái tổng thể; mỗi run vẫn có stream riêng, JS dồn event vào cùng một feed.
    var renderGroups = new List<(string Kind, AgentConversation? Conversation, List<WorkflowRun> Runs)>();
    foreach (var item in timelineItems)
    {
        if (item.Kind == "workflow" && item.WorkflowRun != null)
        {
            if (renderGroups.Count > 0 && renderGroups[^1].Kind == "workflow")
                renderGroups[^1].Runs.Add(item.WorkflowRun);
            else
                renderGroups.Add(("workflow", null, new List<WorkflowRun> { item.WorkflowRun }));
        }
        else if (item.Conversation != null)
        {
            renderGroups.Add(("conversation", item.Conversation, new List<WorkflowRun>()));
        }
    }

    // Gợi ý chỉ hiển thị cho lượt HỎI mới nhất của BA (item cuối timeline). Các lượt cũ coi như đã trả lời.
    var lastItem = timelineItems.LastOrDefault();
    var lastBaSuggestions = (lastItem != null && lastItem.Kind == "conversation"
            && lastItem.Conversation != null && lastItem.Conversation.Role == "assistant")
        ? ParseSuggestions(lastItem.Conversation.Suggestions)
        : new List<string>();

    // Lượt chào đầu tiên (workspace trống) KHÔNG gợi ý: để người dùng tự mô tả ý tưởng dự án.
    // Chỉ khi đã có hội thoại thì mới hiển thị gợi ý cho lượt hỏi mới nhất của BA.
    var displaySuggestions = lastBaSuggestions;

    // Nút "Write Requirement" hiện "sẵn sàng" (nổi bật) khi lượt BA mới nhất MỜI người dùng bấm nút — tức
    // lời nhắn có nhắc tới "Write Requirement". Prompt ép model chỉ mời bấm khi đã khai thác đủ thông tin,
    // nên chính nội dung lời nhắn là tín hiệu sẵn sàng (khớp với lời mời, không còn cờ ready lưu riêng).
    // Khi chưa mời — kể cả lúc workspace còn trống — nút ở trạng thái "mờ" kèm ghi chú: BA vẫn đang hỏi thêm,
    // nhưng người dùng VẪN có thể bấm tạo ngay (gate readiness phía server vẫn chặn nếu thực sự thiếu thông tin).
    var lastBaTurn = conversations.LastOrDefault(c => c.Role == "assistant");
    var requirementReady = lastBaTurn?.Message?.Contains("Write Requirement", StringComparison.OrdinalIgnoreCase) ?? false;

    // Tài liệu nguồn (ảnh/PDF) người dùng upload cho project + cờ vision của model BA (để cảnh báo).
    var sourceFiles = Model.SourceFiles.OrderByDescending(x => x.CreatedAt).ToList();
    var baSupportsVision = ViewBag.BaSupportsVision is bool bv && bv;

    // Panel tiến độ khai thác (bản đồ bao phủ đã parse) + "Điều đã chốt" — render lần đầu ở server,
    // sau đó frame done của ChatStream cập nhật live (markup phải khớp renderCoverage/renderDecisions
    // trong requirements.js).
    var coverage = ViewBag.Coverage as IReadOnlyList<ICOGenerator.Contracts.Requirements.CoverageMapItem>
        ?? new List<ICOGenerator.Contracts.Requirements.CoverageMapItem>();
    var decisions = ViewBag.Decisions as IReadOnlyList<string> ?? new List<string>();
    // "Triển vọng phỏng vấn" (InterviewOutlookService): điểm cần làm rõ (D), màn hình dự kiến (G), ví dụ
    // tính thử đã xác nhận (A). Render lần đầu ở server; frame "outlook" của ChatStream cập nhật live.
    var openQuestions = ViewBag.OpenQuestions as IReadOnlyList<string> ?? new List<string>();
    var plannedScope = ViewBag.PlannedScope as IReadOnlyList<string> ?? new List<string>();
    var workedExamples = ViewBag.WorkedExamples as IReadOnlyList<string> ?? new List<string>();
    // Giả định BA tự đưa khi sinh AI Design Spec (mục ## 12. Assumptions) — hiển thị cho user rà lại.
    var specAssumptions = ViewBag.SpecAssumptions as IReadOnlyList<string> ?? new List<string>();
    var specVersion = ViewBag.SpecVersion as string;
    var coverageClear = coverage.Count(x => x.Status == "RÕ");
    var coverageApplicable = coverage.Count(x => x.Status != "KHÔNG ÁP DỤNG");
    // "Chào lại" cho phỏng vấn dài (F): khi quay lại một dự án đang dở (đã có tiến độ nhưng chưa xong,
    // và requirement chưa được mời chốt), nói rõ còn bao nhiêu nhóm thông tin cần làm rõ.

    // Cờ multi-select của lượt hỏi mới nhất (chip cho phép chọn nhiều rồi gửi một lần). Conversation
    // khác null đã ngầm định Kind == "conversation" (item workflow không có Conversation).
    var lastSuggestionsMulti = lastItem?.Conversation is { Role: "assistant", SuggestionsMultiSelect: true };

    static string CoverageIcon(string status) => status switch
    {
        "RÕ" => "✅",
        "MỘT PHẦN" => "🟡",
        "KHÔNG ÁP DỤNG" => "➖",
        _ => "⚪"
    };

    static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024 ? $"{bytes / 1024d / 1024d:0.#} MB" : $"{Math.Max(1, bytes / 1024)} KB";

    static List<string> ParseSuggestions(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<string>();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new List<string>();
        }
        catch
        {
            return new List<string>();
        }
    }

    static List<ICOGenerator.Contracts.Requirements.FlowStep> ParseFlow(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<ICOGenerator.Contracts.Requirements.FlowStep>();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<ICOGenerator.Contracts.Requirements.FlowStep>>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true })
                ?? new List<ICOGenerator.Contracts.Requirements.FlowStep>();
        }
        catch
        {
            return new List<ICOGenerator.Contracts.Requirements.FlowStep>();
        }
    }
}

<div class="page-head">
    <div>
        <h1>Requirements</h1>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="req-alert error">@TempData["Error"]</div>
}
@if (TempData["SourceUploaded"] != null)
{
    <div class="req-alert ok">Đã upload tài liệu nguồn. BA đang đọc và sẽ tóm tắt lại trong khung chat để anh/chị xác nhận.</div>
}
@if (TempData["SourceScanWarning"] != null)
{
    <div class="req-alert error">⚠️ @TempData["SourceScanWarning"]</div>
}
@if (TempData["RequirementApproved"] != null)
{
    // Đặt kỳ vọng ngay sau Approve: nói rõ điều gì đang chạy nền và mất khoảng bao lâu (ETA đo từ
    // các lần dựng POC đã hoàn tất — EstimatePocEtaQuery; chưa có lịch sử thì bỏ phần con số).
    var etaMinutes = TempData["ApprovedPocEtaMinutes"] as int?;
    <div class="req-alert ok">
        ✅ Yêu cầu đã được duyệt. Hệ thống đang tự dựng <b>bản demo (POC)</b> để anh/chị xem trước —
        @(etaMinutes.HasValue ? $"thường mất khoảng {etaMinutes.Value} phút. " : "quá trình này chạy nền, có thể mất ít phút. ")
        Anh/chị có thể theo dõi tiến độ ngay trong khung chat bên dưới và sẽ nhận thông báo khi POC sẵn sàng.
    </div>
}

<div class="grid doc-grid">

    <aside class="card history-panel">

        @* Tiến độ khai thác yêu cầu: cho user thấy cuộc phỏng vấn đã rõ bao nhiêu nhóm thông tin và còn
           thiếu gì — thay vì cảm giác "bị hỏi vô tận". Ẩn khi chưa có bản đồ (dự án mới). *@
        <div class="coverage-panel" id="coveragePanel" @(coverage.Count == 0 ? "hidden" : "")>
            <h3>Tiến độ khai thác</h3>
            <div class="coverage-progress">
                <div class="coverage-bar">
                    <span id="coverageBarFill"
                          style="width:@(coverageApplicable == 0 ? 0 : coverageClear * 100 / coverageApplicable)%"></span>
                </div>
                <span class="coverage-progress-text" id="coverageProgressText">Đã rõ @coverageClear/@coverageApplicable nhóm</span>
            </div>
            <ul class="coverage-list" id="coverageList">
                @foreach (var item in coverage)
                {
                    <li class="coverage-item @(item.Status == "KHÔNG ÁP DỤNG" ? "na" : "")"
                        title="@item.Summary">
                        <span class="cov-ico">@CoverageIcon(item.Status)</span>
                        <span class="cov-label">@(item.IsCore ? "★ " : "")@item.Label</span>
                    </li>
                }
            </ul>
        </div>

        @* "Điều đã chốt": các quyết định user đã xác nhận trong chat — bấm một mục để soạn sẵn tin nhắn
           yêu cầu sửa lại, bắt hiểu nhầm sớm thay vì để nó đóng băng vào tài liệu. *@
        <div class="decision-panel" id="decisionPanel" @(decisions.Count == 0 ? "hidden" : "")>
            <h3>Điều đã chốt <span class="decision-count" id="decisionCount">(@decisions.Count)</span></h3>
            <div class="history-sub decision-hint">Bấm vào một mục nếu muốn sửa lại quyết định đó.</div>
            <ul class="decision-list" id="decisionList">
                @foreach (var decision in decisions)
                {
                    <li>
                        <button type="button" class="decision-item" data-decision="@decision" title="Bấm để yêu cầu sửa lại">
                            @decision
                        </button>
                    </li>
                }
            </ul>
        </div>

        @* "Sẽ xây gì" (G): các màn hình/tính năng dự kiến, dựng dần theo hội thoại — user bắt hiểu nhầm
           sớm và thấy hình hài ứng dụng thay vì phỏng vấn "mù". Cập nhật live qua frame "outlook". *@
        <div class="scope-panel" id="scopePanel" @(plannedScope.Count == 0 ? "hidden" : "")>
            <h3>Sẽ xây gì <span class="scope-count" id="scopeCount">(@plannedScope.Count)</span></h3>
            <div class="history-sub decision-hint">Các màn hình/tính năng dự kiến theo những gì anh/chị đã kể (dựng dần).</div>
            <ul class="scope-list" id="scopeList">
                @foreach (var item in plannedScope)
                {
                    <li class="scope-item">@item</li>
                }
            </ul>
        </div>

        @* "Điểm cần làm rõ" (D): đối trọng với "Điều đã chốt" — chỗ tài liệu còn mỏng/mâu thuẫn. Bấm một
           mục để soạn sẵn tin nhắn trả lời điểm đó. Cập nhật live qua frame "outlook". *@
        <div class="open-q-panel" id="openQPanel" @(openQuestions.Count == 0 ? "hidden" : "")>
            <h3>Điểm cần làm rõ <span class="open-q-count" id="openQCount">(@openQuestions.Count)</span></h3>
            <div class="history-sub decision-hint">Bấm một mục để trả lời/làm rõ điểm đó ngay trong chat.</div>
            <ul class="open-q-list" id="openQList">
                @foreach (var q in openQuestions)
                {
                    <li>
                        <button type="button" class="open-q-item" data-question="@q" title="Bấm để trả lời điểm này">@q</button>
                    </li>
                }
            </ul>
        </div>

        @* "Ví dụ tính thử đã xác nhận" (A): các con số user đã chốt cho quy tắc định lượng — cũng là chuẩn
           để POC tự kiểm đối chiếu độc lập. Hiển thị để user thấy hệ thống đã ghi nhận đúng cách tính. *@
        <div class="worked-panel" id="workedPanel" @(workedExamples.Count == 0 ? "hidden" : "")>
            <h3>Ví dụ đã xác nhận <span class="worked-count" id="workedCount">(@workedExamples.Count)</span></h3>
            <div class="history-sub decision-hint">Cách tính & luồng anh/chị đã chốt — bản demo (POC) sẽ được kiểm tự động theo đúng các ví dụ này.</div>
            <ul class="worked-list" id="workedList">
                @foreach (var ex in workedExamples)
                {
                    <li class="worked-item">@ex</li>
                }
            </ul>
        </div>

        @* Giả định của bản thiết kế (AI Design Spec): những điều BA tự quyết thay user khi dựng spec/POC.
           User rà mục này để không bất ngờ khi xem POC; muốn đổi giả định nào thì nhắn trong chat. *@
        @if (specAssumptions.Any())
        {
            <div class="assumption-panel" id="assumptionPanel">
                <h3>Giả định cần xác nhận @(string.IsNullOrEmpty(specVersion) ? "" : $"({specVersion})")</h3>
                <div class="history-sub decision-hint">
                    BA đã tự quyết các điểm sau khi dựng bản thiết kế. <b>Rà lại giúp mình:</b> nếu điểm nào
                    chưa đúng, bấm vào nó để sửa — mình sẽ cập nhật tài liệu và dựng lại bản demo cho khớp.
                    Không bấm gì nghĩa là anh/chị đồng ý với các giả định này.
                </div>
                <ul class="assumption-list">
                    @foreach (var assumption in specAssumptions)
                    {
                        <li>
                            <button type="button" class="assumption-item" data-assumption="@assumption" title="Bấm nếu giả định này chưa đúng để sửa">@assumption</button>
                        </li>
                    }
                </ul>
            </div>
        }

        <h3>Product Brief</h3>

        @if (versions.Any())
        {
            foreach (var version in versions)
            {
                <div class="history-item">

                    <div class="history-left">
                        <div class="history-icon">📄</div>

                        <div>
                            <div class="history-title">
                                @(version.Key == "draft" ? "Draft" : version.Key)
                            </div>
                        </div>
                    </div>

                    <button type="button"
                            class="btn outline small"
                            onclick="openRequirementModal('@version.Key')">
                        View
                    </button>
                </div>
            }
        }
        else
        {
            <div class="empty-history">
                No requirement history yet.
            </div>
        }

        <div class="source-panel">
            <h3>Tài liệu nguồn</h3>

            @if (!baSupportsVision)
            {
                <div class="source-vision-warn">
                    ⚠️ Model BA hiện không bật <b>vision</b> → ảnh sẽ không được đọc; chỉ phần chữ trích từ PDF được dùng.
                    Bật "Hỗ trợ ảnh (vision)" trong màn hình AI Models nếu cần.
                </div>
            }

            <form asp-action="UploadSource"
                  method="post"
                  enctype="multipart/form-data"
                  class="source-upload-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="file"
                       name="files"
                       multiple
                       accept="image/png,image/jpeg,image/webp,image/gif,application/pdf,.xlsx,.xlsm,.csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv"
                       class="source-file-input"
                       required />
                <button class="btn outline small full bottom" type="submit">⬆ Upload</button>
            </form>

            @if (sourceFiles.Any())
            {
                <ul class="source-list">
                    @foreach (var src in sourceFiles)
                    {
                        <li class="source-item">
                            <span>@(src.Kind switch {
                                ICOGenerator.Domain.Enums.SourceFileKind.Image => "🖼️",
                                ICOGenerator.Domain.Enums.SourceFileKind.Spreadsheet => "📊",
                                _ => "📄" })</span>
                            <span class="source-name" title="@src.FileName">@src.FileName</span>
                            <span class="source-size">@FormatSize(src.SizeBytes)</span>
                            <form asp-action="DeleteSource"
                                  method="post"
                                  class="source-inline"
                                  onsubmit="return confirm('Xoá tài liệu nguồn này?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@src.Id" />
                                <input type="hidden" name="projectId" value="@Model.Id" />
                                <button class="source-del" type="submit" title="Xoá">🗑</button>
                            </form>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="empty-history">Chưa có tài liệu nguồn.</div>
            }
        </div>

        <form asp-action="NewChat"
              method="post"
              class="new-chat-form"
              onsubmit="return confirm('Bắt đầu chat mới: hội thoại hiện tại sẽ được lưu trữ (BA không dùng nữa) và cuộc trò chuyện bắt đầu lại từ đầu. Tiếp tục?');">

            <input type="hidden"
                   name="projectId"
                   value="@Model.Id" />

            <button class="btn outline full bottom">
                ＋ New Chat
            </button>
        </form>

    </aside>

    <section class="card chat-panel">

        <div id="chatMessages"
             class="chat-messages">

            @if (!conversations.Any())
            {
                <div class="req-msg ba">
                    <b>BA</b>

                    <p>
                        Xin chào! Tôi là Business Analyst. Anh/chị cứ <b>kể thoải mái một mạch</b> mọi điều
                        đang hình dung về ứng dụng: bài toán cần giải quyết, ai sẽ dùng, quy trình hiện tại
                        đang làm thế nào và vướng ở đâu — càng chi tiết tôi càng đỡ phải hỏi lại.
                        Nếu có sẵn tài liệu, ảnh chụp màn hình Excel/biểu mẫu đang dùng, anh/chị
                        <b>đính kèm ở mục "Tài liệu nguồn"</b> bên trái để tôi đọc luôn nhé.
                    </p>
                </div>
            }

            @foreach (var group in renderGroups)
            {
                if (group.Kind == "workflow")
                {
                    var runs = group.Runs;
                    var leadRun = runs[runs.Count - 1];
                    var groupAutoScroll = runs.Any(r => r.Id == autoScrollWorkflowRunId) ? "true" : "false";
                    var runIds = string.Join(",", runs.Select(r => r.Id));
                    // Hành trình kết thúc bằng run delivery → nhãn "Delivery Progress"; ngược lại (chỉ có
                    // run requirement của BA) giữ "Requirement Progress" như trước.
                    var groupTitle = runs.Any(r => r.Name != null && r.Name.Contains("Delivery"))
                        ? "Delivery Progress"
                        : "Requirement Progress";

                    <div id="wf-panel-@leadRun.Id"
                         class="req-msg ba workflow-progress"
                         data-run-ids="@runIds"
                         data-lead-run-id="@leadRun.Id"
                         data-autoscroll="@groupAutoScroll">
                        <div class="workflow-progress-head">
                            <b>BA</b>
                            <span class="workflow-progress-title">@groupTitle</span>
                        </div>
                        <small class="muted wf-sub"></small>
                        <div class="workflow-progress-body wf-body">
                            <div class="wf-banner wf-run">⏳ Đang tải tiến độ delivery…</div>
                        </div>
                    </div>
                }
                else if (group.Conversation?.Role == "user")
                {
                    <div class="req-msg you">
                        <p>@group.Conversation.Message</p>
                    </div>
                }
                else if (group.Conversation != null)
                {
                    // Lượt BA là THÔNG BÁO LỖI gọi AI (tiền tố ⚠️ dùng chung với transcript filter): tô đỏ
                    // như đường streaming, và nếu là lượt CUỐI của hội thoại thì kèm nút "Thử lại" — server
                    // xóa lượt lỗi rồi chạy lại, người dùng khỏi phải gõ lại câu vừa hỏi.
                    var isFailureTurn = (group.Conversation.Message ?? "").StartsWith(
                        ICOGenerator.Services.Requirements.ConversationTranscriptBuilder.LlmFailurePrefix, StringComparison.Ordinal);
                    var isLastTurn = group.Conversation.Id == conversations.LastOrDefault()?.Id;
                    <div class="req-msg ba @(isFailureTurn ? "chat-error" : "")">
                        <b>BA</b>

                        <p style="white-space: pre-wrap;">
                            @group.Conversation.Message
                        </p>

                        @if (isFailureTurn && isLastTurn)
                        {
                            <button type="button" class="btn outline small chat-retry-btn" title="Chạy lại lượt trả lời vừa lỗi — không cần gõ lại câu hỏi">↻ Thử lại</button>
                        }

                        @{
                            // Sơ đồ luồng chỉ đính ở lượt BA mời "Write Requirement" và chỉ hiện cho lượt BA
                            // MỚI NHẤT (như chip gợi ý) để không lặp lại các sơ đồ cũ trong lịch sử. Markup
                            // khớp renderFlowDiagram (requirements.js) để frame done render y hệt khi không reload.
                            var flow = group.Conversation.Id == lastBaTurn?.Id
                                ? ParseFlow(group.Conversation.FlowDiagram)
                                : new List<ICOGenerator.Contracts.Requirements.FlowStep>();
                        }
                        @if (flow.Any())
                        {
                            <div class="flow-diagram" aria-label="Sơ đồ luồng nghiệp vụ để xác nhận">
                                <div class="flow-diagram-title">Luồng nghiệp vụ chính — anh/chị xem giúp đã đúng chưa nhé:</div>
                                <ol class="flow-steps">
                                    @foreach (var step in flow)
                                    {
                                        <li class="flow-step">
                                            @if (!string.IsNullOrWhiteSpace(step.Actor))
                                            {
                                                <span class="flow-actor">@step.Actor</span>
                                            }
                                            <span class="flow-action">@step.Action</span>
                                            @if (!string.IsNullOrWhiteSpace(step.Outcome))
                                            {
                                                <span class="flow-outcome">@step.Outcome</span>
                                            }
                                            <button type="button" class="flow-step-fix" data-step="@step.Action" title="Bấm nếu bước này chưa đúng để đính chính ngay trong chat">chưa đúng?</button>
                                        </li>
                                    }
                                </ol>
                            </div>
                        }
                    </div>
                }
            }
    
            <div id="suggestionList"
                 class="suggestion-list"
                 role="listbox"
                 aria-label="Gợi ý trả lời"
                 data-multi="@(lastSuggestionsMulti ? "true" : "false")"
                 style="@(displaySuggestions.Any() ? "" : "display:none;")">
                @{
                    var suggestionIndex = 0;
                }
                @foreach (var suggestion in displaySuggestions)
                {
                    suggestionIndex++;
                    <button type="button"
                            class="suggestion-option"
                            role="option"
                            data-suggestion="@suggestion">
                        <span class="suggestion-option-text">@suggestion</span>
                        <span class="suggestion-option-key">@suggestionIndex</span>
                    </button>
                }
            </div>

            <div id="thinkingBox"
                 class="req-msg ba thinking"
                 style="display:none;">

                <b>BA</b>

                <div class="thinking-content">

                    <div class="spinner"></div>

                    <span id="thinkingText">
                        BA is analyzing requirements...
                    </span>

                </div>
            </div>

        </div>

        <div class="chat-composer">

            <div class="composer-actions">

                <!-- WRITE REQUIREMENT: sinh bản mô tả sản phẩm (Product Brief) DỄ HIỂU cho user.
                     Tài liệu kỹ thuật (BRD/SRS/FSD/UserStories) do team dev trigger ở Agent Dashboard.
                     Nút ở 2 trạng thái: "mờ" (write-req-waiting) khi BA còn câu hỏi, "sẵn sàng"
                     (write-req-ready) khi BA đã đủ thông tin. Cả hai đều bấm được (lối thoát thủ công);
                     khi chưa sẵn sàng có ghi chú nhắc người dùng. -->
                <form asp-action="WriteRequirement"
                      method="post"
                      class="write-req @(requirementReady ? "write-req-ready" : "write-req-waiting")"
                      onsubmit="var b=this.querySelector('button'); b.disabled=true; b.textContent='Đang tạo tài liệu…';">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <button class="btn write-req-btn @(requirementReady ? "primary" : "outline")"
                            type="submit"
                            title="@(requirementReady
                                ? "BA đã thu thập đủ thông tin — tạo bản mô tả sản phẩm."
                                : "BA vẫn đang hỏi thêm thông tin. Bạn vẫn có thể tạo ngay, nhưng nên trả lời thêm để tài liệu đầy đủ hơn.")">
                        📝 Write Requirement
                    </button>
                    @if (!requirementReady)
                    {
                        <span class="write-req-hint">BA đang hỏi thêm — bạn vẫn có thể tạo ngay.</span>
                    }
                </form>

                <!-- Cổng "Duyệt & tiếp tục" (và Retry/Reject) ĐÃ CHUYỂN sang Agent Dashboard: user thường
                     dừng ở bước POC, chỉ TeamDev/Admin (quyền DeliveryAdvance) mới đẩy tiếp các bước
                     Architecture/code/test. Trang này chỉ hiển thị tiến độ; banner bên dưới sẽ hướng
                     dẫn người có quyền sang dashboard. -->

            </div>

            <form id="chatForm"
                  asp-action="Chat"
                  method="post"
                  class="req-chatbox">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="projectId"
                       value="@Model.Id" />

                <input type="hidden"
                       id="hiddenMessage"
                       name="message" />

              <textarea id="messageInput"
                          rows="1"
                          placeholder="Type your message..."
                          autocomplete="off"></textarea>

                <!-- Nói thay vì gõ (Web Speech API). JS ẩn nút khi trình duyệt không hỗ trợ;
                     đang ghi âm thì nút đổi trạng thái đỏ + text nhận dạng đổ dần vào ô nhập. -->
                <button class="btn outline voice-btn"
                        type="button"
                        id="voiceInputBtn"
                        hidden
                        aria-label="Nói thay vì gõ"
                        title="Nói thay vì gõ — bấm để bắt đầu/dừng ghi âm">
                    <i class="bi bi-mic" aria-hidden="true"></i>
                </button>

                <button class="btn primary"
                        type="submit"
                        aria-label="Send message">
                    ➤
                </button>
            </form>

        </div>

    </section>

</div>

<div id="requirementModal" class="req-modal-overlay">
    <div class="requirement-modal">

        <div class="modal-header">
            <div>
                <h2 id="modalTitle">Product Brief</h2>
            </div>

            <button class="modal-close" type="button" aria-label="Close" onclick="closeRequirementModal()">
                ×
            </button>
        </div>

        <div class="requirement-content">
            @foreach (var doc in productBriefs)
            {
                <div class="doc-preview"
                     id="doc-@doc.Id"
                     data-version="@doc.VersionName"
                     style="display:none;">

                    <div class="doc-actions">
                        <a class="btn outline"
                           asp-controller="Requirements"
                           asp-action="DownloadDocument"
                           asp-route-id="@doc.Id">
                            Download
                        </a>
                        <button type="button"
                                class="btn outline"
                                onclick="openDocHistory('@doc.Id')"
                                title="Xem các lần sinh/sửa trước và khác biệt giữa chúng">
                            <i class="bi bi-clock-history" aria-hidden="true"></i> Lịch sử
                        </button>
                    </div>

                    <h3>@doc.FileName</h3>

                    @* Bản DRAFT cho phép ghi chú trực tiếp: bôi đen một đoạn → "＋ Ghi chú" → gom lại gửi
                       BA sửa (ReviseBrief). Bản đã duyệt (V{n}) chỉ đọc, không gắn cờ này. *@
                    <div class="doc-render"
                         data-doc-id="@doc.Id"
                         data-loaded="false"
                         data-annotatable="@(doc.VersionName == "draft" ? "true" : "false")">
                        <p class="doc-loading">Loading…</p>
                    </div>
                </div>
            }
        </div>

        @* Khay ghi chú trên brief (chỉ bản draft): các ghi chú đã thêm + nút gửi cho BA sửa. Ẩn khi
           chưa có ghi chú nào. Antiforgery token dùng cho POST ReviseBrief qua fetch. *@
        <div class="brief-notes-tray" id="briefNotesTray" hidden>
            @Html.AntiForgeryToken()
            <div class="brief-notes-head">
                <b>Ghi chú của bạn</b> <span class="brief-notes-count" id="briefNotesCount">(0)</span>
                <span class="brief-notes-hint">Bôi đen một đoạn trong bản mô tả rồi bấm "＋ Ghi chú".</span>
            </div>
            <ul class="brief-notes-list" id="briefNotesList"></ul>
        </div>

        <div class="modal-footer">
            @if (selectedVersion == "draft")
            {
                <button type="button" class="btn outline" id="briefNotesSendBtn" hidden
                        title="Gom các ghi chú và nhờ BA sửa lại bản mô tả">
                    ✎ Gửi ghi chú cho BA sửa
                </button>
                <form asp-action="Approve" method="post">
                    <input type="hidden"
                           name="projectId"
                           value="@Model.Id" />

                    <button class="btn approve">
                        Approve this requirement
                    </button>
                </form>
            }
        </div>

    </div>
</div>

@section Breadcrumb {
    Projects <span class="sep">&rsaquo;</span> @Model.Name <span class="sep">&rsaquo;</span> <b>Requirements</b>
}

@section Styles {
    <link rel="stylesheet" href="~/css/requirements.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/doc-history.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/requirements.js" asp-append-version="true"></script>
    <script src="~/js/doc-history.js" asp-append-version="true"></script>
    <script>
        window.REQUIREMENTS_PROJECT_ID = '@Model.Id';
        // Người có quyền DeliveryAdvance (TeamDev/Admin) được dẫn sang Agent Dashboard để duyệt/đẩy bước;
        // user thường chỉ thấy thông báo bàn giao "POC đã sẵn sàng".
        window.REQUIREMENTS_CAN_ADVANCE = @((await Permissions.HasPermissionAsync(User, AppPermission.DeliveryAdvance)) ? "true" : "false");
    </script>
    <script src="~/js/requirement-workflow.js" asp-append-version="true"></script>
}
