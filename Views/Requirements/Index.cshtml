@model Project
@{
    ViewData["Title"] = "Requirements";
    var allDocuments = Model.Documents
    .OrderBy(x => x.FileName)
    .ToList();
    var draftDocuments = Model.Documents
        .Where(x => x.VersionName == "draft")
        .OrderBy(x => x.FileName)
        .ToList();

    var versions = Model.Documents
        .GroupBy(x => x.VersionName)
        .OrderByDescending(g => g.Key == "draft" ? int.MaxValue :
            int.TryParse(g.Key.Replace("V", ""), out var n) ? n : 0)
        .ToList();
    var selectedVersion = ViewBag.SelectedVersion?.ToString() ?? "draft";
    var conversations = Model.Conversations
        .OrderBy(x => x.CreatedAt)
        .ToList();

}

<div class="breadcrumb">
    Projects › @Model.Name › <b>Requirements</b>
</div>

<div class="page-head">
    <div>
        <h1>Requirements</h1>
        <p>Chat with BA to define and capture requirements</p>
    </div>

    <div class="card status">
        <span>Requirement Status</span>
        <b>@(draftDocuments.Any() ? "Draft" : "Empty")</b>
    </div>
</div>

@{
    var workflowStarted = TempData["WorkflowStarted"] != null;
}
<style>
    #wf-panel .wf-badge {
        font-size: 12px;
        padding: 1px 8px;
        border-radius: 10px;
        margin-left: 6px;
        white-space: nowrap;
    }

    #wf-panel .muted {
        color: #64748B;
    }

    .wf-task {
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        padding: 8px 10px;
        margin-top: 8px;
    }

    .wf-task-head {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .wf-meta {
        font-size: 12px;
        margin-top: 2px;
    }

    .wf-err {
        color: #DC2626;
        font-size: 13px;
        margin-top: 6px;
        white-space: pre-wrap;
    }

    .wf-out {
        color: #475569;
        font-size: 12px;
        margin-top: 6px;
        white-space: pre-wrap;
        max-height: 140px;
        overflow: auto;
        background: #F8FAFC;
        padding: 6px 8px;
        border-radius: 6px;
    }

    .wf-banner {
        padding: 8px 10px;
        border-radius: 8px;
        font-size: 14px;
    }

    .wf-run {
        background: #EFF6FF;
        color: #1D4ED8;
    }

    .wf-ok {
        background: #ECFDF5;
        color: #047857;
    }

    .wf-fail {
        background: #FEF2F2;
        color: #B91C1C;
    }
</style>

<div class="card" id="wf-panel" style="margin-bottom:16px;@(workflowStarted ? "" : "display:none;")">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
        <h3 style="margin:0;">Delivery Progress</h3>
        <small id="wf-sub" class="muted"></small>
    </div>
    <div id="wf-body">
        @if (workflowStarted)
        {
            <div class="wf-banner wf-run">⏳ Đã gửi requirement cho agent Developer. Đang khởi động… trang sẽ tự cập nhật.</div>
        }
    </div>
</div>

<div class="grid doc-grid">

    <!-- HISTORY -->
    <aside class="card history-panel">

        <h3>History</h3>

        <input class="search full"
               placeholder="Search in history" />

        @if (versions.Any())
        {
            foreach (var version in versions)
            {
                <div class="history-item">

                    <div class="history-left">
                        <div class="history-icon">📄</div>

                        <div>
                            <div class="history-title">
                                Requirement @version.Key
                            </div>

                            <div class="history-sub">
                                @version.Count() documents
                            </div>
                        </div>
                    </div>

                    <button type="button"
                            class="btn outline small"
                            onclick="openRequirementModal('@version.Key')">
                        View
                    </button>
                </div>
            }
        }
        else
        {
            <div class="empty-history">
                No requirement history yet.
            </div>
        }

        <form asp-action="NewChat"
              method="post"
              class="new-chat-form">

            <input type="hidden"
                   name="projectId"
                   value="@Model.Id" />

            <button class="btn outline full bottom">
                ＋ New Chat
            </button>
        </form>

    </aside>

    <!-- CHAT -->
    <section class="card chat-panel">

        <div id="chatMessages"
             class="chat-messages">

            @if (!conversations.Any())
            {
                <div class="msg ba">
                    <b>BA</b>

                    <p>
                        Xin chào! Tôi là Business Analyst.
                        Bạn có thể mô tả ngắn gọn ý tưởng dự án không?
                    </p>
                </div>
            }

            @foreach (var item in conversations)
            {
                if (item.Role == "user")
                {
                    <div class="msg you">
                        <p>@item.Message</p>
                    </div>
                }
                else
                {
                    <div class="msg ba">
                        <b>BA</b>

                        <p style="white-space: pre-wrap;">
                            @item.Message
                        </p>
                    </div>
                }
            }

            <!-- THINKING -->
            <div id="thinkingBox"
                 class="msg ba thinking"
                 style="display:none;">

                <b>BA</b>

                <div class="thinking-content">

                    <div class="spinner"></div>

                    <span id="thinkingText">
                        BA is analyzing requirements...
                    </span>

                </div>
            </div>

        </div>

        <!-- CHAT INPUT -->
        <form id="chatForm"
              asp-action="Chat"
              method="post"
              class="chatbox">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="projectId"
                   value="@Model.Id" />

            <input type="hidden"
                   id="hiddenMessage"
                   name="message" />

            <input id="messageInput"
                   placeholder="Type your message..."
                   autocomplete="off" />

            <button class="btn primary"
                    type="submit">
                ➤
            </button>
        </form>

    </section>

</div>

<!-- REQUIREMENT MODAL -->
<div id="requirementModal" class="modal-overlay">
    <div class="modal requirement-modal">

        <div class="modal-header">
            <div>
                <h2 id="modalTitle">Requirement</h2>
                <p>Preview generated requirement documents</p>
            </div>

            <button class="modal-close" onclick="closeRequirementModal()">
                ✕
            </button>
        </div>

        <div class="requirement-tabs">
            @foreach (var doc in allDocuments)
            {
                <button class="doc-tab"
                        data-version="@doc.VersionName"
                        onclick="showDocument('@doc.Id')"
                        style="display:none;">
                    @System.IO.Path.GetFileNameWithoutExtension(doc.FileName)
                </button>
            }
        </div>

        <div class="requirement-content">
            @foreach (var doc in allDocuments)
            {
                <div class="doc-preview"
                     id="doc-@doc.Id"
                     data-version="@doc.VersionName"
                     style="display:none;">

                    <h3>@doc.FileName</h3>

                    <pre>@(string.IsNullOrWhiteSpace(doc.Content) ? "No preview available." : doc.Content)</pre>

                    <div class="doc-actions">
                        @*  <a class="btn outline"
                           target="_blank"
                           href="/Requirements/DownloadDocument/@doc.Id">
                            Download
                        </a> *@

                        <a class="btn outline"
                           asp-controller="Requirements"
                           asp-action="DownloadDocument"
                           asp-route-id="@doc.Id">
                            Download
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="modal-footer">
            @if (selectedVersion == "draft")
            {
                <form asp-action="Approve" method="post">
                    <input type="hidden"
                           name="projectId"
                           value="@Model.Id" />

                    <button class="btn approve">
                        I approve this requirement
                    </button>
                </form>
            }
        </div>

    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/requirements.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/requirements.js" asp-append-version="true"></script>
    <script>
        (function () {
        const PID = '@Model.Id';
        const panel = document.getElementById('wf-panel');
        const sub = document.getElementById('wf-sub');
        const bodyEl = document.getElementById('wf-body');
        if (!panel) return;
        const COLOR = { Queued: '#64748B', Running: '#2563EB', Completed: '#16A34A', Failed: '#DC2626',
        Canceled: '#64748B', WaitingForHuman: '#D97706', Blocked: '#D97706', NeedsReview: '#D97706', Retrying: '#2563EB' };
        function badge(s) { const c = COLOR[s] || '#64748B'; return `<span class="wf-badge" style="background:${c}1A;color:${c};border:1px solid ${c}55;">${s}</span>`; }
        function esc(t) { const d = document.createElement('div'); d.textContent = (t == null ? '' : t); return d.innerHTML; }
        async function load() {
        let data;
        try { const r = await fetch(`/Requirements/WorkflowStatus?projectId=${PID}`); data = await r.json(); }
        catch (e) { return; }
        if (!data.hasWorkflow) return; // no workflow yet -> keep panel hidden
        panel.style.display = '';
        sub.innerHTML = `${esc(data.runName)} · ${badge(data.runStatus)} · stage: ${esc(data.stage)}`
        + (data.startedAt ? ` · bắt đầu ${data.startedAt}` : '') + (data.finishedAt ? ` · xong ${data.finishedAt}` : '');
        let rows = (data.tasks || []).map(t => {
        const detail = t.error ? `<div class="wf-err">⚠ ${esc(t.error)}</div>` : (t.output ? `<div class="wf-out">${esc(t.output)}</div>` : '');
        const meta = [t.agentName ? ('agent: ' + esc(t.agentName)) : '', t.attempt ? ('lần ' + t.attempt) : '',
        t.startedAt ? ('bắt đầu ' + t.startedAt) : '', t.finishedAt ? ('xong ' + t.finishedAt) : ''].filter(Boolean).join(' · ');
        return `<div class="wf-task"><div class="wf-task-head"><b>${esc(t.title)}</b> ${badge(t.status)}</div><div class="muted wf-meta">${meta}</div>${detail}</div>`;
        }).join('') || '<p class="muted">Workflow chưa có task nào.</p>';
        let banner = '';
        if (data.runStatus === 'Running' || data.runStatus === 'Queued')
        banner = '<div class="wf-banner wf-run">⏳ Agent đang xử lý… trang sẽ tự cập nhật.</div>';
        else if (data.isCompleted)
        banner = `<div class="wf-banner wf-ok">✓ Hoàn tất. <a href="/Projects/Mockup?projectId=${PID}" target="_blank">Xem demo POC</a></div>`;
        else if (data.runStatus === 'Failed')
        banner = '<div class="wf-banner wf-fail">✗ Workflow thất bại — xem chi tiết lỗi ở task bên dưới.</div>';
        bodyEl.innerHTML = banner + rows;
        if (!data.isTerminal) setTimeout(load, 3000);
        }
        load();
        })();
    </script>
}
