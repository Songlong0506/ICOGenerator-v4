@model Project
@{
    ViewData["Title"] = "Requirements";
    // Trang Requirements chỉ hiển thị tài liệu DỄ HIỂU cho user thường: Product Brief. Bản kỹ thuật
    // (AI Design Spec) và tài liệu kỹ thuật nặng (BRD/SRS/FSD/UserStories) sống ở Agent Dashboard.
    var allDocuments = Model.Documents
        .Where(x => x.FileName == "ProductBrief.docx")
        .ToList();

    var versions = allDocuments
        .GroupBy(x => x.VersionName)
        .OrderByDescending(g => g.Key == "draft" ? int.MaxValue :
            int.TryParse(g.Key.Replace("V", ""), out var n) ? n : 0)
        .ToList();
    var selectedVersion = ViewBag.SelectedVersion?.ToString() ?? "draft";
    var conversations = Model.Conversations
        .OrderBy(x => x.CreatedAt)
        .ToList();
    var workflowRuns = Model.WorkflowRuns
        .OrderBy(x => x.CreatedAt)
        .ToList();
    var workflowStarted = TempData["WorkflowStarted"] != null;
    var autoScrollWorkflowRunId = workflowStarted
        ? workflowRuns.OrderByDescending(x => x.CreatedAt).Select(x => (Guid?)x.Id).FirstOrDefault()
        : null;
    var timelineItems = conversations
        .Select(x => new { Kind = "conversation", CreatedAt = x.CreatedAt, Conversation = (AgentConversation?)x, WorkflowRun = (WorkflowRun?)null })
        .Concat(workflowRuns.Select(x => new { Kind = "workflow", CreatedAt = x.CreatedAt, Conversation = (AgentConversation?)null, WorkflowRun = (WorkflowRun?)x }))
        .OrderBy(x => x.CreatedAt)
        .ToList();

    // Gộp tiến độ thành MỘT timeline thống nhất: các workflow run LIỀN KỀ trên timeline (không có
    // tin nhắn hội thoại xen giữa) thuộc cùng một hành trình — ví dụ "Requirement Design Spec V1"
    // rồi "Delivery Workflow V1" mà worker sinh ngay sau khi spec xong — nên gom vào MỘT panel:
    // một header, một badge, một banner, một feed sự kiện liên tục. Run "lead" (mới nhất trong nhóm)
    // quyết định trạng thái tổng thể; mỗi run vẫn có stream riêng, JS dồn event vào cùng một feed.
    var renderGroups = new List<(string Kind, AgentConversation? Conversation, List<WorkflowRun> Runs)>();
    foreach (var item in timelineItems)
    {
        if (item.Kind == "workflow" && item.WorkflowRun != null)
        {
            if (renderGroups.Count > 0 && renderGroups[^1].Kind == "workflow")
                renderGroups[^1].Runs.Add(item.WorkflowRun);
            else
                renderGroups.Add(("workflow", null, new List<WorkflowRun> { item.WorkflowRun }));
        }
        else if (item.Conversation != null)
        {
            renderGroups.Add(("conversation", item.Conversation, new List<WorkflowRun>()));
        }
    }

    // Gợi ý chỉ hiển thị cho lượt HỎI mới nhất của BA (item cuối timeline). Các lượt cũ coi như đã trả lời.
    var lastItem = timelineItems.LastOrDefault();
    var lastBaSuggestions = (lastItem != null && lastItem.Kind == "conversation"
            && lastItem.Conversation != null && lastItem.Conversation.Role == "assistant")
        ? ParseSuggestions(lastItem.Conversation.Suggestions)
        : new List<string>();

    // Lượt chào đầu tiên (workspace trống) KHÔNG gợi ý: để người dùng tự mô tả ý tưởng dự án.
    // Chỉ khi đã có hội thoại thì mới hiển thị gợi ý cho lượt hỏi mới nhất của BA.
    var displaySuggestions = lastBaSuggestions;

    // Nút "Write Requirement" chỉ "sẵn sàng" (nổi bật) khi lượt BA mới nhất tự báo đã đủ thông tin
    // (ReadyForRequirement = true). Khi chưa đủ — kể cả khi workspace còn trống — nút ở trạng thái "mờ"
    // kèm ghi chú: BA vẫn đang hỏi thêm, nhưng người dùng VẪN có thể bấm tạo ngay nếu muốn (gate readiness
    // phía server vẫn chặn nếu thực sự thiếu thông tin cốt lõi).
    var lastBaTurn = conversations.LastOrDefault(c => c.Role == "assistant");
    var requirementReady = lastBaTurn?.ReadyForRequirement ?? false;

    // Tài liệu nguồn (ảnh/PDF) người dùng upload cho project + cờ vision của model BA (để cảnh báo).
    var sourceFiles = Model.SourceFiles.OrderByDescending(x => x.CreatedAt).ToList();
    var baSupportsVision = ViewBag.BaSupportsVision is bool bv && bv;

    static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024 ? $"{bytes / 1024d / 1024d:0.#} MB" : $"{Math.Max(1, bytes / 1024)} KB";

    static List<string> ParseSuggestions(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<string>();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new List<string>();
        }
        catch
        {
            return new List<string>();
        }
    }
}

<div class="page-head">
    <div>
        <h1>Requirements</h1>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="req-alert error">@TempData["Error"]</div>
}
@if (TempData["SourceUploaded"] != null)
{
    <div class="req-alert ok">Đã upload tài liệu nguồn.</div>
}

<style>
    .req-alert { padding: 10px 12px; border-radius: 6px; margin-bottom: 12px; font-size: 13px; }
    .req-alert.error { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
    .req-alert.ok { color: #166534; background: #f0fdf4; border: 1px solid #bbf7d0; }
    .source-panel { margin-top: 18px; border-top: 1px solid #e5e7eb; padding-top: 14px; }
    .source-vision-warn { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; padding: 8px; border-radius: 6px; font-size: 12px; margin-bottom: 8px; }
    .source-upload-form { display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
    .source-file-input { font-size: 12px; }
    .source-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
    .source-item { display: flex; align-items: center; gap: 6px; font-size: 12px; }
    .source-item .source-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .source-item .source-size { color: #6b7280; }
    .source-del { background: transparent; border: 0; color: #dc2626; cursor: pointer; padding: 2px 4px; width: auto; }
    .source-inline { display: inline; }
</style>

<div class="grid doc-grid">

    <!-- HISTORY -->
    <aside class="card history-panel">

        <h3>History</h3>

        @if (versions.Any())
        {
            foreach (var version in versions)
            {
                <div class="history-item">

                    <div class="history-left">
                        <div class="history-icon">📄</div>

                        <div>
                            <div class="history-title">
                                Requirement @version.Key
                            </div>

                            <div class="history-sub">
                                @version.Count() documents
                            </div>
                        </div>
                    </div>

                    <button type="button"
                            class="btn outline small"
                            onclick="openRequirementModal('@version.Key')">
                        View
                    </button>
                </div>
            }
        }
        else
        {
            <div class="empty-history">
                No requirement history yet.
            </div>
        }

        <!-- SOURCE FILES: ảnh/PDF người dùng cung cấp để BA tham khảo khi viết requirement -->
        <div class="source-panel">
            <h3>Tài liệu nguồn</h3>
            <div class="history-sub" style="margin-bottom:8px;">Ảnh / PDF để BA đọc khi viết requirement.</div>

            @if (!baSupportsVision)
            {
                <div class="source-vision-warn">
                    ⚠️ Model BA hiện không bật <b>vision</b> → ảnh sẽ không được đọc; chỉ phần chữ trích từ PDF được dùng.
                    Bật "Hỗ trợ ảnh (vision)" trong màn hình AI Models nếu cần.
                </div>
            }

            <form asp-action="UploadSource"
                  method="post"
                  enctype="multipart/form-data"
                  class="source-upload-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="file"
                       name="files"
                       multiple
                       accept="image/png,image/jpeg,image/webp,image/gif,application/pdf"
                       class="source-file-input"
                       required />
                <button class="btn outline small full bottom" type="submit">⬆ Upload</button>
            </form>

            @if (sourceFiles.Any())
            {
                <ul class="source-list">
                    @foreach (var src in sourceFiles)
                    {
                        <li class="source-item">
                            <span>@(src.Kind == ICOGenerator.Domain.Enums.SourceFileKind.Image ? "🖼️" : "📄")</span>
                            <span class="source-name" title="@src.FileName">@src.FileName</span>
                            <span class="source-size">@FormatSize(src.SizeBytes)</span>
                            <form asp-action="DeleteSource"
                                  method="post"
                                  class="source-inline"
                                  onsubmit="return confirm('Xoá tài liệu nguồn này?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@src.Id" />
                                <input type="hidden" name="projectId" value="@Model.Id" />
                                <button class="source-del" type="submit" title="Xoá">🗑</button>
                            </form>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="empty-history">Chưa có tài liệu nguồn.</div>
            }
        </div>

        <form asp-action="NewChat"
              method="post"
              class="new-chat-form"
              onsubmit="return confirm('Bắt đầu chat mới sẽ xóa toàn bộ lịch sử hội thoại của dự án này. Tiếp tục?');">

            <input type="hidden"
                   name="projectId"
                   value="@Model.Id" />

            <button class="btn outline full bottom">
                ＋ New Chat
            </button>
        </form>

    </aside>

    <!-- CHAT -->
    <section class="card chat-panel">

        <div id="chatMessages"
             class="chat-messages">

            @if (!conversations.Any())
            {
                <div class="req-msg ba">
                    <b>BA</b>

                    <p>
                        Xin chào! Tôi là Business Analyst.
                        Bạn có thể mô tả ngắn gọn ý tưởng dự án không?
                    </p>
                </div>
            }

            @foreach (var group in renderGroups)
            {
                if (group.Kind == "workflow")
                {
                    var runs = group.Runs;
                    var leadRun = runs[runs.Count - 1];
                    var groupAutoScroll = runs.Any(r => r.Id == autoScrollWorkflowRunId) ? "true" : "false";
                    var runIds = string.Join(",", runs.Select(r => r.Id));
                    // Hành trình kết thúc bằng run delivery → nhãn "Delivery Progress"; ngược lại (chỉ có
                    // run requirement của BA) giữ "Requirement Progress" như trước.
                    var groupTitle = runs.Any(r => r.Name != null && r.Name.Contains("Delivery"))
                        ? "Delivery Progress"
                        : "Requirement Progress";

                    <div id="wf-panel-@leadRun.Id"
                         class="req-msg ba workflow-progress"
                         data-run-ids="@runIds"
                         data-lead-run-id="@leadRun.Id"
                         data-autoscroll="@groupAutoScroll">
                        <div class="workflow-progress-head">
                            <b>BA</b>
                            <span class="workflow-progress-title">@groupTitle</span>
                        </div>
                        <small class="muted wf-sub"></small>
                        <div class="workflow-progress-body wf-body">
                            <div class="wf-banner wf-run">⏳ Đang tải tiến độ delivery…</div>
                        </div>
                    </div>
                }
                else if (group.Conversation?.Role == "user")
                {
                    <div class="req-msg you">
                        <p>@group.Conversation.Message</p>
                    </div>
                }
                else if (group.Conversation != null)
                {
                    <div class="req-msg ba">
                        <b>BA</b>

                        <p style="white-space: pre-wrap;">
                            @group.Conversation.Message
                        </p>
                    </div>
                }
            }
    
            <div id="suggestionList"
                 class="suggestion-list"
                 role="listbox"
                 aria-label="Gợi ý trả lời"
                 style="@(displaySuggestions.Any() ? "" : "display:none;")">
                @{
                    var suggestionIndex = 0;
                }
                @foreach (var suggestion in displaySuggestions)
                {
                    suggestionIndex++;
                    <button type="button"
                            class="suggestion-option"
                            role="option"
                            data-suggestion="@suggestion">
                        <span class="suggestion-option-text">@suggestion</span>
                        <span class="suggestion-option-key">@suggestionIndex</span>
                    </button>
                }
            </div>

            <!-- THINKING -->
            <div id="thinkingBox"
                 class="req-msg ba thinking"
                 style="display:none;">

                <b>BA</b>

                <div class="thinking-content">

                    <div class="spinner"></div>

                    <span id="thinkingText">
                        BA is analyzing requirements...
                    </span>

                </div>
            </div>

        </div>

        <!-- COMPOSER: action buttons (write-requirement + approve-stage) + chat input, anchored to bottom -->
        <div class="chat-composer">

            <!-- ACTION BUTTONS: thao tác điều khiển workflow, tách khỏi luồng chat hội thoại -->
            <div class="composer-actions">

                <!-- WRITE REQUIREMENT: sinh bản mô tả sản phẩm (Product Brief) DỄ HIỂU cho user.
                     Tài liệu kỹ thuật (BRD/SRS/FSD/UserStories) do team dev trigger ở Agent Dashboard.
                     Nút ở 2 trạng thái: "mờ" (write-req-waiting) khi BA còn câu hỏi, "sẵn sàng"
                     (write-req-ready) khi BA đã đủ thông tin. Cả hai đều bấm được (lối thoát thủ công);
                     khi chưa sẵn sàng có ghi chú nhắc người dùng. -->
                <form asp-action="WriteRequirement"
                      method="post"
                      class="write-req @(requirementReady ? "write-req-ready" : "write-req-waiting")"
                      onsubmit="var b=this.querySelector('button'); b.disabled=true; b.textContent='Đang tạo tài liệu…';">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <button class="btn write-req-btn @(requirementReady ? "primary" : "outline")"
                            type="submit"
                            title="@(requirementReady
                                ? "BA đã thu thập đủ thông tin — tạo bản mô tả sản phẩm."
                                : "BA vẫn đang hỏi thêm thông tin. Bạn vẫn có thể tạo ngay, nhưng nên trả lời thêm để tài liệu đầy đủ hơn.")">
                        📝 Write Requirement
                    </button>
                    @if (!requirementReady)
                    {
                        <span class="write-req-hint">BA đang hỏi thêm — bạn vẫn có thể tạo ngay.</span>
                    }
                </form>

                <!-- Cổng "Duyệt & tiếp tục" (và Retry/Reject) ĐÃ CHUYỂN sang Agent Dashboard: user thường
                     dừng ở bước POC, chỉ TeamDev/Admin (quyền DeliveryAdvance) mới đẩy tiếp các bước
                     Architecture/code/test. Trang này chỉ hiển thị tiến độ; banner bên dưới sẽ hướng
                     dẫn người có quyền sang dashboard. -->

            </div>

            <!-- CHAT INPUT -->
            <form id="chatForm"
                  asp-action="Chat"
                  method="post"
                  class="req-chatbox">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="projectId"
                       value="@Model.Id" />

                <input type="hidden"
                       id="hiddenMessage"
                       name="message" />

              <textarea id="messageInput"
                          rows="1"
                          placeholder="Type your message..."
                          autocomplete="off"></textarea>

                <button class="btn primary"
                        type="submit"
                        aria-label="Send message">
                    ➤
                </button>
            </form>

        </div>

    </section>

</div>

<!-- REQUIREMENT MODAL -->
<div id="requirementModal" class="req-modal-overlay">
    <div class="requirement-modal">

        <div class="modal-header">
            <div>
                <h2 id="modalTitle">Requirement</h2>
            </div>

            <button class="modal-close" onclick="closeRequirementModal()">
                ✕
            </button>
        </div>

        <div class="requirement-tabs">
            @foreach (var doc in allDocuments)
            {
                <button class="doc-tab"
                        data-version="@doc.VersionName"
                        onclick="showDocument('@doc.Id')"
                        style="display:none;">
                    @System.IO.Path.GetFileNameWithoutExtension(doc.FileName)
                </button>
            }
        </div>

        <div class="requirement-content">
            @foreach (var doc in allDocuments)
            {
                <div class="doc-preview"
                     id="doc-@doc.Id"
                     data-version="@doc.VersionName"
                     style="display:none;">

                    <h3>@doc.FileName</h3>

                    <div class="doc-render"
                         data-doc-id="@doc.Id"
                         data-loaded="false">
                        <p class="doc-loading">Loading…</p>
                    </div>

                    <div class="doc-actions">
                        <a class="btn outline"
                           asp-controller="Requirements"
                           asp-action="DownloadDocument"
                           asp-route-id="@doc.Id">
                            Download
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="modal-footer">
            @if (selectedVersion == "draft")
            {
                <form asp-action="Approve" method="post">
                    <input type="hidden"
                           name="projectId"
                           value="@Model.Id" />

                    <button class="btn approve">
                        Approve this requirement
                    </button>
                </form>
            }
        </div>

    </div>
</div>

@section Breadcrumb {
    Projects <span class="sep">&rsaquo;</span> @Model.Name <span class="sep">&rsaquo;</span> <b>Requirements</b>
}

@section Styles {
    <link rel="stylesheet" href="~/css/requirements.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/requirements.js" asp-append-version="true"></script>
    <script>
        window.REQUIREMENTS_PROJECT_ID = '@Model.Id';
        // Người có quyền DeliveryAdvance (TeamDev/Admin) được dẫn sang Agent Dashboard để duyệt/đẩy bước;
        // user thường chỉ thấy thông báo bàn giao "POC đã sẵn sàng".
        window.REQUIREMENTS_CAN_ADVANCE = @((await Permissions.HasPermissionAsync(User, AppPermission.DeliveryAdvance)) ? "true" : "false");
    </script>
    <script src="~/js/requirement-workflow.js" asp-append-version="true"></script>
}
