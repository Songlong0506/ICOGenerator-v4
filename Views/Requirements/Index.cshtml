@model Project
@{
    ViewData["Title"] = "Requirements";
    var allDocuments = Model.Documents
    .OrderBy(x => x.FileName)
    .ToList();
    var draftDocuments = Model.Documents
        .Where(x => x.VersionName == "draft")
        .OrderBy(x => x.FileName)
        .ToList();

    var versions = Model.Documents
        .GroupBy(x => x.VersionName)
        .OrderByDescending(g => g.Key == "draft" ? int.MaxValue :
            int.TryParse(g.Key.Replace("V", ""), out var n) ? n : 0)
        .ToList();
    var selectedVersion = ViewBag.SelectedVersion?.ToString() ?? "draft";
    var conversations = Model.Conversations
        .OrderBy(x => x.CreatedAt)
        .ToList();
    var workflowRuns = Model.WorkflowRuns
        .OrderBy(x => x.CreatedAt)
        .ToList();
    var workflowStarted = TempData["WorkflowStarted"] != null;
    var autoScrollWorkflowRunId = workflowStarted
        ? workflowRuns.OrderByDescending(x => x.CreatedAt).Select(x => (Guid?)x.Id).FirstOrDefault()
        : null;
    var timelineItems = conversations
        .Select(x => new { Kind = "conversation", CreatedAt = x.CreatedAt, Conversation = x, WorkflowRun = (WorkflowRun?)null })
        .Concat(workflowRuns.Select(x => new { Kind = "workflow", CreatedAt = x.CreatedAt, Conversation = (AgentConversation?)null, WorkflowRun = x }))
        .OrderBy(x => x.CreatedAt)
        .ToList();

    // Gợi ý chỉ hiển thị cho lượt HỎI mới nhất của BA (item cuối timeline). Các lượt cũ coi như đã trả lời.
    var lastItem = timelineItems.LastOrDefault();
    var lastBaSuggestions = (lastItem != null && lastItem.Kind == "conversation"
            && lastItem.Conversation != null && lastItem.Conversation.Role == "assistant")
        ? ParseSuggestions(lastItem.Conversation.Suggestions)
        : new List<string>();

    // Workspace trống: gợi sẵn vài loại dự án để người dùng bắt đầu nhanh (vẫn nhập tự do được).
    var starterSuggestions = new List<string>
    {
        "Website bán hàng online",
        "App quản lý công việc nhóm",
        "Hệ thống đặt lịch hẹn",
        "Ứng dụng quản lý kho hàng"
    };

    var displaySuggestions = timelineItems.Any() ? lastBaSuggestions : starterSuggestions;

    static List<string> ParseSuggestions(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new List<string>();
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new List<string>();
        }
        catch
        {
            return new List<string>();
        }
    }
}

<div class="page-head">
    <div>
        <h1>Requirements</h1>
    </div>

    <div class="card status">
        <span>Requirement Status</span>
        <b>@(draftDocuments.Any() ? "Draft" : "Empty")</b>
    </div>
</div>

<div class="grid doc-grid">

    <!-- HISTORY -->
    <aside class="card history-panel">

        <h3>History</h3>

        @if (versions.Any())
        {
            foreach (var version in versions)
            {
                <div class="history-item">

                    <div class="history-left">
                        <div class="history-icon">📄</div>

                        <div>
                            <div class="history-title">
                                Requirement @version.Key
                            </div>

                            <div class="history-sub">
                                @version.Count() documents
                            </div>
                        </div>
                    </div>

                    <button type="button"
                            class="btn outline small"
                            onclick="openRequirementModal('@version.Key')">
                        View
                    </button>
                </div>
            }
        }
        else
        {
            <div class="empty-history">
                No requirement history yet.
            </div>
        }

        <form asp-action="NewChat"
              method="post"
              class="new-chat-form"
              onsubmit="return confirm('Bắt đầu chat mới sẽ xóa toàn bộ lịch sử hội thoại của dự án này. Tiếp tục?');">

            <input type="hidden"
                   name="projectId"
                   value="@Model.Id" />

            <button class="btn outline full bottom">
                ＋ New Chat
            </button>
        </form>

    </aside>

    <!-- CHAT -->
    <section class="card chat-panel">

        <div id="chatMessages"
             class="chat-messages">

            @if (!conversations.Any())
            {
                <div class="msg ba">
                    <b>BA</b>

                    <p>
                        Xin chào! Tôi là Business Analyst.
                        Bạn có thể mô tả ngắn gọn ý tưởng dự án không?
                    </p>
                </div>
            }

            @foreach (var item in timelineItems)
            {
                if (item.Kind == "workflow" && item.WorkflowRun != null)
                {
                    var run = item.WorkflowRun;
                    var autoScroll = autoScrollWorkflowRunId == run.Id ? "true" : "false";

                    <div id="wf-panel-@run.Id"
                         class="msg ba workflow-progress"
                         data-run-id="@run.Id"
                         data-autoscroll="@autoScroll">
                        <div class="workflow-progress-head">
                            <b>BA</b>
                            <span class="workflow-progress-title">@(run.Name != null && run.Name.Contains("Requirement") ? "Requirement Progress" : "Delivery Progress")</span>
                        </div>
                        <small id="wf-sub-@run.Id" class="muted wf-sub"></small>
                        <div id="wf-body-@run.Id" class="workflow-progress-body wf-body">
                            <div class="wf-banner wf-run">⏳ Đang tải tiến độ delivery…</div>
                        </div>
                    </div>
                }
                else if (item.Conversation?.Role == "user")
                {
                    <div class="msg you">
                        <p>@item.Conversation.Message</p>
                    </div>
                }
                else if (item.Conversation != null)
                {
                    <div class="msg ba">
                        <b>BA</b>

                        <p style="white-space: pre-wrap;">
                            @item.Conversation.Message
                        </p>
                    </div>
                }
            }

            <!-- SUGGESTION CHIPS: đáp án gợi ý cho lượt hỏi mới nhất của BA (giống plan mode).
                 Người dùng bấm để trả lời nhanh, hoặc tự gõ vào ô bên dưới nếu không khớp. -->
            <div id="suggestionChips"
                 class="suggestion-chips"
                 aria-label="Gợi ý trả lời"
                 style="@(displaySuggestions.Any() ? "" : "display:none;")">
                @foreach (var suggestion in displaySuggestions)
                {
                    <button type="button"
                            class="suggestion-chip"
                            data-suggestion="@suggestion">
                        @suggestion
                    </button>
                }
            </div>

            <!-- THINKING -->
            <div id="thinkingBox"
                 class="msg ba thinking"
                 style="display:none;">

                <b>BA</b>

                <div class="thinking-content">

                    <div class="spinner"></div>

                    <span id="thinkingText">
                        BA is analyzing requirements...
                    </span>

                </div>
            </div>

        </div>

        <!-- COMPOSER: write-requirement action + chat input, anchored to bottom -->
        <div class="chat-composer">

            <!-- WRITE REQUIREMENT (generate the 5 docs on demand) -->
            <form asp-action="WriteRequirement"
                  method="post"
                  class="write-req"
                  onsubmit="var b=this.querySelector('button'); b.disabled=true; b.textContent='Đang tạo tài liệu…';">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />
                <button class="btn outline write-req-btn" type="submit"
                        title="Sinh/cập nhật BRD, SRS, FSD, User Stories, AI Design Spec từ hội thoại">
                    📝 Write Requirement
                </button>
            </form>

            <!-- CHAT INPUT -->
            <form id="chatForm"
                  asp-action="Chat"
                  method="post"
                  class="chatbox">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="projectId"
                       value="@Model.Id" />

                <input type="hidden"
                       id="hiddenMessage"
                       name="message" />

              <textarea id="messageInput"
                          rows="1"
                          placeholder="Type your message..."
                          autocomplete="off"></textarea>

                <button class="btn primary"
                        type="submit"
                        aria-label="Send message">
                    ➤
                </button>
            </form>

        </div>

    </section>

</div>

<!-- REQUIREMENT MODAL -->
<div id="requirementModal" class="modal-overlay">
    <div class="modal requirement-modal">

        <div class="modal-header">
            <div>
                <h2 id="modalTitle">Requirement</h2>
                <p>Preview generated requirement documents</p>
            </div>

            <button class="modal-close" onclick="closeRequirementModal()">
                ✕
            </button>
        </div>

        <div class="requirement-tabs">
            @foreach (var doc in allDocuments)
            {
                <button class="doc-tab"
                        data-version="@doc.VersionName"
                        onclick="showDocument('@doc.Id')"
                        style="display:none;">
                    @System.IO.Path.GetFileNameWithoutExtension(doc.FileName)
                </button>
            }
        </div>

        <div class="requirement-content">
            @foreach (var doc in allDocuments)
            {
                <div class="doc-preview"
                     id="doc-@doc.Id"
                     data-version="@doc.VersionName"
                     style="display:none;">

                    <h3>@doc.FileName</h3>

                    <div class="doc-render"
                         data-doc-id="@doc.Id"
                         data-loaded="false">
                        <p class="doc-loading">Loading…</p>
                    </div>

                    <div class="doc-actions">
                        @*  <a class="btn outline"
                           target="_blank"
                           href="/Requirements/DownloadDocument/@doc.Id">
                            Download
                        </a> *@

                        <a class="btn outline"
                           asp-controller="Requirements"
                           asp-action="DownloadDocument"
                           asp-route-id="@doc.Id">
                            Download
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="modal-footer">
            @if (selectedVersion == "draft")
            {
                <form asp-action="Approve" method="post">
                    <input type="hidden"
                           name="projectId"
                           value="@Model.Id" />

                    <button class="btn approve">
                        Approve this requirement
                    </button>
                </form>
            }
        </div>

    </div>
</div>

@section Breadcrumb {
    Projects <span class="sep">&rsaquo;</span> @Model.Name <span class="sep">&rsaquo;</span> <b>Requirements</b>
}

@section Styles {
    <link rel="stylesheet" href="~/css/requirements.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/requirements.js" asp-append-version="true"></script>
    <script>
        (function () {
            const PID = '@Model.Id';
            const TOKEN = (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '';
            const panels = Array.from(document.querySelectorAll('.workflow-progress[data-run-id]'));

            if (!panels.length) return;

            const COLOR = {
                Queued: '#64748B',
                Running: '#2563EB',
                Completed: '#16A34A',
                Failed: '#DC2626',
                Canceled: '#64748B',
                WaitingForHuman: '#D97706',
                Blocked: '#D97706',
                NeedsReview: '#D97706',
                Retrying: '#2563EB'
            };

            function badge(status) {
                const color = COLOR[status] || '#64748B';
                return `<span class="wf-badge" style="background:${color}1A;color:${color};border:1px solid ${color}55;">${status}</span>`;
            }

            function esc(text) {
                const div = document.createElement('div');
                div.textContent = text == null ? '' : text;
                return div.innerHTML;
            }

            const EVENT_ICON = {
                start: '🚀',
                setup: '⚙️',
                thinking: '🤔',
                tool: '🔧',
                observation: '📥',
                final: '✅',
                completed: '🎉',
                error: '❌'
            };

            function maybeScrollPanel(panel, data) {
                if (panel.dataset.autoscroll !== 'true') return;

                panel.scrollIntoView({ block: 'nearest' });

                if (data.isTerminal) {
                    panel.dataset.autoscroll = 'false';
                }
            }

            function ensureSkeleton(panel) {
                const bodyEl = panel.querySelector('.wf-body');
                if (bodyEl.querySelector('.wf-feed')) return;

                bodyEl.innerHTML =
                    '<div class="wf-feed"></div>' +
                    '<div class="wf-activity" style="display:none;">' +
                        '<span class="wf-typing"><span></span><span></span><span></span></span>' +
                        '<span class="wf-activity-text"></span>' +
                    '</div>' +
                    '<div class="wf-banner-slot"></div>';
            }

            function appendEvents(panel, events) {
                if (!events.length) return;

                const feed = panel.querySelector('.wf-feed');

                for (const ev of events) {
                    const icon = EVENT_ICON[ev.kind] || '•';
                    const time = new Date(ev.at).toLocaleTimeString();
                    const item = document.createElement('div');
                    item.className = `wf-event wf-event-${esc(ev.kind)}`;

                    let html =
                        `<span class="wf-event-icon">${icon}</span>` +
                        `<div class="wf-event-main">` +
                            `<div class="wf-event-msg">${esc(ev.message)}` +
                                `<span class="wf-event-time">${esc(time)}</span></div>`;

                    if (ev.detail) {
                        html += `<details class="wf-event-detail"><summary>chi tiết</summary><pre>${esc(ev.detail)}</pre></details>`;
                    }

                    html += '</div>';
                    item.innerHTML = html;
                    feed.appendChild(item);
                }

                feed.scrollTop = feed.scrollHeight;
            }

            function updateActivity(panel, data) {
                const activity = panel.querySelector('.wf-activity');
                const textEl = panel.querySelector('.wf-activity-text');
                const running = data.runStatus === 'Running' || data.runStatus === 'Queued';

                if (!running) {
                    activity.style.display = 'none';
                    return;
                }

                const lastMsg = panel.dataset.lastMsg ||
                    (data.runStatus === 'Queued' ? 'Đang chờ agent nhận task…' : 'Agent đang xử lý…');

                textEl.textContent = lastMsg;
                activity.style.display = 'flex';
            }

            function gateForm(action, runId, label, cls) {
                return `<form method="post" action="${action}" style="display:inline-block;margin-right:8px;">` +
                    `<input type="hidden" name="__RequestVerificationToken" value="${TOKEN}">` +
                    `<input type="hidden" name="projectId" value="${PID}">` +
                    `<input type="hidden" name="runId" value="${esc(runId)}">` +
                    `<button class="btn ${cls}" type="submit">${label}</button>` +
                    `</form>`;
            }

            function updateBanner(panel, data) {
                const slot = panel.querySelector('.wf-banner-slot');

                // Chỉ reset "gate" key khi KHÔNG còn ở trạng thái chờ duyệt.
                if (data.runStatus !== 'WaitingForHuman') slot.dataset.gate = '';

                if (data.isCompleted) {
                    if (data.runKind === 'Requirement') {
                        slot.innerHTML = `<div class="wf-banner wf-ok">✓ Đã tạo/cập nhật tài liệu requirement.</div>`;

                        // Reload đúng 1 lần để hiển thị tài liệu draft + tin nhắn BA mới.
                        const reloadKey = 'wf-reloaded-' + panel.dataset.runId;
                        if (!sessionStorage.getItem(reloadKey)) {
                            sessionStorage.setItem(reloadKey, '1');
                            setTimeout(() => location.reload(), 1200);
                        }
                    } else {
                        slot.innerHTML = `<div class="wf-banner wf-ok">✓ Hoàn tất tất cả các bước. <a href="/Projects/Mockup?projectId=${PID}" target="_blank">Xem demo POC</a></div>`;
                    }
                } else if (data.runStatus === 'WaitingForHuman') {
                    // Tránh dựng lại form mỗi nhịp poll (gây nháy / hủy click): chỉ render
                    // lại khi sang cổng mới.
                    if (slot.dataset.gate === data.currentStage) return;
                    slot.dataset.gate = data.currentStage;

                    const pocLink = data.pocReady
                        ? ` <a href="/Projects/Mockup?projectId=${PID}" target="_blank">Xem POC</a>`
                        : '';
                    const nextLabel = data.nextStageTitle ? `: ${esc(data.nextStageTitle)}` : '';
                    const approve = gateForm('/Requirements/ApproveStage', data.runId, `✓ Duyệt &amp; tiếp tục${nextLabel}`, 'approve');
                    const reject = gateForm('/Requirements/RejectStage', data.runId, '✗ Chưa đúng ý — sửa requirement', 'outline');

                    slot.innerHTML =
                        `<div class="wf-banner wf-wait">⏸️ Bước hiện tại đã xong — chờ bạn duyệt.${pocLink}` +
                        `<div class="wf-gate-actions" style="margin-top:8px;">${approve}${reject}</div></div>`;
                } else if (data.runStatus === 'Canceled') {
                    slot.innerHTML = `<div class="wf-banner wf-fail">✗ Đã hủy. Hãy bổ sung requirement với BA, bấm “Write Requirement” rồi “Approve” để chạy lại.</div>`;
                } else if (data.runStatus === 'Failed') {
                    const err = (data.tasks || []).map(t => t.error).filter(Boolean).join('\n');
                    slot.innerHTML = `<div class="wf-banner wf-fail">✗ Workflow thất bại.${err ? `<pre class="wf-err">${esc(err)}</pre>` : ''}</div>`;
                } else {
                    slot.innerHTML = '';
                }
            }

            async function load(panel) {
                const runId = panel.dataset.runId;
                const afterSeq = panel.dataset.afterSeq || '0';
                const sub = panel.querySelector('.wf-sub');
                let data;

                try {
                    const response = await fetch(`/Requirements/WorkflowStatus?projectId=${PID}&runId=${runId}&afterSeq=${afterSeq}`);
                    data = await response.json();
                } catch (e) {
                    setTimeout(() => load(panel), 3000);
                    return;
                }

                if (!data.hasWorkflow) return;

                sub.innerHTML = `${esc(data.runName)} · ${badge(data.runStatus)}`;

                ensureSkeleton(panel);

                const events = data.events || [];
                appendEvents(panel, events);

                if (events.length) {
                    panel.dataset.afterSeq = String(data.lastEventSeq);
                    panel.dataset.lastMsg = events[events.length - 1].message;
                }

                updateActivity(panel, data);
                updateBanner(panel, data);
                maybeScrollPanel(panel, data);

                if (!data.isTerminal) setTimeout(() => load(panel), 1500);
            }

            panels.forEach(load);
        })();
    </script>
}
