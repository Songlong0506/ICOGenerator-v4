@model ICOGenerator.Application.Account.LoginVm
@{
    Layout = null;
    var returnUrl = ViewBag.ReturnUrl as string;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập · ICO Generator</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .login-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f1f5f9; padding: 24px; }
        .login-card { background: #fff; width: min(400px, 100%); border-radius: 16px; box-shadow: 0 20px 60px rgba(15, 23, 42, .12); padding: 32px; }
        .login-card h1 { font-size: 20px; margin: 0 0 4px; color: #0f172a; }
        .login-card .sub { color: #64748b; font-size: 14px; margin: 0 0 24px; }
        .login-field { margin-bottom: 16px; }
        .login-field label { display: block; font-size: 13px; font-weight: 600; color: #334155; margin-bottom: 6px; }
        .login-field input { width: 100%; box-sizing: border-box; padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 10px; font-size: 14px; }
        .login-field input:focus { outline: none; border-color: #007bc0; box-shadow: 0 0 0 3px rgba(0, 123, 192, .15); }
        .login-btn { width: 100%; padding: 11px; background: #007bc0; color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 600; cursor: pointer; }
        .login-btn:hover { background: #0069a6; }
        .login-error { background: #fee2e2; color: #991b1b; border-radius: 10px; padding: 10px 12px; font-size: 13px; margin-bottom: 16px; }
        .login-brand { font-weight: 800; letter-spacing: .5px; color: #007bc0; margin-bottom: 18px; }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-card">
            <div class="login-brand">ICO Generator</div>
            <h1>Đăng nhập</h1>
            <p class="sub">Vui lòng đăng nhập để tiếp tục.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="login-error" role="alert"></div>
            }

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                <div class="login-field">
                    <label asp-for="Username">Tên đăng nhập</label>
                    <input asp-for="Username" autocomplete="username" autofocus />
                </div>
                <div class="login-field">
                    <label asp-for="Password">Mật khẩu</label>
                    <input asp-for="Password" type="password" autocomplete="current-password" />
                </div>
                <button class="login-btn" type="submit">Đăng nhập</button>
            </form>
        </div>
    </div>
</body>
</html>
