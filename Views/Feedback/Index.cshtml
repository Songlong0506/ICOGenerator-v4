@using ICOGenerator.Application.Feedback
@using ICOGenerator.Domain.Enums
@model FeedbackPage

@{
    string TypeBadge(FeedbackType t) => t switch
    {
        FeedbackType.Bug => "orange",
        FeedbackType.Suggestion => "blue",
        FeedbackType.Experience => "green",
        _ => "gray"
    };
    string StatusBadge(FeedbackStatus s) => s switch
    {
        FeedbackStatus.New => "blue",
        FeedbackStatus.InProgress => "orange",
        FeedbackStatus.Resolved => "green",
        _ => "gray"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/feedback.css" asp-append-version="true" />
}

<div class="page-head">
    <div>
        <h1>Feedback</h1>
        <p>Báo lỗi, góp ý hoặc chia sẻ trải nghiệm dùng app. Bạn có thể đính kèm ảnh, PDF, tài liệu hoặc video.</p>
    </div>
</div>

<div class="fb-grid">

    <div class="card fb-form-card">
        <h2 style="margin-top:0">Gửi phản hồi</h2>
        <form asp-action="Submit" method="post" enctype="multipart/form-data">
            <label for="fbType">Loại phản hồi</label>
            <select id="fbType" name="Type">
                @foreach (var t in Enum.GetValues<FeedbackType>())
                {
                    <option value="@t">@t.GetTitle()</option>
                }
            </select>

            <label for="fbTitle">Tiêu đề *</label>
            <input id="fbTitle" name="Title" maxlength="200" required placeholder="Tóm tắt ngắn gọn" />

            <label for="fbMessage">Nội dung *</label>
            <textarea id="fbMessage" name="Message" rows="6" required placeholder="Mô tả chi tiết lỗi/góp ý, các bước tái hiện, kết quả mong đợi..."></textarea>

            <label for="fbFiles">Đính kèm</label>
            <input id="fbFiles" class="fb-file" type="file" name="files" multiple
                   accept="@string.Join(",", Model.AllowedExtensions)" />
            <p class="fb-hint">
                Ảnh, PDF, tài liệu (Word/Excel/PowerPoint/text) hoặc video. Tối đa @Model.MaxFiles file,
                @(Model.MaxFileBytes / 1024 / 1024)MB mỗi file.
            </p>

            <div class="fb-submit-bar">
                <button class="btn primary full" type="submit">Gửi phản hồi</button>
            </div>
        </form>
    </div>

    <div>
        @{
            var fbHasFilter = Model.StatusFilter != null || Model.TypeFilter != null;
        }
        @* Command bar (mẫu Bosch): lọc phản hồi theo Loại + Trạng thái (form GET, tự submit khi đổi). *@
        <form asp-action="Index" method="get" class="command-bar cbar-filter-form">
            <div class="cbar-field">
                <label for="fb-filter-type">Loại</label>
                <select id="fb-filter-type" name="type" data-caption="Loại" onchange="this.form.submit()">
                    <option value="">Tất cả loại</option>
                    @foreach (var t in Enum.GetValues<FeedbackType>())
                    {
                        <option value="@t" selected="@(Model.TypeFilter == t)">@t.GetTitle()</option>
                    }
                </select>
            </div>
            <div class="cbar-field">
                <label for="fb-filter-status">Trạng thái</label>
                <select id="fb-filter-status" name="status" data-caption="Trạng thái" onchange="this.form.submit()">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (var s in Enum.GetValues<FeedbackStatus>())
                    {
                        <option value="@s" selected="@(Model.StatusFilter == s)">@s.GetTitle()</option>
                    }
                </select>
            </div>
            @if (fbHasFilter)
            {
                <a class="cbar-btn" asp-action="Index">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                    <span>Xóa lọc</span>
                </a>
            }
        </form>

        @if (Model.Items.Count == 0)
        {
            <div class="card fb-empty">
                Chưa có phản hồi nào. Hãy là người đầu tiên gửi góp ý ở bên trái!
            </div>
        }
        else
        {
            <div class="fb-list">
                @foreach (var item in Model.Items)
                {
                    <div class="card fb-item">
                        <div class="fb-item-head">
                            <span class="badge @TypeBadge(item.Type)">@item.Type.GetTitle()</span>
                            <h3>@item.Title</h3>
                            <span class="badge @StatusBadge(item.Status)">@item.Status.GetTitle()</span>
                        </div>

                        <p class="fb-meta">
                            @item.SubmittedByName · @item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </p>

                        <div class="fb-msg">@item.Message</div>

                        @if (item.Attachments.Count > 0)
                        {
                            <div class="fb-atts">
                                @foreach (var att in item.Attachments)
                                {
                                    if (att.IsImage)
                                    {
                                        <a class="fb-att img" target="_blank" title="@att.FileName"
                                           href="@Url.Action("Attachment", new { id = att.Id })">
                                            <img src="@Url.Action("Attachment", new { id = att.Id })" alt="@att.FileName" loading="lazy" />
                                        </a>
                                    }
                                    else
                                    {
                                        <a class="fb-att file" title="@att.FileName"
                                           href="@Url.Action("Attachment", new { id = att.Id, download = true })">
                                            <svg class="ico" viewBox="0 0 24 24">
                                                @if (att.IsVideo)
                                                {
                                                    <polygon points="5 3 19 12 5 21 5 3" />
                                                }
                                                else
                                                {
                                                    <text><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M14 2v6h6" /></text>
                                                }
                                            </svg>
                                            <span class="fb-att-name">@att.FileName</span>
                                            <span class="fb-att-size">@att.SizeLabel</span>
                                        </a>
                                    }
                                }
                            </div>
                        }

                        @if (Model.CanManage || item.IsMine)
                        {
                            <div class="fb-item-foot">
                                @if (Model.CanManage)
                                {
                                    <form class="fb-status-form" asp-action="UpdateStatus" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <label style="margin:0">Trạng thái</label>
                                        <select name="status" onchange="this.form.submit()">
                                            @foreach (var s in Enum.GetValues<FeedbackStatus>())
                                            {
                                                <option value="@s" selected="@(item.Status == s)">@s.GetTitle()</option>
                                            }
                                        </select>
                                    </form>
                                }
                                <span class="spacer"></span>
                                <form asp-action="Delete" method="post"
                                      onsubmit="return confirm('Xóa phản hồi này? Hành động không thể hoàn tác.');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="link-danger">Xóa</button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
