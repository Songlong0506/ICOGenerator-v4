@using ICOGenerator.Application.Audit
@using ICOGenerator.Domain.Enums
@model AuditLogListPage

@{
    string CategoryBadge(AuditCategory c) => c switch
    {
        AuditCategory.Settings => "blue",
        AuditCategory.Role => "orange",
        AuditCategory.Agent => "green",
        _ => "gray"
    };
    string ActionBadge(AuditAction a) => a switch
    {
        AuditAction.Create => "green",
        AuditAction.Update => "blue",
        _ => "orange"
    };

    // Tên hiển thị người thực hiện (fallback về username khi không tra được), kèm vai trò nếu có.
    string ActorDisplay(string? username) =>
        string.IsNullOrWhiteSpace(username) ? ""
            : (Model.ActorDisplayNames.TryGetValue(username.Trim(), out var dn) ? dn : username);
    string ActorWithRole(string? username, string? role) =>
        ActorDisplay(username) + (string.IsNullOrEmpty(role) ? "" : $" · {role}");
}

@section Styles {
    <link rel="stylesheet" href="~/css/audit.css" asp-append-version="true" />
}

<div class="page-head">
    <div>
        <h1>Audit Log</h1>
    </div>
</div>

@await Html.PartialAsync("_CommandBar", new CommandBarModel
{
    SearchPlaceholder = "Tìm trong nhật ký…",
    TargetSelector = "#auditTable",
    FilterPanelId = "auditFilter",
    FilterPanelOpen = Model.CategoryFilter != null,
    FilterActive = Model.CategoryFilter != null,
    SortOptions = new[]
    {
        new CommandBarSort { Label = "Thời gian mới nhất", Column = 4, Descending = true },
        new CommandBarSort { Label = "Thời gian cũ nhất", Column = 4 },
        new CommandBarSort { Label = "Loại (A→Z)", Column = 0 },
    }
})

<div id="auditFilter" class="card filter-card cbar-panel">
    <form asp-action="Index" method="get" class="filter-bar">
        <div class="filter-field">
            <label for="audit-category">Loại</label>
            <select id="audit-category" name="category" onchange="this.form.submit()">
                <option value="">Tất cả loại</option>
                @foreach (var c in Enum.GetValues<AuditCategory>())
                {
                    <option value="@c" selected="@(Model.CategoryFilter == c)">@c.GetTitle()</option>
                }
            </select>
        </div>
        @if (Model.CategoryFilter != null)
        {
            <div class="filter-actions">
                <a class="btn outline" asp-action="Index">Xóa lọc</a>
            </div>
        }
    </form>
</div>

@if (Model.Items.Count == 0)
{
    <div class="card audit-empty">
        Chưa có thay đổi cấu hình nào được ghi lại@(Model.CategoryFilter != null ? " cho loại đã chọn" : "").
    </div>
}
else
{
    <div class="card table-card">
        <table id="auditTable" class="audit-table">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Action</th>
                    <th>Summary</th>
                    <th>Performed By</th>
                    <th>Time</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><span class="badge @CategoryBadge(item.Category)">@item.Category.GetTitle()</span></td>
                        <td><span class="badge @ActionBadge(item.Action)">@item.Action.GetTitle()</span></td>
                        <td class="audit-summary">@item.Summary</td>
                        <td>@ActorWithRole(item.ActorUsername, item.ActorRole)</td>
                        <td class="audit-time">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td class="actions">
                            <button class="btn small outline"
                                    type="button"
                                    aria-label="Xem chi tiết"
                                    data-category="@item.Category.GetTitle()"
                                    data-category-class="@CategoryBadge(item.Category)"
                                    data-action="@item.Action.GetTitle()"
                                    data-action-class="@ActionBadge(item.Action)"
                                    data-summary="@item.Summary"
                                    data-actor="@ActorWithRole(item.ActorUsername, item.ActorRole)"
                                    data-time="@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")"
                                    data-entity="@item.EntityId"
                                    data-before="@(item.BeforeJson ?? "")"
                                    data-after="@(item.AfterJson ?? "")"
                                    onclick="openAuditDetail(this)">
                                <i class="bi bi-eye" aria-hidden="true"></i> Chi tiết
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @await Html.PartialAsync("_Pager", new ICOGenerator.Application.Shared.PagerModel
        {
            Page = Model.Page,
            TotalPages = Model.TotalPages,
            PageSize = Model.PageSize,
            PageUrl = p => Url.Action("Index", new { category = Model.CategoryFilter, page = p, pageSize = Model.PageSize })!,
            PageSizeUrl = s => Url.Action("Index", new { category = Model.CategoryFilter, page = 1, pageSize = s })!
        })
    </div>
}

<div id="auditDetail" class="modal-backdrop hidden">
    <div class="modal audit-detail-modal">
        <button type="button" class="x" onclick="closeModal('auditDetail')">×</button>

        <h2>Chi tiết thay đổi</h2>

        <div class="audit-detail-head">
            <span class="badge" id="audit-detail-category"></span>
            <span class="badge" id="audit-detail-action"></span>
        </div>

        <p class="audit-detail-summary" id="audit-detail-summary"></p>

        <dl class="audit-detail-meta">
            <div>
                <dt>Người thực hiện</dt>
                <dd id="audit-detail-actor"></dd>
            </div>
            <div>
                <dt>Thời gian</dt>
                <dd id="audit-detail-time"></dd>
            </div>
            <div>
                <dt>Đối tượng</dt>
                <dd id="audit-detail-entity"></dd>
            </div>
        </dl>

        <div class="audit-diff-grid" id="audit-detail-diff">
            <div>
                <h4>Trước</h4>
                <pre class="audit-json" id="audit-detail-before"></pre>
            </div>
            <div>
                <h4>Sau</h4>
                <pre class="audit-json" id="audit-detail-after"></pre>
            </div>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn" onclick="closeModal('auditDetail')">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/audit.js" asp-append-version="true"></script>
}
