<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ICO Generator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        string NavActive(params string[] controllers) =>
            controllers.Any(c => string.Equals(currentController, c, StringComparison.OrdinalIgnoreCase)) ? "active" : "";

        string PageTitle = currentController switch
        {
            "Projects" => "Projects",
            "Agents" => "Agents",
            "Usage" => "Usage",
            "Quality" => "Delivery Quality",
            "Evals" => "Prompt Evals",
            "Prompts" => "Agents",
            "Models" => "AI Models",
            "Settings" => "Settings",
            "Feedback" => "Feedback",
            "Requirements" => "Requirements",
            "AgentDashboard" => "Agent Dashboard",
            "Roles" => "Roles & Permissions",
            "Audit" => "Audit Log",
            _ => "Home"
        };
        var currentRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    }
    <div class="app-shell" id="appShell">

        <div class="supergraphic"></div>

        <div class="app-body">

            <aside class="sidebar">
                <div class="sidebar-head">
                    <span class="app-name">ICO Generator</span>
                    <button class="sb-toggle" id="sbToggle" title="Toggle menu" aria-label="Toggle menu" type="button">
                        <svg class="ico ico-close" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18" /></svg>
                        <svg class="ico ico-menu" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
                    </button>
                </div>

                @{
                    // Menu chỉ hiện màn hình mà role hiện tại được phép xem (quyền *View tương ứng).
                    var canProjects = await Permissions.HasPermissionAsync(User, AppPermission.ProjectsView);
                    var canAgents = await Permissions.HasPermissionAsync(User, AppPermission.AgentsView);
                    var canUsage = await Permissions.HasPermissionAsync(User, AppPermission.UsageView);
                    var canQuality = await Permissions.HasPermissionAsync(User, AppPermission.QualityView);
                    var canEvals = await Permissions.HasPermissionAsync(User, AppPermission.EvalView);
                    var canModels = await Permissions.HasPermissionAsync(User, AppPermission.ModelsView);
                    var canSettings = await Permissions.HasPermissionAsync(User, AppPermission.SettingsView);
                    var canFeedback = await Permissions.HasPermissionAsync(User, AppPermission.FeedbackView);
                    var canRoles = await Permissions.HasPermissionAsync(User, AppPermission.AdministrationManageRoles);
                    var canAudit = await Permissions.HasPermissionAsync(User, AppPermission.AuditView);
                }
                <nav class="sidebar-nav">
                    @if (canProjects)
                    {
                        <a class="nav-item @NavActive("Projects", "Requirements", "AgentDashboard")" asp-controller="Projects" asp-action="Index" title="Projects">
                            <svg class="ico" viewBox="0 0 24 24"><path d="M3 3h8v8H3zM13 3h8v8h-8zM13 13h8v8h-8zM3 13h8v8H3z" /></svg>
                            <span class="nav-label">Projects</span>
                        </a>
                    }
                    @if (canAgents)
                    {
                        <a class="nav-item @NavActive("Agents", "Prompts")" asp-controller="Agents" asp-action="Index" title="Agents">
                            <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
                            <span class="nav-label">Agents</span>
                        </a>
                    }
                    @if (canUsage)
                    {
                        <a class="nav-item @NavActive("Usage")" asp-controller="Usage" asp-action="Index" title="Usage">
                            <svg class="ico" viewBox="0 0 24 24"><path d="M3 3v18h18M7 15l3-3 3 3 5-6" /></svg>
                            <span class="nav-label">Usage</span>
                        </a>
                    }
                    @if (canQuality)
                    {
                        <a class="nav-item @NavActive("Quality")" asp-controller="Quality" asp-action="Index" title="Delivery Quality">
                            <svg class="ico" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>
                            <span class="nav-label">Quality</span>
                        </a>
                    }
                    @if (canEvals)
                    {
                        <a class="nav-item @NavActive("Evals")" asp-controller="Evals" asp-action="Index" title="Prompt Evals">
                            <svg class="ico" viewBox="0 0 24 24"><path d="M9 11l3 3 8-8" /><path d="M20 12v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h9" /></svg>
                            <span class="nav-label">Evals</span>
                        </a>
                    }
                    @if (canModels)
                    {
                        <a class="nav-item @NavActive("Models")" asp-controller="Models" asp-action="Index" title="Models">
                            <svg class="ico" viewBox="0 0 24 24"><path d="M12 2l9 5v10l-9 5-9-5V7z" /><path d="M3 7l9 5 9-5M12 12v10" /></svg>
                            <span class="nav-label">Models</span>
                        </a>
                    }
                    @if (canSettings)
                    {
                        <a class="nav-item @NavActive("Settings")" asp-controller="Settings" asp-action="Index" title="Settings">
                            <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.2" /><path d="M12 2v3M12 19v3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M2 12h3M19 12h3M4.9 19.1l2.1-2.1M17 7l2.1-2.1" /></svg>
                            <span class="nav-label">Settings</span>
                        </a>
                    }
                    @if (canFeedback)
                    {
                        <a class="nav-item @NavActive("Feedback")" asp-controller="Feedback" asp-action="Index" title="Feedback">
                            <svg class="ico" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" /></svg>
                            <span class="nav-label">Feedback</span>
                        </a>
                    }
                    @if (canRoles)
                    {
                        <a class="nav-item @NavActive("Roles")" asp-controller="Roles" asp-action="Index" title="Roles & Permissions">
                            <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /><path d="M17 3l2 2 3-3" /></svg>
                            <span class="nav-label">Roles</span>
                        </a>
                    }
                    @if (canAudit)
                    {
                        <a class="nav-item @NavActive("Audit")" asp-controller="Audit" asp-action="Index" title="Audit Log">
                            <svg class="ico" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M14 2v6h6" /><path d="M9 13h6M9 17h6M9 9h1" /></svg>
                            <span class="nav-label">Audit Log</span>
                        </a>
                    }
                </nav>

                <div class="sidebar-foot">
                    <div class="nav-item" id="navUser" title="User">
                        <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
                        <span class="nav-label">@(User.Identity?.Name ?? "Account")</span>
                    </div>
                    <div class="nav-item" id="navImprint" title="Imprint">
                        <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 16v-4M12 8h.01" /></svg>
                        <span class="nav-label">Imprint</span>
                    </div>
                </div>
            </aside>

            <div class="main-col">

                <header class="topbar">
                    <div class="breadcrumb">
                        @if (IsSectionDefined("Breadcrumb"))
                        {
                            @RenderSection("Breadcrumb", required: false)
                        }
                        else
                        {
                            <text>Home <span class="sep">&rsaquo;</span> @PageTitle</text>
                        }
                    </div>
                    <div class="topbar-spacer"></div>
                    <div class="notif" id="notifRoot">
                        <button class="notif-bell" id="notifBell" type="button" title="Thông báo" aria-label="Thông báo" aria-haspopup="true" aria-expanded="false">
                            <i class="bi bi-bell"></i>
                            <span class="notif-badge" id="notifBadge" hidden>0</span>
                        </button>
                        <div class="notif-panel" id="notifPanel" hidden>
                            <div class="notif-panel-head">
                                <span>Thông báo</span>
                                <button type="button" class="notif-markall" id="notifMarkAll">Đánh dấu đã đọc</button>
                            </div>
                            <div class="notif-list" id="notifList">
                                <div class="notif-empty">Đang tải…</div>
                            </div>
                            <div class="notif-foot-row">
                                <a class="notif-foot" asp-controller="Notifications" asp-action="Index">Xem tất cả</a>
                                <a class="notif-foot" asp-controller="Notifications" asp-action="Preferences" title="Tùy chọn thông báo"><i class="bi bi-gear"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="bosch-logo">BOSCH</div>
                </header>

                <main class="page">@RenderBody()</main>
            </div>
        </div>
    </div>

    <div class="modal-overlay shell-modal" id="userModal">
        <div class="shell-modal-card">
            <div class="shell-modal-head">
                <h3>Account</h3>
                <button class="shell-modal-close" data-close="userModal" aria-label="Close" type="button"><svg class="ico" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18" /></svg></button>
            </div>
            <div class="shell-modal-body">
                <div class="shell-field">
                    <label>Default Language</label>
                    <select class="shell-select"><option>English</option><option>Tiếng Việt</option><option>Deutsch</option></select>
                </div>
                <p>Đang đăng nhập: <strong>@(User.Identity?.Name ?? "—")</strong>@(string.IsNullOrEmpty(currentRole) ? "" : $" · {currentRole}")</p>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button class="btn primary" type="submit">Logout</button>
                </form>
            </div>
        </div>
    </div>

    <div class="modal-overlay shell-modal" id="imprintModal">
        <div class="shell-modal-card lg">
            <div class="imprint-bar"></div>
            <div class="shell-modal-head">
                <div class="imprint-logo">BOSCH<small>Invented for life</small></div>
                <div style="flex:1"></div>
                <button class="shell-modal-close" data-close="imprintModal" aria-label="Close" type="button"><svg class="ico" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18" /></svg></button>
            </div>
            <div class="shell-modal-body">
                <dl class="imprint-grid">
                    <dt>Purpose</dt>
                    <dd>AI-assisted generation of project requirements, design and delivery artifacts.</dd>
                    <dt>Security class of the IT System (cf. CD 02900)</dt>
                    <dd>C_SC1</dd>
                    <dt>Requirements towards the IT Owner of the consuming IT System</dt>
                    <dd>Login by SSO or Group account</dd>
                    <dt>Name</dt>
                    <dd>ICO Generator</dd>
                    <dt>Version</dt>
                    <dd>4.0</dd>
                    <dt>Designed and developed by</dt>
                    <dd>HcP/ICO</dd>
                </dl>
            </div>
        </div>
    </div>

    @Html.AntiForgeryToken()
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
