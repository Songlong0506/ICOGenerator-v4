<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ICO Generator</title>
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <aside class="sidebar">
        <div class="brand"><div class="logo">⬡</div><div>ICO<br/>Generator</div></div>
        <nav>
            <a asp-controller="Projects" asp-action="Index">▣ Projects</a>
            <a asp-controller="Agents" asp-action="Index">♧ Agents</a>
            <a asp-controller="Usage" asp-action="Index">◴ Usage / Tokens</a>
            <a asp-controller="Models" asp-action="Index">◈ Models</a>
            <a href="#">⚙ Settings</a>
        </nav>
        <div class="user"><div class="avatar">TU</div><div><b>Tran User</b><br/><span>Owner</span></div></div>
    </aside>
    <main class="content">@RenderBody()</main>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
