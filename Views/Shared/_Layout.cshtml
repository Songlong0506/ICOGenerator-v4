<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ICO Generator</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        string NavActive(params string[] controllers) =>
            controllers.Any(c => string.Equals(currentController, c, StringComparison.OrdinalIgnoreCase)) ? "active" : "";

        string PageTitle = currentController switch
        {
            "Projects" => "Projects",
            "Agents" => "Agents",
            "Usage" => "Usage",
            "Models" => "AI Models",
            "Settings" => "Settings",
            "Requirements" => "Requirements",
            "ManageAgent" => "Manage Agent",
            _ => "Home"
        };
    }
    <div class="app-shell" id="appShell">

        <div class="supergraphic"></div>

        <div class="app-body">

            <!-- ===== Sidebar ===== -->
            <aside class="sidebar">
                <div class="sidebar-head">
                    <span class="app-name">ICO Generator</span>
                    <button class="sb-toggle" id="sbToggle" title="Toggle menu" aria-label="Toggle menu" type="button">
                        <svg class="ico ico-close" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18" /></svg>
                        <svg class="ico ico-menu" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
                    </button>
                </div>

                <nav class="sidebar-nav">
                    <a class="nav-item @NavActive("Projects", "Requirements", "ManageAgent")" asp-controller="Projects" asp-action="Index" title="Projects">
                        <svg class="ico" viewBox="0 0 24 24"><path d="M3 3h8v8H3zM13 3h8v8h-8zM13 13h8v8h-8zM3 13h8v8H3z" /></svg>
                        <span class="nav-label">Projects</span>
                    </a>
                    <a class="nav-item @NavActive("Agents")" asp-controller="Agents" asp-action="Index" title="Agents">
                        <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
                        <span class="nav-label">Agents</span>
                    </a>
                    <a class="nav-item @NavActive("Usage")" asp-controller="Usage" asp-action="Index" title="Usage">
                        <svg class="ico" viewBox="0 0 24 24"><path d="M3 3v18h18M7 15l3-3 3 3 5-6" /></svg>
                        <span class="nav-label">Usage</span>
                    </a>
                    <a class="nav-item @NavActive("Models")" asp-controller="Models" asp-action="Index" title="Models">
                        <svg class="ico" viewBox="0 0 24 24"><path d="M12 2l9 5v10l-9 5-9-5V7z" /><path d="M3 7l9 5 9-5M12 12v10" /></svg>
                        <span class="nav-label">Models</span>
                    </a>
                    <a class="nav-item @NavActive("Settings")" asp-controller="Settings" asp-action="Index" title="Settings">
                        <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.2" /><path d="M12 2v3M12 19v3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M2 12h3M19 12h3M4.9 19.1l2.1-2.1M17 7l2.1-2.1" /></svg>
                        <span class="nav-label">Settings</span>
                    </a>
                </nav>

                <!-- ===== Bottom: User + Imprint ===== -->
                <div class="sidebar-foot">
                    <div class="nav-item" id="navUser" title="User">
                        <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
                        <span class="nav-label">EXTERNAL Vu Song Toan (Amaris)</span>
                    </div>
                    <div class="nav-item" id="navImprint" title="Imprint">
                        <svg class="ico" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 16v-4M12 8h.01" /></svg>
                        <span class="nav-label">Imprint</span>
                    </div>
                </div>
            </aside>

            <!-- ===== Main column ===== -->
            <div class="main-col">

                <header class="topbar">
                    <div class="breadcrumb">
                        @if (IsSectionDefined("Breadcrumb"))
                        {
                            @RenderSection("Breadcrumb", required: false)
                        }
                        else
                        {
                            <text>Home <span class="sep">&rsaquo;</span> @PageTitle</text>
                        }
                    </div>
                    <div class="topbar-spacer"></div>
                    <div class="bosch-logo">BOSCH</div>
                </header>

                <main class="page">@RenderBody()</main>
            </div>
        </div>
    </div>

    <!-- ===== User popup ===== -->
    <div class="modal-overlay shell-modal" id="userModal">
        <div class="shell-modal-card">
            <div class="shell-modal-head">
                <h3>Account</h3>
                <button class="shell-modal-close" data-close="userModal" aria-label="Close" type="button"><svg class="ico" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18" /></svg></button>
            </div>
            <div class="shell-modal-body">
                <div class="shell-field">
                    <label>Default Language</label>
                    <select class="shell-select"><option>English</option><option>Tiếng Việt</option><option>Deutsch</option></select>
                </div>
                <p>Do you want to logout?</p>
                <button class="btn primary" type="button">Logout</button>
            </div>
        </div>
    </div>

    <!-- ===== Imprint popup ===== -->
    <div class="modal-overlay shell-modal" id="imprintModal">
        <div class="shell-modal-card lg">
            <div class="imprint-bar"></div>
            <div class="shell-modal-head">
                <div class="imprint-logo">BOSCH<small>Invented for life</small></div>
                <div style="flex:1"></div>
                <button class="shell-modal-close" data-close="imprintModal" aria-label="Close" type="button"><svg class="ico" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18" /></svg></button>
            </div>
            <div class="shell-modal-body">
                <dl class="imprint-grid">
                    <dt>Purpose</dt>
                    <dd>AI-assisted generation of project requirements, design and delivery artifacts.</dd>
                    <dt>Security class of the IT System (cf. CD 02900)</dt>
                    <dd>C_SC1</dd>
                    <dt>Requirements towards the IT Owner of the consuming IT System</dt>
                    <dd>Login by SSO or Group account</dd>
                    <dt>Name</dt>
                    <dd>ICO Generator</dd>
                    <dt>Version</dt>
                    <dd>4.0</dd>
                    <dt>Designed and developed by</dt>
                    <dd>HcP/ICO</dd>
                </dl>
            </div>
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var shell = document.getElementById('appShell');
            var toggle = document.getElementById('sbToggle');
            if (toggle) toggle.addEventListener('click', function () { shell.classList.toggle('collapsed'); });

            function open(id) { var m = document.getElementById(id); if (m) m.classList.add('open'); }
            var u = document.getElementById('navUser'); if (u) u.addEventListener('click', function () { open('userModal'); });
            var i = document.getElementById('navImprint'); if (i) i.addEventListener('click', function () { open('imprintModal'); });
            document.querySelectorAll('[data-close]').forEach(function (b) {
                b.addEventListener('click', function () { var m = document.getElementById(b.getAttribute('data-close')); if (m) m.classList.remove('open'); });
            });
            document.querySelectorAll('.shell-modal').forEach(function (o) {
                o.addEventListener('click', function (e) { if (e.target === o) o.classList.remove('open'); });
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
