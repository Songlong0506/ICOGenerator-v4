@using ICOGenerator.Application.Settings
@model AppSettingsVm

@section Styles {
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
}

<div class="page-head">
    <div>
        <h1>Settings</h1>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert error" style="color:#b91c1c;background:#fef2f2;border:1px solid #fecaca">@TempData["Error"]</div>
}

<form class="settings-form" asp-action="Update" method="post">
    @Html.AntiForgeryToken()

    <div class="card settings-card">
        <h2>Database</h2>
        <label>Connection String *</label>
        <textarea name="ConnectionString" rows="3" required>@Model.ConnectionString</textarea>
    </div>

    <div class="card settings-card">
        <h2>Agent Workspace</h2>
        <label>Workspace Root Path *</label>
        <input name="WorkspaceRootPath" value="@Model.WorkspaceRootPath" required placeholder="C:\Study App\ICOGeneratorWorkspaces" />
    </div>

    <div class="card settings-card">
        <h2>Tool Policy</h2>

        <label>Allowed Commands</label>
        <textarea name="AllowedCommands" rows="8">@Model.AllowedCommands</textarea>

        <label>Allowed File Extensions</label>
        <textarea name="AllowedFileExtensions" rows="8">@Model.AllowedFileExtensions</textarea>
    </div>

    <div class="card settings-card">
        <h2>Git / Pull Request</h2>

        <label>Remote Name</label>
        <input name="PullRequestRemoteName" value="@Model.PullRequestRemoteName" placeholder="origin" />
    </div>

    <div class="card settings-card">
        <h2>Hosting</h2>

        <label>Allowed Hosts</label>
        <input name="AllowedHosts" value="@Model.AllowedHosts" placeholder="*" />
    </div>

    <div class="save-bar">
        <button class="btn primary" type="submit">Save Settings</button>
    </div>
</form>
