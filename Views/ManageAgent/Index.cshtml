@model Project
@{
    var agents = ViewBag.Agents as List<Agent> ?? new();
    var phases = ViewBag.Phases as IReadOnlyList<string> ?? new List<string> { "01_Requirement", "02_Design", "03_Implementation", "04_Test" };
    var totalTokens = Model.Documents.Sum(x => x.TokenUsed) + Model.Conversations.Sum(x => x.TokenUsed) + Model.ModelCallLogs.Sum(x => x.TotalTokens);

    Func<string, string> phaseOf = folder => phases.FirstOrDefault(p => string.Equals(p, folder, StringComparison.OrdinalIgnoreCase)) ?? "Other";
    var docsByPhase = Model.Documents.GroupBy(d => phaseOf(d.Folder)).ToDictionary(g => g.Key, g => g.ToList());
    var orderedFolders = phases.ToList();
    if (docsByPhase.ContainsKey("Other")) { orderedFolders.Add("Other"); }

    var docMap = Model.Documents.ToDictionary(
        d => d.Id.ToString(),
        d => (object)new { name = d.FileName, content = d.Content, agentId = d.AgentId?.ToString() ?? "" });
    var docsJson = System.Text.Json.JsonSerializer.Serialize(docMap);
    var firstDoc = Model.Documents.FirstOrDefault();
}

<style>
    .large-modal {
        width: min(1400px,96vw);
    }

    #logs-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.45);
        z-index: 9998;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }
</style>

<div class="breadcrumb">Projects › @Model.Name › <b>Manage Agent</b></div>
<div class="page-head">
    <div>
        <h1>Manage Agent</h1>
        <p>View agent work, documents, tokens, conversations and AI call logs</p>
    </div>
    <div class="card token">
        <span>Total Tokens Used</span>
        <b>@totalTokens.ToString("N0")</b>
    </div>
</div>

<div class="agent-cards">
    @foreach (var a in agents.Take(6))
    {
        var agentTokens = Model.Conversations.Where(x => x.AgentId == a.Id).Sum(x => x.TokenUsed)
            + Model.ModelCallLogs.Where(x => x.AgentId == a.Id).Sum(x => x.TotalTokens);
        <div class="card mini agent-card" data-agent-id="@a.Id" data-agent-name="@a.Name" onclick="filterByAgent('@a.Id', '@a.Name')">
            <span class="circle" style="background:@a.Color"></span>
            <b>@a.Name</b>
            <small>@a.RoleTitle</small>
            <p>@agentTokens.ToString("N0") tokens</p>
            <small class="muted log-link" onclick="event.stopPropagation(); loadAgentLogs('@a.Id', '@a.Name')">Click to view AI Call Logs</small>
        </div>
    }
</div>

<div class="grid manage-grid">
    <div class="card">
        <div class="ws-head">
            <h3>Workspace</h3>
            <small id="ws-filter-label" class="muted"></small>
            <button type="button" id="ws-clear" class="btn ws-clear hidden" onclick="clearAgentFilter()">Show all</button>
        </div>
        <ul class="tree" id="ws-tree">
            @foreach (var folder in orderedFolders)
            {
                var docs = docsByPhase.TryGetValue(folder, out var list) ? list : new List<ICOGenerator.Domain.ProjectDocument>();
                <li class="folder">📁 @folder</li>
                foreach (var d in docs)
                {
                    <li class="file" data-doc-id="@d.Id" data-agent-id="@(d.AgentId?.ToString() ?? "")" onclick="showDoc('@d.Id')">📄 @d.FileName</li>
                }
                if (!docs.Any())
                {
                    <li class="empty">— empty —</li>
                }
            }
        </ul>
    </div>

    <div class="card">
        <h3 id="doc-title">@(firstDoc?.FileName ?? "No document")</h3>
        <div class="preview"><pre id="doc-content">@(firstDoc?.Content ?? "No document yet")</pre></div>
        <h3>Agent Conversation</h3>
        @foreach (var c in Model.Conversations.OrderByDescending(x => x.CreatedAt))
        {
            <div class="conversation">
                <b>@c.Agent.Name</b>
                <span>@c.Message</span>
                <small>@c.TokenUsed.ToString("N0") tokens</small>
            </div>
        }
    </div>
</div>

<style>
    .ws-head { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .ws-head h3 { margin: 0; }
    .tree .folder { font-weight: 600; margin-top: 6px; }
    .tree .file { cursor: pointer; padding-left: 18px; }
    .tree .file:hover { color: #2563eb; }
    .tree .file.selected { color: #2563eb; font-weight: 600; }
    .tree .empty { color: #94a3b8; padding-left: 18px; font-style: italic; }
    .agent-card.active { outline: 2px solid #6366f1; outline-offset: 2px; }
    .log-link { cursor: pointer; text-decoration: underline; }
    .ws-clear { padding: 4px 10px; font-size: 12px; }
</style>

<script>
    const DOCS = @Html.Raw(docsJson);
    let activeAgentFilter = null;

    function filterByAgent(agentId, name) {
        if (activeAgentFilter === agentId) { clearAgentFilter(); return; }
        activeAgentFilter = agentId;
        document.querySelectorAll('.agent-card').forEach(c => c.classList.toggle('active', c.dataset.agentId === agentId));
        document.querySelectorAll('#ws-tree .file').forEach(f => {
            f.style.display = (f.dataset.agentId === agentId) ? '' : 'none';
        });
        const label = document.getElementById('ws-filter-label');
        if (label) label.textContent = 'Filtered by: ' + name;
        const clear = document.getElementById('ws-clear');
        if (clear) clear.classList.remove('hidden');
    }

    function clearAgentFilter() {
        activeAgentFilter = null;
        document.querySelectorAll('.agent-card').forEach(c => c.classList.remove('active'));
        document.querySelectorAll('#ws-tree .file').forEach(f => f.style.display = '');
        const label = document.getElementById('ws-filter-label');
        if (label) label.textContent = '';
        const clear = document.getElementById('ws-clear');
        if (clear) clear.classList.add('hidden');
    }

    function showDoc(id) {
        const doc = DOCS[id];
        if (!doc) return;
        document.getElementById('doc-title').textContent = doc.name;
        document.getElementById('doc-content').textContent = doc.content || 'No document yet';
        document.querySelectorAll('#ws-tree .file').forEach(f => f.classList.remove('selected'));
        const node = document.querySelector('#ws-tree .file[data-doc-id="' + id + '"]');
        if (node) node.classList.add('selected');
    }
</script>

<div class="modal-backdrop" id="logs-modal">
    <div class="modal-card large-modal">

        <div class="logs-header">
            <div>
                <h3>AI Call Logs</h3>
                <p id="logs-subtitle">
                    Click an agent card to view model invocation history.
                </p>
            </div>

            <button class="btn" onclick="closeLogsModal()">
                Close
            </button>
        </div>

        <div style="overflow-x:auto;">
            <table class="logs-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Purpose</th>
                        <th>Model</th>
                        <th>Tokens</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody id="logs-tbody"></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal-backdrop" id="log-modal">
    <div class="modal-card">
        <div class="logs-header">
            <div>
                <h3>Model Invocation Detail</h3>
                <p id="log-detail-meta"></p>
            </div>
            <button class="btn" onclick="closeLogModal()">Close</button>
        </div>

        <div class="tabs">
            <button class="tab active" onclick="showLogTab('request', this)">Request</button>
            <button class="tab" onclick="showLogTab('response', this)">Response</button>
            <button class="tab" onclick="showLogTab('content', this)">Extracted Content</button>
            <button class="tab" onclick="showLogTab('error', this)">Error</button>
        </div>

        <pre class="log-json" id="log-request"></pre>
        <pre class="log-json hidden" id="log-response"></pre>
        <pre class="log-json hidden" id="log-content"></pre>
        <pre class="log-json hidden" id="log-error"></pre>
    </div>
</div>

<style>
    .agent-card { cursor: pointer; transition: transform .15s ease, box-shadow .15s ease; }
    .agent-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(15, 23, 42, .08); }
    .muted { color: #64748b; }
    .logs-panel { display: none; margin-top: 24px; }
    .logs-header { display: flex; justify-content: space-between; gap: 16px; align-items: center; margin-bottom: 16px; }
    .logs-header p { color: #64748b; margin: 4px 0 0; }
    .logs-table { width: 100%; border-collapse: collapse; }
    .logs-table th, .logs-table td { padding: 12px; border-bottom: 1px solid #e2e8f0; text-align: left; vertical-align: top; }
    .logs-table th { background: #f8fafc; font-size: 13px; color: #475569; }
    .badge { padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; }
    .badge-success { background: #dcfce7; color: #166534; }
    .badge-error { background: #fee2e2; color: #991b1b; }
    .btn { border: 1px solid #e2e8f0; background: #fff; padding: 8px 12px; border-radius: 10px; cursor: pointer; }
    .btn-primary { background: #2563eb; color: #fff; border-color: #2563eb; }
    .modal-backdrop { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, .45); z-index: 9999; align-items: center; justify-content: center; padding: 24px; }
    .modal-card { background: #fff; border-radius: 16px; width: min(1100px, 96vw); max-height: 90vh; overflow: auto; padding: 20px; box-shadow: 0 20px 60px rgba(15, 23, 42, .25); }
    .tabs { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
    .tab { border: 1px solid #e2e8f0; background: #fff; padding: 8px 12px; border-radius: 10px; cursor: pointer; }
    .tab.active { background: #2563eb; color: #fff; border-color: #2563eb; }
    .log-json { background: #0f172a; color: #e2e8f0; border-radius: 12px; padding: 16px; white-space: pre-wrap; overflow: auto; max-height: 60vh; font-size: 13px; }
    .hidden { display: none !important; }
</style>

<script>
    const projectId = '@Model.Id';

        async function loadAgentLogs(agentId, agentName) {

        document.getElementById('logs-modal').style.display = 'flex';

        document.getElementById('logs-subtitle').textContent =
            `Agent: ${agentName}`;

        const tbody = document.getElementById('logs-tbody');

        tbody.innerHTML =
            '<tr><td colspan="7">Loading...</td></tr>';

        const url =
            `/ManageAgent/AgentCallLogs?projectId=${projectId}&agentId=${agentId}`;

        const response = await fetch(url);

        const logs = await response.json();

        if (!logs.length) {

            tbody.innerHTML =
                '<tr><td colspan="7">No AI call logs found for this agent.</td></tr>';

            return;
        }

        tbody.innerHTML = logs.map(x => `
            <tr>
                <td>${formatDateTime(x.createdAt)}</td>

                <td>
                    ${escapeHtml(x.purpose || '-')}
                    <br>
                    <small>Step ${x.step || 1}</small>
                </td>

                <td>
                    ${escapeHtml(x.modelName || x.modelId || '-')}
                    <br>
                    <small>${escapeHtml(x.endpoint || '')}</small>
                </td>

                <td>
                    ${Number(x.totalTokens || 0).toLocaleString()}
                    <br>
                    <small>
                        P:${x.promptTokens || 0}
                        C:${x.completionTokens || 0}
                    </small>
                </td>

                <td>${x.durationMs || 0} ms</td>

                <td>
                    <span class="badge ${x.isSuccess ? 'badge-success' : 'badge-error'}">
                        ${x.isSuccess ? 'Success' : 'Error'}
                    </span>
                </td>

                <td>
                    <button class="btn btn-primary"
                            onclick="viewLogDetail('${x.id}')">
                        View
                    </button>
                </td>
            </tr>
        `).join('');
    }

        function closeLogsModal() {
        document.getElementById('logs-modal').style.display = 'none';
    }

    async function viewLogDetail(id) {
        const response = await fetch(`/ManageAgent/CallLogDetail?id=${id}`);
        const log = await response.json();

        document.getElementById('log-detail-meta').textContent = `${log.agentName} · ${log.modelName || log.modelId} · ${formatDateTime(log.createdAt)} · ${log.totalTokens || 0} tokens · ${log.durationMs || 0} ms`;
        document.getElementById('log-request').textContent = prettyJson(log.requestJson);
        document.getElementById('log-response').textContent = prettyJson(log.responseText);
        document.getElementById('log-content').textContent = log.extractedContent || '';
        document.getElementById('log-error').textContent = log.errorMessage || '';
        document.getElementById('log-modal').style.display = 'flex';
        showLogTab('request', document.querySelector('.tab'));
    }

    function closeLogsPanel() {
        document.getElementById('logs-panel').style.display = 'none';
    }

    function closeLogModal() {
        document.getElementById('log-modal').style.display = 'none';
    }

    function showLogTab(name, button) {
        ['request', 'response', 'content', 'error'].forEach(x => document.getElementById(`log-${x}`).classList.add('hidden'));
        document.getElementById(`log-${name}`).classList.remove('hidden');
        document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
        button.classList.add('active');
    }

    function prettyJson(value) {
        if (!value) return '';
        try { return JSON.stringify(JSON.parse(value), null, 2); }
        catch { return value; }
    }

    function formatDateTime(value) {
        if (!value) return '-';
        return new Date(value).toLocaleString();
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    document.getElementById('logs-modal')
    .addEventListener('click', function (e) {

        if (e.target.id === 'logs-modal') {
            closeLogsModal();
        }
    });
</script>
