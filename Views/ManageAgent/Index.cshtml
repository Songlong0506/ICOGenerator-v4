@model Project
@{ var agents = ViewBag.Agents as List<Agent> ?? new(); var totalTokens = Model.Documents.Sum(x=>x.TokenUsed)+Model.Conversations.Sum(x=>x.TokenUsed); }
<div class="breadcrumb">Projects › @Model.Name › <b>Manage Agent</b></div><div class="page-head"><div><h1>Manage Agent</h1><p>View agent work, documents, tokens and conversations</p></div><div class="card token"><span>Total Tokens Used</span><b>@totalTokens.ToString("N0")</b></div></div>
<div class="agent-cards">@foreach(var a in agents.Take(5)){<div class="card mini"><span class="circle" style="background:@a.Color"></span><b>@a.Name</b><small>@a.RoleTitle</small><p>@Model.Conversations.Where(x=>x.AgentId==a.Id).Sum(x=>x.TokenUsed).ToString("N0") tokens</p></div>}</div>
<div class="grid manage-grid"><div class="card"><h3>BA Workspace</h3><ul class="tree"><li>📁 01_Requirement</li>@foreach(var d in Model.Documents){<li class="file">📄 @d.FileName</li>}<li>📁 02_Analysis</li><li>📁 03_Design</li><li>📁 04_Others</li></ul></div><div class="card"><h3>@(Model.Documents.FirstOrDefault()?.FileName ?? "No document")</h3><div class="preview"><pre>@(Model.Documents.FirstOrDefault()?.Content ?? "No document yet")</pre></div><h3>Agent Conversation</h3>@foreach(var c in Model.Conversations.OrderByDescending(x=>x.CreatedAt)){<div class="conversation"><b>@c.Agent.Name</b><span>@c.Message</span><small>@c.TokenUsed.ToString("N0") tokens</small></div>}</div></div>
