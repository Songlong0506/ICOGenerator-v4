@model Project
@{
    var agents = ViewBag.Agents as List<Agent> ?? new();
    var phases = ViewBag.Phases as IReadOnlyList<string> ?? new List<string> { "01_Requirement", "02_Design", "03_Architecture", "04_Implementation", "05_Test" };
    // Token totals come from AgentModelCallLog (the single source of truth for AI token
    // usage), aggregated across all of the project's call logs in the query. Per-agent
    // values sum to the grand total because every call log is attributed to an agent.
    var totalTokens = (long)(ViewBag.TotalTokens ?? 0L);
    var tokensByAgent = ViewBag.TokensByAgent as IReadOnlyDictionary<Guid, long> ?? new Dictionary<Guid, long>();
    var callsByAgent = ViewBag.CallsByAgent as IReadOnlyDictionary<Guid, int> ?? new Dictionary<Guid, int>();
    var lastActivityByAgent = ViewBag.LastActivityByAgent as IReadOnlyDictionary<Guid, DateTime> ?? new Dictionary<Guid, DateTime>();
    var workspaceDocuments = ViewBag.WorkspaceDocuments as IReadOnlyList<ICOGenerator.Domain.ProjectDocument> ?? Model.Documents.ToList();

    Func<string, string> phaseOf = folder => phases.FirstOrDefault(p => string.Equals(p, folder, StringComparison.OrdinalIgnoreCase)) ?? "Other";
    var docsByPhase = workspaceDocuments.GroupBy(d => phaseOf(d.Folder)).ToDictionary(g => g.Key, g => g.ToList());
    var orderedFolders = phases.ToList();
    if (docsByPhase.ContainsKey("Other")) { orderedFolders.Add("Other"); }

    static int VersionOrder(string versionName)
    {
        if (string.Equals(versionName, "draft", StringComparison.OrdinalIgnoreCase))
            return 0;

        if (versionName.Length > 1
            && versionName.StartsWith("V", StringComparison.OrdinalIgnoreCase)
            && int.TryParse(versionName[1..], out var versionNumber))
            return versionNumber;

        return int.MaxValue;
    }

    // DB-tracked documents are previewed by their real row Id; workspace files that exist only
    // on disk (no DB row) carry a fresh random Id each request, so they must be previewed by
    // their relative path instead. Mark the disk-only ones here so the client picks the right URL.
    var dbDocIds = new HashSet<Guid>(Model.Documents.Select(d => d.Id));
    var docMap = workspaceDocuments.ToDictionary(
        d => d.Id.ToString(),
        d => (object)new
        {
            name = d.FileName,
            agentId = d.AgentId?.ToString() ?? "",
            path = dbDocIds.Contains(d.Id) ? "" : (d.FilePath ?? "")
        });
    var docsJson = System.Text.Json.JsonSerializer.Serialize(docMap);
    var firstDoc = workspaceDocuments.FirstOrDefault();
}

<style>
    .large-modal {
        width: min(1400px,96vw);
    }

    #logs-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.45);
        z-index: 9998;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }
</style>

@section Breadcrumb {
    Projects <span class="sep">&rsaquo;</span> @Model.Name <span class="sep">&rsaquo;</span> <b>Manage Agent</b>
}

<div class="page-head">
    <div>
        <h1>Manage Agent</h1>
        <p>View agent work, documents, tokens, conversations and AI call logs</p>
    </div>
    <div class="card token">
        <span>Total Tokens Used</span>
        <b>@totalTokens.ToString("N0")</b>
    </div>
</div>

<div class="agent-table-wrap">
    <table class="agent-table">
        <thead>
            <tr>
                <th>Agent</th>
                <th class="share-col">Share</th>
                <th class="num-col">Total Tokens</th>
                <th class="num-col">Calls</th>
                <th>Last Activity</th>
                <th>Call Logs</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in agents)
            {
                var agentTokens = tokensByAgent.TryGetValue(a.Id, out var t) ? t : 0L;
                var agentCalls = callsByAgent.TryGetValue(a.Id, out var c) ? c : 0;
                var sharePct = totalTokens > 0 ? (double)agentTokens / totalTokens * 100 : 0d;
                var shareWidth = sharePct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                var shareLabel = sharePct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);
                var hasActivity = lastActivityByAgent.TryGetValue(a.Id, out var lastAt);
                var lastAtIso = hasActivity ? DateTime.SpecifyKind(lastAt, DateTimeKind.Utc).ToString("o") : null;
                <tr class="agent-row" data-agent-id="@a.Id" data-agent-name="@a.Name" onclick="filterByAgent('@a.Id', '@a.Name')">
                    <td>
                        <div class="agent-name-cell">
                            <span class="circle" style="background:@a.Color"></span>
                            <span class="agent-name-text">
                                <b>@a.Name</b>
                                <small class="muted">@a.RoleKey.GetTitle()</small>
                            </span>
                            <span class="running-indicator" title="Agent đang chạy — bấm để xem hoạt động" onclick="event.stopPropagation(); openAgentActivity('@a.Id', '@a.Name')"><span class="pulse-dot"></span> Running</span>
                        </div>
                    </td>
                    <td class="share-col">
                        <div class="share-bar"><span class="share-fill" style="width:@(shareWidth)%"></span></div>
                        <small class="muted">@shareLabel%</small>
                    </td>
                    <td class="num-col">@agentTokens.ToString("N0")</td>
                    <td class="num-col">@agentCalls.ToString("N0")</td>
                    <td>
                        @if (hasActivity)
                        {
                            <span class="last-activity" data-utc="@lastAtIso"></span>
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>
                    <td>
                        <button type="button" class="btn" onclick="event.stopPropagation(); loadAgentLogs('@a.Id', '@a.Name')">View Logs</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="grid manage-grid">
    <div class="card">
        <div class="ws-head">
            <h3>Workspace</h3>
            <small id="ws-filter-label" class="muted"></small>
            <button type="button" id="ws-clear" class="btn ws-clear hidden" onclick="clearAgentFilter()">Show all</button>
        </div>
        <ul class="tree" id="ws-tree">
            @foreach (var folder in orderedFolders)
            {
                var docs = docsByPhase.TryGetValue(folder, out var list)
                    ? list.OrderBy(d => VersionOrder(d.VersionName)).ThenBy(d => d.VersionName).ThenBy(d => d.FileName).ToList()
                    : new List<ICOGenerator.Domain.ProjectDocument>();

                var rootDocs = docs.Where(d => string.IsNullOrWhiteSpace(d.VersionName)).OrderBy(d => d.FileName).ToList();
                var versionGroups = docs
                    .Where(d => !string.IsNullOrWhiteSpace(d.VersionName))
                    .GroupBy(d => d.VersionName)
                    .OrderBy(g => VersionOrder(g.Key))
                    .ThenBy(g => g.Key)
                    .ToList();

                <li class="folder phase-folder">
                    <button type="button" class="tree-row folder-toggle" aria-expanded="true" onclick="toggleFolder(this)">
                        <span class="folder-caret" aria-hidden="true">▾</span>
                        <span aria-hidden="true">📁</span>
                        <span>@folder</span>
                    </button>
                    <ul class="tree-children">
                        @if (rootDocs.Any() || versionGroups.Any())
                        {
                            foreach (var d in rootDocs)
                            {
                                <li class="file" data-doc-id="@d.Id" data-agent-id="@(d.AgentId?.ToString() ?? "")" onclick="showDoc('@d.Id')">📄 @d.FileName</li>
                            }

                            foreach (var versionGroup in versionGroups)
                            {
                                <li class="folder version-folder">
                                    <button type="button" class="tree-row folder-toggle" aria-expanded="true" onclick="toggleFolder(this)">
                                        <span class="folder-caret" aria-hidden="true">▾</span>
                                        <span aria-hidden="true">📁</span>
                                        <span>@versionGroup.Key</span>
                                    </button>
                                    <ul class="tree-children">
                                        @foreach (var d in versionGroup.OrderBy(d => d.FileName))
                                        {
                                            <li class="file" data-doc-id="@d.Id" data-agent-id="@(d.AgentId?.ToString() ?? "")" onclick="showDoc('@d.Id')">📄 @d.FileName</li>
                                        }
                                    </ul>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="empty">— empty —</li>
                        }
                    </ul>
                </li>
            }
        </ul>
    </div>

    <div class="card">
        <h3 id="doc-title">@(firstDoc?.FileName ?? "No document")</h3>
        <div class="preview"><div id="doc-content" class="doc-render"><p class="doc-empty">No document yet</p></div></div>
    </div>
</div>

<style>
    .ws-head { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .ws-head h3 { margin: 0; }
    .tree, .tree ul { list-style: none; margin: 0; padding-left: 0; }
    .tree ul { padding-left: 18px; }
    .tree .folder { font-weight: 600; margin-top: 6px; }
    .tree-row { display: inline-flex; align-items: center; gap: 4px; width: 100%; border: 0; background: transparent; padding: 2px 0; color: inherit; font: inherit; text-align: left; cursor: pointer; }
    .tree-row:hover { color: #007bc0; }
    .folder-caret { display: inline-block; width: 14px; color: #64748b; transition: transform .15s ease; }
    .tree .folder.collapsed > .tree-children { display: none; }
    .tree .folder.collapsed > .tree-row .folder-caret { transform: rotate(-90deg); }
    .tree .version-folder { font-weight: 400; }
    .tree .file { cursor: pointer; padding: 2px 0; }
    .tree .file:hover { color: #007bc0; }
    .tree .file.selected { color: #007bc0; font-weight: 600; }
    .tree .empty { color: #94a3b8; padding: 2px 0; font-style: italic; }
    .ws-clear { padding: 4px 10px; font-size: 12px; }

    /* ---------- Agent table ---------- */
    .agent-table-wrap { overflow-x: auto; margin-bottom: 18px; border: 1px solid #e2e8f0; border-radius: 12px; background: #fff; }
    .agent-table { width: 100%; border-collapse: collapse; }
    .agent-table th, .agent-table td { padding: 12px 16px; border-bottom: 1px solid #e2e8f0; text-align: left; vertical-align: middle; }
    .agent-table tbody tr:last-child td { border-bottom: 0; }
    .agent-table th { background: #f8fafc; font-size: 13px; color: #475569; font-weight: 600; white-space: nowrap; }
    .agent-table .num-col { text-align: right; white-space: nowrap; }
    .agent-table .share-col { width: 220px; }
    .agent-row { cursor: pointer; transition: background .12s ease; }
    .agent-row:hover { background: #f8fafc; }
    .agent-row.active { background: #e6f2fb; box-shadow: inset 3px 0 0 #007bc0; }
    .agent-name-cell { display: flex; align-items: center; gap: 10px; }
    .agent-name-text { display: flex; flex-direction: column; line-height: 1.3; }
    .share-bar { height: 8px; border-radius: 999px; background: #eef2f7; overflow: hidden; }
    .share-fill { display: block; height: 100%; background: #007bc0; border-radius: 999px; }
    .share-col small { display: block; margin-top: 4px; }

    /* Live "running" indicator: hidden until the active-agents poll marks the row running. */
    .agent-row .running-indicator { display: none; }
    .agent-row.running { background: #f0fdf4; box-shadow: inset 3px 0 0 #16a34a; }
    .agent-row.running .running-indicator {
        display: inline-flex; align-items: center; gap: 6px;
        margin-left: 4px;
        padding: 3px 9px; border-radius: 999px;
        background: #dcfce7; color: #166534;
        font-size: 11px; font-weight: 700; cursor: pointer;
        border: 1px solid #16a34a55;
    }
    .agent-row.running .running-indicator:hover { background: #bbf7d0; }
    .pulse-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #16a34a; box-shadow: 0 0 0 0 rgba(22,163,74,.6);
        animation: pulse-ring 1.4s ease-out infinite;
    }
    @@keyframes pulse-ring {
        0% { box-shadow: 0 0 0 0 rgba(22,163,74,.6); }
        70% { box-shadow: 0 0 0 7px rgba(22,163,74,0); }
        100% { box-shadow: 0 0 0 0 rgba(22,163,74,0); }
    }

    .preview { max-height: 70vh; overflow: auto; }
    .doc-render { line-height: 1.65; color: #1e293b; font-size: 14px; }
    .doc-render > :first-child { margin-top: 0; }
    .doc-render h1 { font-size: 24px; margin: 20px 0 12px; font-weight: 700; }
    .doc-render h2 { font-size: 20px; margin: 18px 0 10px; font-weight: 700; }
    .doc-render h3 { font-size: 17px; margin: 16px 0 8px; font-weight: 700; }
    .doc-render h4, .doc-render h5, .doc-render h6 { font-size: 15px; margin: 14px 0 6px; font-weight: 700; }
    .doc-render p { margin: 8px 0; }
    .doc-render table.doc-table { border-collapse: collapse; width: 100%; margin: 14px 0; font-size: 13px; }
    .doc-render table.doc-table td { border: 1px solid #cbd5e1; padding: 8px 12px; vertical-align: top; text-align: left; }
    .doc-render table.doc-table tr:first-child td { background: #f1f5f9; font-weight: 600; }
    .doc-empty, .doc-loading { color: #94a3b8; font-style: italic; }
</style>

<script>
    const DOCS = @Html.Raw(docsJson);
    const FIRST_DOC_ID = '@(firstDoc?.Id.ToString() ?? "")';
    const PROJECT_ID = '@Model.Id';
    let activeAgentFilter = null;

    function filterByAgent(agentId, name) {
        if (activeAgentFilter === agentId) { clearAgentFilter(); return; }
        activeAgentFilter = agentId;
        document.querySelectorAll('.agent-row').forEach(c => c.classList.toggle('active', c.dataset.agentId === agentId));
        document.querySelectorAll('#ws-tree .file').forEach(f => {
            f.style.display = (f.dataset.agentId === agentId) ? '' : 'none';
        });
        updateWorkspaceTreeVisibility();
        const label = document.getElementById('ws-filter-label');
        if (label) label.textContent = 'Filtered by: ' + name;
        const clear = document.getElementById('ws-clear');
        if (clear) clear.classList.remove('hidden');
    }

    function clearAgentFilter() {
        activeAgentFilter = null;
        document.querySelectorAll('.agent-row').forEach(c => c.classList.remove('active'));
        document.querySelectorAll('#ws-tree .file').forEach(f => f.style.display = '');
        updateWorkspaceTreeVisibility();
        const label = document.getElementById('ws-filter-label');
        if (label) label.textContent = '';
        const clear = document.getElementById('ws-clear');
        if (clear) clear.classList.add('hidden');
    }

    function toggleFolder(button) {
        const folderNode = button.closest('.folder');
        if (!folderNode) return;

        const isCollapsed = folderNode.classList.toggle('collapsed');
        button.setAttribute('aria-expanded', String(!isCollapsed));
    }

    function updateWorkspaceTreeVisibility() {
        document.querySelectorAll('#ws-tree .version-folder').forEach(versionNode => {
            const hasVisibleFile = Array.from(versionNode.querySelectorAll('.file'))
                .some(file => file.style.display !== 'none');
            versionNode.style.display = hasVisibleFile ? '' : 'none';
        });

        document.querySelectorAll('#ws-tree .phase-folder').forEach(phaseNode => {
            const hasVisibleFile = Array.from(phaseNode.querySelectorAll('.file'))
                .some(file => file.style.display !== 'none');
            const hasStaticEmpty = phaseNode.querySelector(':scope > ul > .empty') !== null;
            phaseNode.style.display = (hasVisibleFile || hasStaticEmpty || !activeAgentFilter) ? '' : 'none';
        });
    }

    async function showDoc(id) {
        if (!id) return;

        const meta = DOCS[id];
        const titleEl = document.getElementById('doc-title');
        const contentEl = document.getElementById('doc-content');

        if (meta) titleEl.textContent = meta.name;

        document.querySelectorAll('#ws-tree .file').forEach(f => f.classList.remove('selected'));
        const node = document.querySelector('#ws-tree .file[data-doc-id="' + id + '"]');
        if (node) node.classList.add('selected');

        contentEl.innerHTML = '<p class="doc-loading">Loading…</p>';

        try {
            // DB documents resolve by Id; disk-only files (meta.path set) resolve by
            // projectId + relative path, since their Id is a throwaway per-request Guid.
            const url = (meta && meta.path)
                ? '/ManageAgent/DocumentPreview?projectId=' + encodeURIComponent(PROJECT_ID) + '&path=' + encodeURIComponent(meta.path)
                : '/ManageAgent/DocumentPreview?id=' + encodeURIComponent(id);
            const response = await fetch(url);
            if (!response.ok) throw new Error('Preview request failed');
            const data = await response.json();
            titleEl.textContent = data.name;
            contentEl.innerHTML = data.html;
        } catch {
            contentEl.innerHTML = '<p class="doc-empty">Unable to load preview.</p>';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        if (FIRST_DOC_ID) showDoc(FIRST_DOC_ID);
        // Render UTC call-log timestamps in the viewer's local timezone (matches the logs modal).
        document.querySelectorAll('.last-activity[data-utc]').forEach(function (el) {
            el.textContent = formatDateTime(el.dataset.utc);
        });
    });
</script>

<div class="modal-backdrop" id="logs-modal">
    <div class="modal-card large-modal">

        <div class="logs-header">
            <div>
                <h3>AI Call Logs</h3>
                <p id="logs-subtitle">
                    Click an agent card to view model invocation history.
                </p>
            </div>

            <button class="btn" onclick="closeLogsModal()">
                Close
            </button>
        </div>

        <div style="overflow-x:auto;">
            <table class="logs-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Purpose</th>
                        <th>Model</th>
                        <th>Tokens</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody id="logs-tbody"></tbody>
            </table>
        </div>

    </div>
</div>

<div class="modal-backdrop" id="log-modal">
    <div class="modal-card">
        <div class="logs-header">
            <div>
                <h3>Model Invocation Detail</h3>
                <p id="log-detail-meta"></p>
            </div>
            <button class="btn" onclick="closeLogModal()">Close</button>
        </div>

        <div class="tabs">
            <button class="tab active" onclick="showLogTab('request', this)">Request</button>
            <button class="tab" onclick="showLogTab('response', this)">Response</button>
            <button class="tab" onclick="showLogTab('content', this)">Extracted Content</button>
            <button class="tab" onclick="showLogTab('error', this)">Error</button>
        </div>

        <pre class="log-json" id="log-request"></pre>
        <pre class="log-json hidden" id="log-response"></pre>
        <pre class="log-json hidden" id="log-content"></pre>
        <pre class="log-json hidden" id="log-error"></pre>
    </div>
</div>

<div class="modal-backdrop" id="agent-activity-modal">
    <div class="modal-card">
        <div class="logs-header">
            <div>
                <h3>Agent Activity</h3>
                <p id="activity-subtitle">Các thao tác agent đang thực hiện (real-time, để debug).</p>
            </div>
            <button class="btn" onclick="closeAgentActivity()">Close</button>
        </div>

        <div id="activity-meta" class="activity-meta"></div>
        <div id="activity-feed" class="activity-feed">
            <p class="activity-empty">Đang tải hoạt động…</p>
        </div>
    </div>
</div>

<style>
    .activity-meta { display: flex; flex-wrap: wrap; gap: 8px 16px; margin-bottom: 12px; font-size: 13px; color: #475569; }
    .activity-meta b { color: #1e293b; }
    .activity-feed { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 12px; max-height: 60vh; overflow: auto; }
    .activity-empty { color: #94a3b8; font-style: italic; margin: 4px; }
    .act-event { display: flex; gap: 10px; padding: 8px 6px; border-bottom: 1px dashed #e2e8f0; }
    .act-event:last-child { border-bottom: 0; }
    .act-icon { flex: 0 0 auto; }
    .act-main { flex: 1 1 auto; min-width: 0; }
