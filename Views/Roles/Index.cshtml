@using ICOGenerator.Application.Roles
@using ICOGenerator.Domain.Security
@model RolePermissionMatrixVm

@section Styles {
    <link rel="stylesheet" href="~/css/roles.css" asp-append-version="true" />
}

<div class="page-head">
    <div>
        <h1>Roles &amp; Permissions</h1>
    </div>
</div>

@await Html.PartialAsync("_CommandBar", new CommandBarModel
{
    SearchPlaceholder = "Search permissions…",
    TargetSelector = "#rolesTable",
    Primary = new CommandBarButton
    {
        Label = "Save",
        Icon = "bi-check-lg",
        OnClick = "document.getElementById('rolesForm').requestSubmit()"
    }
})

<form id="rolesForm" asp-action="Update" method="post">
    @Html.AntiForgeryToken()

    <table id="rolesTable" class="data-table roles-table">
        <thead>
            <tr>
                <th>Permission</th>
                @foreach (var col in Model.Columns)
                {
                    <th class="role-col">@col.Title</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var screen in Model.Screens)
            {
                <tr class="screen-row" data-cbar-skip>
                    <td colspan="@(Model.Columns.Count + 1)">@screen.Title</td>
                </tr>
                @foreach (var permission in screen.Permissions)
                {
                    <tr>
                        <td class="perm-label">@permission.GetTitle()</td>
                        @foreach (var col in Model.Columns)
                        {
                            <td class="role-col">
                                @if (col.Locked)
                                {
                                    <span class="locked-mark" title="Super Administrator always has full access">✓</span>
                                }
                                else
                                {
                                    <input type="checkbox" name="granted" value="@col.Role:@permission"
                                           checked="@col.Has(permission)" />
                                }
                            </td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>
</form>
