@model ICOGenerator.Application.Projects.ProjectListPage
@{
    string Badge(ProjectStatus s) => s switch { ProjectStatus.Completed => "badge green", ProjectStatus.InProgress => "badge blue", _ => "badge orange" };
}

<style>
    .btn.disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }

    .pager {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .pager-controls {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

        .pager-controls .btn {
            padding: 8px 12px;
            min-width: 40px;
        }

    .btn.success {
        border-color: #10b981;
        color: #10b981;
        background: #ecfdf5;
    }

    .project-name-cell {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .task-running-indicator {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        border: 1px solid #93c5fd;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 12px;
        font-weight: 800;
        padding: 5px 10px;
    }

    .task-running-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #2563eb;
        box-shadow: 0 0 0 rgba(37, 99, 235, .5);
        animation: projectTaskPulse 1.5s infinite;
    }

    @@keyframes projectTaskPulse {
        0% {
            box-shadow: 0 0 0 0 rgba(37, 99, 235, .5);
        }

        70% {
            box-shadow: 0 0 0 8px rgba(37, 99, 235, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(37, 99, 235, 0);
        }
    }

    /* ---------- Org Unit searchable dropdown (modal New Project) ---------- */
    .org-combo {
        position: relative;
    }

    .org-combo-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        width: 100%;
        padding: 9px 12px;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--ink);
        font-family: inherit;
        font-size: 14px;
        text-align: left;
        cursor: pointer;
    }

        .org-combo-trigger:focus {
            outline: none;
            border-color: var(--bosch-blue);
            box-shadow: 0 0 0 2px var(--bosch-blue-tint-strong);
        }

    .org-combo-text {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

        .org-combo-text.is-placeholder {
            color: var(--muted);
        }

    .org-combo-caret {
        color: var(--muted);
        font-size: 12px;
        transition: transform .15s;
    }

    .org-combo.open .org-combo-caret {
        transform: rotate(180deg);
    }

    .org-combo-panel {
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        z-index: 10;
        background: #fff;
        border: 1px solid var(--line);
        box-shadow: 0 12px 30px rgba(0,0,0,.18);
    }

    .org-combo-search {
        position: relative;
        padding: 8px;
        border-bottom: 1px solid var(--line);
    }

        .org-combo-search input {
            width: 100%;
            padding: 8px 32px 8px 12px;
            font-size: 14px;
        }

    .org-combo-search-icon {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 13px;
        color: var(--muted);
        pointer-events: none;
    }

    .org-combo-list {
        list-style: none;
        margin: 0;
        padding: 4px;
        max-height: 220px;
        overflow-y: auto;
    }

    .org-combo-option {
        padding: 9px 12px;
        font-size: 14px;
        color: var(--ink);
        cursor: pointer;
    }

        .org-combo-option:hover,
        .org-combo-option.active {
            background: var(--bosch-blue-tint);
        }

        .org-combo-option.selected {
            background: var(--bosch-blue-tint-strong);
            font-weight: 700;
        }

        .org-combo-option.hidden {
            display: none;
        }

    .org-combo-empty {
        padding: 14px 12px;
        font-size: 13px;
        color: var(--muted);
        text-align: center;
    }

    /* ---------- Filter bar (Org Unit + Status) ---------- */
    .filter-card {
        margin-bottom: 16px;
    }

    .filter-bar {
        display: flex;
        align-items: flex-end;
        gap: 16px;
        flex-wrap: wrap;
    }

    .filter-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 200px;
    }

        .filter-field > label {
            color: var(--muted);
            font-weight: 700;
            font-size: 13px;
        }

        .filter-field select {
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 8px 10px;
            font-family: inherit;
            font-size: 14px;
            color: var(--ink);
            background: #fff;
            cursor: pointer;
        }

            .filter-field select:focus {
                outline: none;
                border-color: var(--bosch-blue);
                box-shadow: 0 0 0 2px var(--bosch-blue-tint-strong);
            }

    .filter-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ---------- Org Unit multi-select combo (filter bar) ---------- */
    .ms-combo {
        position: relative;
        min-width: 240px;
    }

    .ms-combo-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        background: #fff;
        color: var(--ink);
        font-family: inherit;
        font-size: 14px;
        text-align: left;
        cursor: pointer;
    }

        .ms-combo-trigger:focus {
            outline: none;
            border-color: var(--bosch-blue);
            box-shadow: 0 0 0 2px var(--bosch-blue-tint-strong);
        }

    .ms-combo-text {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

        .ms-combo-text.is-placeholder {
            color: var(--muted);
        }

    .ms-combo-caret {
        color: var(--muted);
        font-size: 12px;
        transition: transform .15s;
    }

    .ms-combo.open .ms-combo-caret {
        transform: rotate(180deg);
    }

    .ms-combo-panel {
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        z-index: 10;
        min-width: 240px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 8px;
        box-shadow: 0 12px 30px rgba(0,0,0,.18);
        overflow: hidden;
    }

    .ms-combo-search {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px;
        border-bottom: 1px solid var(--line);
    }

    .ms-combo-search-box {
        position: relative;
        flex: 1;
    }

        .ms-combo-search-box input {
            width: 100%;
            padding: 8px 32px 8px 12px;
            font-size: 14px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
        }

            .ms-combo-search-box input:focus {
                outline: none;
                border-color: var(--bosch-blue);
                box-shadow: 0 0 0 2px var(--bosch-blue-tint-strong);
            }

    .ms-combo-search-icon {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 13px;
        color: var(--muted);
        pointer-events: none;
    }

    /* Hàng chọn có checkbox: ẩn checkbox gốc, vẽ ô vuông tùy biến (.ms-combo-box) để đồng bộ giao diện. */
    .ms-combo-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0;
        cursor: pointer;
        font-weight: inherit;
        color: inherit;
    }

        .ms-combo-checkbox input[type="checkbox"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
            margin: 0;
        }

    .ms-combo-box {
        flex: 0 0 18px;
        width: 18px;
        height: 18px;
        border: 1.5px solid #cbd5e1;
        border-radius: 4px;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .ms-combo-box::after {
            content: "✓";
            font-size: 12px;
            font-weight: 900;
            line-height: 1;
            color: #fff;
            opacity: 0;
        }

    /* Checkbox "Chọn tất cả": khi tick thì tô xanh Bosch cho khác hàng thường. */
    .ms-combo-all input:checked + .ms-combo-box,
    .ms-combo-all input:indeterminate + .ms-combo-box {
        background: var(--bosch-blue);
        border-color: var(--bosch-blue);
    }

        .ms-combo-all input:checked + .ms-combo-box::after {
            opacity: 1;
        }

    .ms-combo-all input:indeterminate + .ms-combo-box::after {
        content: "–";
        opacity: 1;
    }

    .ms-combo-list {
        list-style: none;
        margin: 0;
        padding: 4px;
        max-height: 240px;
        overflow-y: auto;
    }

    .ms-combo-option {
        border-radius: 6px;
    }

        .ms-combo-option > .ms-combo-checkbox {
            padding: 9px 12px;
        }

        .ms-combo-option:hover {
            background: var(--bosch-blue-tint);
        }

        .ms-combo-option-text {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-size: 14px;
        }

        /* Hàng đã chọn: nền navy đậm, chữ trắng, dấu ✓ trắng — bám theo mẫu thiết kế. */
        .ms-combo-option.selected {
            background: #0f172a;
            color: #fff;
        }

            .ms-combo-option.selected:hover {
                background: #1e293b;
            }

            .ms-combo-option.selected .ms-combo-option-text {
                font-weight: 700;
            }

            .ms-combo-option.selected .ms-combo-box {
                border-color: transparent;
                background: transparent;
            }

                .ms-combo-option.selected .ms-combo-box::after {
                    opacity: 1;
                }

        .ms-combo-option.hidden {
            display: none;
        }

    .ms-combo-empty {
        padding: 14px 12px;
        font-size: 13px;
        color: var(--muted);
        text-align: center;
    }
</style>

<div class="page-head">
    <div>
        <h1>Projects</h1>
    </div>
    <button class="btn primary" onclick="openModal('newProject')">＋ New Project</button>
</div>
@{
    var selectedOrgUnits = Model.SelectedOrgUnitCodesOrEmpty;
    var hasFilter = selectedOrgUnits.Count > 0 || Model.SelectedStatus.HasValue;

    // Link phân trang phải giữ nguyên bộ lọc. Org Unit giờ chọn nhiều (mảng) nên asp-route-* không dựng
    // được — tự ghép query string với đủ các tham số orgUnit lặp lại + status.
    string PageUrl(int targetPage)
    {
        var qs = new List<string>
        {
            $"page={targetPage}",
            $"pageSize={Model.PageSize}"
        };
        foreach (var code in selectedOrgUnits)
            qs.Add($"orgUnit={Uri.EscapeDataString(code)}");
        if (Model.SelectedStatus.HasValue)
            qs.Add($"status={Model.SelectedStatus}");
        return $"{Url.Action("Index")}?{string.Join("&", qs)}";
    }
}
<div class="card filter-card">
    @* Khu vực lọc danh sách dự án theo Đơn vị yêu cầu (Org Unit) và Trạng thái. Form GET nên bộ lọc
       nằm trong URL — chia sẻ được và giữ nguyên khi phân trang. Thay đổi select tự submit. *@
    <form method="get" asp-controller="Projects" asp-action="Index" class="filter-bar">
        <div class="filter-field">
            <label>Org Unit</label>
            @* Combo chọn NHIỀU đơn vị: mỗi lựa chọn là một checkbox name="orgUnit" nằm sẵn trong form GET,
               nên khi bấm "Lọc" toàn bộ mã đã tick được gửi lên (mảng). Không tự submit theo từng tick để
               người dùng chọn xong nhiều đơn vị rồi mới lọc. UI (nút, panel, tìm kiếm, chọn tất cả) do JS lái. *@
            <div class="ms-combo" data-ms-combo>
                <button type="button" class="ms-combo-trigger" data-ms-trigger aria-haspopup="listbox" aria-expanded="false">
                    <span class="ms-combo-text" data-ms-label data-ms-placeholder="Tất cả đơn vị"></span>
                    <span class="ms-combo-caret" aria-hidden="true">▾</span>
                </button>
                <div class="ms-combo-panel hidden" data-ms-panel>
                    <div class="ms-combo-search">
                        <label class="ms-combo-checkbox ms-combo-all" title="Chọn tất cả">
                            <input type="checkbox" data-ms-all />
                            <span class="ms-combo-box" aria-hidden="true"></span>
                        </label>
                        <div class="ms-combo-search-box">
                            <input type="text" placeholder="Tìm đơn vị…" autocomplete="off" data-ms-search />
                            <span class="ms-combo-search-icon" aria-hidden="true">🔍</span>
                        </div>
                    </div>
                    <ul class="ms-combo-list" role="listbox" aria-multiselectable="true" data-ms-list>
                        @foreach (var o in Model.OrgUnitOptions)
                        {
                            var isSelected = selectedOrgUnits.Contains(o.Code, StringComparer.OrdinalIgnoreCase);
                            <li class="ms-combo-option @(isSelected ? "selected" : "")" role="option" aria-selected="@(isSelected ? "true" : "false")" data-search="@o.Name.ToLowerInvariant()">
                                <label class="ms-combo-checkbox">
                                    <input type="checkbox" name="orgUnit" value="@o.Code" @(isSelected ? "checked" : "") data-ms-option />
                                    <span class="ms-combo-box" aria-hidden="true"></span>
                                    <span class="ms-combo-option-text">@o.Name</span>
                                </label>
                            </li>
                        }
                    </ul>
                    <div class="ms-combo-empty hidden" data-ms-empty>Không tìm thấy đơn vị</div>
                </div>
            </div>
        </div>
        <div class="filter-field">
            <label for="filter-status">Status</label>
            <select id="filter-status" name="status" onchange="this.form.submit()">
                <option value="">Tất cả trạng thái</option>
                @foreach (var s in Enum.GetValues<ProjectStatus>())
                {
                    <option value="@s" selected="@(Model.SelectedStatus == s)">@s</option>
                }
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn primary">Lọc</button>
            @if (hasFilter)
            {
                <a class="btn outline" asp-controller="Projects" asp-action="Index">Xóa lọc</a>
            }
        </div>
    </form>
</div>
<div class="card table-card">
    <table>
        <thead><tr><th>Project Name</th><th>Description</th><th>Created By</th><th>Org Unit</th><th>Created At</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="7" style="text-align:center; color:var(--muted); padding:24px;">
                        @(hasFilter ? "Không có dự án nào khớp với bộ lọc." : "Chưa có dự án nào.")
                    </td>
                </tr>
            }
            @foreach (var item in Model.Items)
            {
                var p = item.Project;
                <tr>
                    <td>
                        <div class="project-name-cell">
                            <b>@p.Name</b>
                        </div>
                    </td>
                    <td>@p.Description</td>
                    <td>@(string.IsNullOrWhiteSpace(p.CreatedByUsername) ? "—" : p.CreatedByUsername)</td>
                    @* Tên đơn vị tra từ OrgUnits; mã không còn trong dữ liệu HR thì hiển thị mã thô. *@
                    <td>@(item.OrgUnitName ?? (string.IsNullOrWhiteSpace(p.OrgUnitCode) ? "—" : p.OrgUnitCode))</td>
                    <td>@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td><span class="@Badge(p.Status)">@p.Status</span></td>
                    <td>
                        <div class="actions">
                            <a class="btn outline"
                               asp-controller="Requirements"
                               asp-action="Index"
                               asp-route-projectId="@p.Id">
                                Requirements
                            </a>

                            <a class="btn"
                               asp-controller="AgentDashboard"
                               asp-action="Index"
                               asp-route-projectId="@p.Id">
                                Agent Dashboard
                            </a>

                            @if (item.HasMockup)
                            {
                                <a class="btn success"
                                   asp-controller="Projects"
                                   asp-action="Mockup"
                                   asp-route-projectId="@p.Id"
                                   target="_blank">
                                    Mockup
                                </a>
                            }
                            else
                            {
                                <button class="btn disabled"
                                        type="button"
                                        disabled>
                                    Mockup
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="pager">
        <span>Showing @Model.FirstItemIndex to @Model.LastItemIndex of @Model.TotalCount projects</span>
        @if (Model.TotalPages > 1)
        {
            <div class="pager-controls">
                @if (Model.HasPrevious)
                {
                    <a class="btn outline" href="@PageUrl(Model.Page - 1)">‹ Prev</a>
                }
                else
                {
                    <span class="btn outline disabled">‹ Prev</span>
                }

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.Page)
                    {
                        <span class="btn primary">@i</span>
                    }
                    else
                    {
                        <a class="btn" href="@PageUrl(i)">@i</a>
                    }
                }

                @if (Model.HasNext)
                {
                    <a class="btn outline" href="@PageUrl(Model.Page + 1)">Next ›</a>
                }
                else
                {
                    <span class="btn outline disabled">Next ›</span>
                }
            </div>
        }
    </div>
</div>
<div id="newProject" class="modal-backdrop hidden">
    <form class="modal" asp-action="Create" method="post">
        <button type="button" class="x" onclick="closeModal('newProject')">×</button><h2>New Project</h2>
        <label>Name *</label><input name="Name" placeholder="e.g E-commerce Web App" required />
        <label>Description</label><input name="Description" placeholder="Short description" />
        @if (Model.OrgUnitOptions.Count > 0)
        {
            @* Đơn vị yêu cầu (tùy chọn): giúp BA hiểu bối cảnh phòng ban ngay từ đầu, tài liệu ghi đúng
               đơn vị chủ quản và trang Usage thống kê được theo phòng ban. Dropdown phẳng, không phân
               cấp Department/OrgUnit, kèm ô tìm kiếm để chọn nhanh khi danh sách dài. *@
            <label>Org Unit</label>
            <div class="org-combo" data-org-combo>
                <input type="hidden" name="OrgUnitCode" value="" data-org-value />
                <button type="button" class="org-combo-trigger" data-org-trigger aria-haspopup="listbox" aria-expanded="false">
                    <span class="org-combo-text is-placeholder" data-org-label>— Chưa chọn —</span>
                    <span class="org-combo-caret" aria-hidden="true">▾</span>
                </button>
                <div class="org-combo-panel hidden" data-org-panel>
                    <div class="org-combo-search">
                        <input type="text" placeholder="Tìm đơn vị…" autocomplete="off" data-org-search />
                        <span class="org-combo-search-icon" aria-hidden="true">🔍</span>
                    </div>
                    <ul class="org-combo-list" role="listbox" data-org-list>
                        <li class="org-combo-option" role="option" data-code="" data-search="">— Chưa chọn —</li>
                        @foreach (var o in Model.OrgUnitOptions)
                        {
                            <li class="org-combo-option" role="option" data-code="@o.Code" data-search="@o.Name.ToLowerInvariant()">@o.Name</li>
                        }
                    </ul>
                    <div class="org-combo-empty hidden" data-org-empty>Không tìm thấy đơn vị</div>
                </div>
            </div>
        }
        <div class="modal-actions"><button type="button" class="btn" onclick="closeModal('newProject')">Cancel</button><button class="btn primary">Create Project</button></div>
    </form>
</div>

@section Scripts {
    <script>
        // Dropdown "Đơn vị yêu cầu" có ô tìm kiếm: hiển thị nhãn đã chọn, lọc danh sách theo từ khóa,
        // ghi mã đơn vị vào hidden input để form submit. Không phân cấp Department/OrgUnit — danh sách phẳng.
        (function () {
            var combo = document.querySelector('[data-org-combo]');
            if (!combo) return;

            var trigger = combo.querySelector('[data-org-trigger]');
            var panel = combo.querySelector('[data-org-panel]');
            var label = combo.querySelector('[data-org-label]');
            var value = combo.querySelector('[data-org-value]');
            var search = combo.querySelector('[data-org-search]');
            var empty = combo.querySelector('[data-org-empty]');
            var options = Array.prototype.slice.call(combo.querySelectorAll('.org-combo-option'));

            function open() {
                combo.classList.add('open');
                panel.classList.remove('hidden');
                trigger.setAttribute('aria-expanded', 'true');
                search.value = '';
                filter();
                search.focus();
            }

            function close() {
                combo.classList.remove('open');
                panel.classList.add('hidden');
                trigger.setAttribute('aria-expanded', 'false');
            }

            function filter() {
                var q = search.value.trim().toLowerCase();
                var visible = 0;
                options.forEach(function (opt) {
                    var match = q === '' || opt.getAttribute('data-search').indexOf(q) !== -1;
                    opt.classList.toggle('hidden', !match);
                    if (match) visible++;
                });
                empty.classList.toggle('hidden', visible > 0);
            }

            function select(opt) {
                value.value = opt.getAttribute('data-code');
                label.textContent = opt.textContent;
                label.classList.toggle('is-placeholder', opt.getAttribute('data-code') === '');
                options.forEach(function (o) { o.classList.remove('selected'); });
                opt.classList.add('selected');
                close();
            }

            trigger.addEventListener('click', function () {
                if (combo.classList.contains('open')) close(); else open();
            });

            options.forEach(function (opt) {
                opt.addEventListener('click', function () { select(opt); });
            });

            search.addEventListener('input', filter);

            search.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { close(); trigger.focus(); }
            });

            document.addEventListener('click', function (e) {
                if (!combo.contains(e.target)) close();
            });
        })();

        // Combo "Đơn vị yêu cầu" ở thanh lọc — chọn NHIỀU. Mỗi option là 1 checkbox name="orgUnit" sẵn trong
        // form GET; JS chỉ lo giao diện (nhãn nút, mở/đóng panel, tìm kiếm, chọn tất cả) và đồng bộ lớp
        // .selected. Không tự submit theo từng tick — người dùng chọn xong rồi bấm "Lọc".
        (function () {
            var combo = document.querySelector('[data-ms-combo]');
            if (!combo) return;

            var trigger = combo.querySelector('[data-ms-trigger]');
            var panel = combo.querySelector('[data-ms-panel]');
            var label = combo.querySelector('[data-ms-label]');
            var search = combo.querySelector('[data-ms-search]');
            var empty = combo.querySelector('[data-ms-empty]');
            var allBox = combo.querySelector('[data-ms-all]');
            var placeholder = label.getAttribute('data-ms-placeholder') || '';
            var options = Array.prototype.slice.call(combo.querySelectorAll('.ms-combo-option'));

            function checkboxOf(opt) { return opt.querySelector('[data-ms-option]'); }
            function isVisible(opt) { return !opt.classList.contains('hidden'); }

            // Nhãn nút: 0 chọn → placeholder; 1–2 → ghép tên; >2 → "N mục đã chọn".
            function renderLabel() {
                var names = options
                    .filter(function (opt) { return checkboxOf(opt).checked; })
                    .map(function (opt) { return opt.querySelector('.ms-combo-option-text').textContent.trim(); });
                if (names.length === 0) {
                    label.textContent = placeholder;
                    label.classList.add('is-placeholder');
                } else {
                    label.textContent = names.length <= 2 ? names.join(', ') : (names.length + ' mục đã chọn');
                    label.classList.remove('is-placeholder');
                }
            }

            // Trạng thái "Chọn tất cả" bám theo các option ĐANG hiển thị (sau khi lọc tìm kiếm).
            function renderAll() {
                var visible = options.filter(isVisible);
                var checked = visible.filter(function (opt) { return checkboxOf(opt).checked; });
                allBox.checked = visible.length > 0 && checked.length === visible.length;
                allBox.indeterminate = checked.length > 0 && checked.length < visible.length;
            }

            function syncOption(opt) {
                var on = checkboxOf(opt).checked;
                opt.classList.toggle('selected', on);
                opt.setAttribute('aria-selected', on ? 'true' : 'false');
            }

            function open() {
                combo.classList.add('open');
                panel.classList.remove('hidden');
                trigger.setAttribute('aria-expanded', 'true');
                search.value = '';
                filter();
                search.focus();
            }

            function close() {
                combo.classList.remove('open');
                panel.classList.add('hidden');
                trigger.setAttribute('aria-expanded', 'false');
            }

            function filter() {
                var q = search.value.trim().toLowerCase();
                var visible = 0;
                options.forEach(function (opt) {
                    var match = q === '' || opt.getAttribute('data-search').indexOf(q) !== -1;
                    opt.classList.toggle('hidden', !match);
                    if (match) visible++;
                });
                empty.classList.toggle('hidden', visible > 0);
                renderAll();
            }

            trigger.addEventListener('click', function () {
                if (combo.classList.contains('open')) close(); else open();
            });

            options.forEach(function (opt) {
                checkboxOf(opt).addEventListener('change', function () {
                    syncOption(opt);
                    renderLabel();
                    renderAll();
                });
            });

            allBox.addEventListener('change', function () {
                var on = allBox.checked;
                options.filter(isVisible).forEach(function (opt) {
                    var cb = checkboxOf(opt);
                    if (cb.checked !== on) {
                        cb.checked = on;
                        syncOption(opt);
                    }
                });
                renderLabel();
                renderAll();
            });

            search.addEventListener('input', filter);

            search.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { close(); trigger.focus(); }
            });

            document.addEventListener('click', function (e) {
                if (!combo.contains(e.target)) close();
            });

            renderLabel();
            renderAll();
        })();
    </script>
}
