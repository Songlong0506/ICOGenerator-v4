@model ICOGenerator.Application.Projects.ProjectListPage
@{
    string Badge(ProjectStatus s) => s switch { ProjectStatus.Completed => "badge green", ProjectStatus.InProgress => "badge blue", _ => "badge orange" };
}

<style>
    .btn.disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }

    .pager {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .pager-controls {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

        .pager-controls .btn {
            padding: 8px 12px;
            min-width: 40px;
        }

    .btn.success {
        border-color: #10b981;
        color: #10b981;
        background: #ecfdf5;
    }

    .project-name-cell {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .task-running-indicator {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        border: 1px solid #93c5fd;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 12px;
        font-weight: 800;
        padding: 5px 10px;
    }

    .task-running-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #2563eb;
        box-shadow: 0 0 0 rgba(37, 99, 235, .5);
        animation: projectTaskPulse 1.5s infinite;
    }

    @@keyframes projectTaskPulse {
        0% {
            box-shadow: 0 0 0 0 rgba(37, 99, 235, .5);
        }

        70% {
            box-shadow: 0 0 0 8px rgba(37, 99, 235, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(37, 99, 235, 0);
        }
    }
</style>

<div class="page-head">
    <div>
        <h1>Projects</h1>
    </div>
    <button class="btn primary" onclick="openModal('newProject')">＋ New Project</button>
</div>
<div class="card table-card">
    <table>
        <thead><tr><th>Project Name</th><th>Description</th><th>Created At</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                var p = item.Project;
                <tr>
                    <td>
                        <div class="project-name-cell">
                            <b>@p.Name</b>
                            @if (item.HasRunningWorkflow)
                            {
                                <span class="task-running-indicator" title="Workflow @item.LatestWorkflowStatus - @item.LatestWorkflowStage">
                                    <span class="task-running-dot"></span>
                                    Task đang chạy
                                </span>
                            }
                        </div>
                    </td>
                    <td>@p.Description</td>
                    <td>@p.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td><span class="@Badge(p.Status)">@p.Status</span></td>
                    <td class="actions">
                        <a class="btn outline"
                           asp-controller="Requirements"
                           asp-action="Index"
                           asp-route-projectId="@p.Id">
                            Requirements
                        </a>

                        <a class="btn"
                           asp-controller="AgentDashboard"
                           asp-action="Index"
                           asp-route-projectId="@p.Id">
                            Agent Dashboard
                        </a>

                        @if (item.HasMockup)
                        {
                            <a class="btn success"
                               asp-controller="Projects"
                               asp-action="Mockup"
                               asp-route-projectId="@p.Id"
                               target="_blank">
                                Mockup
                            </a>
                        }
                        else
                        {
                            <button class="btn disabled"
                                    type="button"
                                    disabled>
                                Mockup
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="pager">
        <span>Showing @Model.FirstItemIndex to @Model.LastItemIndex of @Model.TotalCount projects</span>
        @if (Model.TotalPages > 1)
        {
            <div class="pager-controls">
                @if (Model.HasPrevious)
                {
                    <a class="btn outline" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">‹ Prev</a>
                }
                else
                {
                    <span class="btn outline disabled">‹ Prev</span>
                }

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.Page)
                    {
                        <span class="btn primary">@i</span>
                    }
                    else
                    {
                        <a class="btn" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                    }
                }

                @if (Model.HasNext)
                {
                    <a class="btn outline" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Next ›</a>
                }
                else
                {
                    <span class="btn outline disabled">Next ›</span>
                }
            </div>
        }
    </div>
</div>
<div id="newProject" class="modal-backdrop hidden">
    <form class="modal" asp-action="Create" method="post">
        <button type="button" class="x" onclick="closeModal('newProject')">×</button><h2>New Project</h2>
        <label>Name *</label><input name="Name" placeholder="e.g E-commerce Web App" required />
        <label>Description</label><input name="Description" placeholder="Short description" />
        <div class="modal-actions"><button type="button" class="btn" onclick="closeModal('newProject')">Cancel</button><button class="btn primary">Create Project</button></div>
    </form>
</div>
