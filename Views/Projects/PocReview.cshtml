@model ICOGenerator.Application.Projects.PocReviewPage
@{
    ViewData["Title"] = "POC Review";
    var canManage = ViewBag.CanManageComments is bool cm && cm;
}

@* Trang review POC: nhúng POC (sandbox, origin opaque — xem ProjectsController.Mockup) trong iframe ở
   chế độ review (annotator được tiêm lúc phục vụ), kèm panel ghi chú bên phải. Người xem bật "chế độ
   ghim", click phần tử trong POC để ghi chú; các ghi chú Open được người duyệt gom vào "Yêu cầu chỉnh
   sửa" ở cổng POC trên Agent Dashboard. Trang cha (đây) giữ toàn bộ thao tác ghi/xóa — iframe chỉ nói
   chuyện qua postMessage nên rào chắn sandbox giữ nguyên. *@

<div class="page-head">
    <div>
        <h1>POC Review</h1>
        <p class="muted">Bật chế độ ghim rồi click vào phần tử trong POC để ghi chú cho đội Dev.</p>
    </div>
</div>

<div class="poc-review-layout"
     id="pocReviewRoot"
     data-project-id="@Model.ProjectId"
     data-comments-url="@Url.Action("PocComments", "Projects", new { projectId = Model.ProjectId })"
     data-add-url="@Url.Action("AddPocComment", "Projects")"
     data-delete-url="@Url.Action("DeletePocComment", "Projects")"
     data-route-req-url="@Url.Action("RoutePocFeedbackToRequirement", "Projects")">

    <section class="card poc-frame-panel">
        <div class="poc-toolbar">
            <button type="button" id="pinModeBtn" class="btn outline">📌 Bật chế độ ghim</button>
            <span class="muted poc-toolbar-hint" id="pinModeHint">Chế độ ghim đang tắt — POC thao tác bình thường.</span>
            <a class="btn outline small poc-open-tab"
               asp-action="Mockup"
               asp-route-projectId="@Model.ProjectId"
               target="_blank">Mở tab riêng ↗</a>
        </div>

        @* sandbox trên thẻ iframe LẶP LẠI đúng CSP sandbox mà endpoint Mockup tự đặt (defense-in-depth,
           không nới thêm gì); review=True để server tiêm annotator vào tài liệu (bool binder KHÔNG
           nhận "1" — phải là true/false). *@
        <iframe id="pocFrame"
                title="POC demo"
                src="@Url.Action("Mockup", "Projects", new { projectId = Model.ProjectId, review = true })"
                sandbox="allow-scripts allow-forms allow-modals"></iframe>
    </section>

    <aside class="card poc-comments-panel">
        @* Checklist UAT: kịch bản đi-từng-bước sinh từ AI Design Spec (UatScenarioService) — biến review
           từ khám phá tự do thành nghiệm thu có kịch bản. Tick từng bước (lưu localStorage); bước không
           đạt thì "Báo lỗi" mở form ghi chú prefill sẵn ngữ cảnh kịch bản. *@
        @if (Model.Scenarios.Scenarios.Any())
        {
            <details class="uat-panel" open>
                <summary>🧭 Kịch bản kiểm thử <span class="poc-count">(@Model.Scenarios.Scenarios.Count)</span></summary>
                <p class="muted poc-panel-hint">Đi theo từng kịch bản, tick các bước đã đạt; bấm vào một bước để POC <b>chỉ chỗ</b> cần thao tác; bước nào sai thì bấm "Báo lỗi".</p>
                <div id="uatList">
                    @for (var i = 0; i < Model.Scenarios.Scenarios.Count; i++)
                    {
                        var scenario = Model.Scenarios.Scenarios[i];
                        <div class="uat-scenario" data-screen="@scenario.Screen" data-title="@scenario.Title">
                            <div class="uat-title">
                                @scenario.Title
                                @if (scenario.RuleRefs.Any())
                                {
                                    <span class="uat-rules" title="Business rule kịch bản này kiểm chứng">@string.Join(", ", scenario.RuleRefs)</span>
                                }
                                <button type="button" class="btn outline small uat-tour" title="Đi lần lượt từng bước, POC sẽ chỉ chỗ">▶ Hướng dẫn</button>
                            </div>
                            <ol class="uat-steps">
                                @for (var j = 0; j < scenario.Steps.Count; j++)
                                {
                                    <li>
                                        <label>
                                            <input type="checkbox" class="uat-step" data-key="@(i)-@(j)" />
                                            <span class="uat-step-text" data-step="@scenario.Steps[j]" title="Bấm để POC chỉ chỗ thao tác này">@scenario.Steps[j]</span>
                                        </label>
                                    </li>
                                }
                            </ol>
                            <button type="button" class="btn outline small uat-fail">✗ Báo lỗi kịch bản này</button>
                        </div>
                    }
                </div>
            </details>
        }

        <h3>Ghi chú trên POC <span class="poc-count" id="pocCommentCount"></span></h3>
        <p class="muted poc-panel-hint">
            Ghi chú sẽ được gom vào "Yêu cầu chỉnh sửa" ở cổng POC (Agent Dashboard) để agent sửa đúng phần tử.
        </p>
        @* Đóng vòng POC → TÀI LIỆU: khi POC lộ ra điều tài liệu yêu cầu HIỂU SAI (thiếu màn hình/bước, sai
           công thức…), gửi các điểm đó về BA để sửa TÀI LIỆU rồi dựng lại POC — thay vì chỉ vá HTML. Ghi
           chú thẩm mỹ được bỏ qua ở đây. Chỉ hiện với người có quyền quản lý requirement. *@
        @if (canManage)
        {
            <div class="poc-route-req">
                <button type="button" id="pocRouteReqBtn" class="btn outline small full">↩ Có điểm hiểu sai yêu cầu → gửi về Requirement</button>
                <p class="muted poc-panel-hint" id="pocRouteReqHint">
                    Dùng khi bản demo cho thấy TÀI LIỆU yêu cầu còn thiếu/sai (không phải lỗi trình bày). BA sẽ
                    cập nhật lại bản mô tả, sau đó anh/chị duyệt lại để dựng POC mới từ tài liệu đã sửa.
                </p>
            </div>
        }

        <form id="pocCommentForm" class="poc-comment-form" hidden>
            @Html.AntiForgeryToken()
            <div class="poc-target-label" id="pocTargetLabel"></div>
            <textarea id="pocCommentText" rows="3" maxlength="4000"
                      placeholder="Phần tử này cần sửa gì? Ví dụ: đổi nhãn thành 'Lưu', thêm cột Trạng thái…"></textarea>
            <div class="poc-form-actions">
                <button type="submit" class="btn primary small">Ghim ghi chú</button>
                <button type="button" class="btn outline small" id="pocCommentCancel">Hủy</button>
            </div>
        </form>

        <div id="pocCommentList" class="poc-comment-list">
            <p class="muted">Đang tải ghi chú…</p>
        </div>

        @* Changelog các vòng "Yêu cầu chỉnh sửa" đã chạy: bàn giao cuối của agent nêu đã đổi gì ứng với
           từng ghi chú — người review thấy ngay POC mới khác gì thay vì phải tự so hai bản. *@
        @if (Model.Revisions.Any())
        {
            <div class="poc-changelog">
                <h3>Nhật ký vòng sửa <span class="poc-count">(@Model.Revisions.Count)</span></h3>
                @foreach (var revision in Model.Revisions)
                {
                    <details class="poc-changelog-item">
                        <summary>@revision.Title@(revision.FinishedAt.HasValue ? $" · {revision.FinishedAt.Value.ToLocalTime():dd/MM HH:mm}" : "")</summary>
                        <pre>@revision.Output</pre>
                    </details>
                }
            </div>
        }
    </aside>
</div>

@section Breadcrumb {
    Projects <span class="sep">&rsaquo;</span> @Model.ProjectName <span class="sep">&rsaquo;</span> <b>POC Review</b>
}

@section Styles {
    <link rel="stylesheet" href="~/css/poc-review.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.POC_REVIEW_CAN_MANAGE = @(canManage ? "true" : "false");
    </script>
    <script src="~/js/poc-review.js" asp-append-version="true"></script>
}
