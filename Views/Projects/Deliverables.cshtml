@model ICOGenerator.Application.Projects.ProjectDeliverablesVm
@{
    ViewData["Title"] = "Deliverables";

    string PhaseLabel(string phase) => phase switch
    {
        "01_Requirement" => "📋 Requirement",
        "02_Design" => "🎨 Design (UI/UX)",
        "03_Architecture" => "🏛️ Architecture",
        "04_Implementation" => "💻 Implementation",
        "05_Test" => "🧪 Test",
        _ => phase
    };

    static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024.0):0.#} MB";
    }

    var totalFiles = Model.Phases.Sum(p => p.Files.Count);
}

<div class="page-head">
    <div>
        <h1>Deliverables</h1>
    </div>
    @if (Model.PocReady)
    {
        <a class="btn primary"
           asp-controller="Projects" asp-action="Mockup" asp-route-projectId="@Model.ProjectId"
           target="_blank">▶ Xem POC (live)</a>
    }
</div>

<div class="card">
    <p class="muted" style="margin-top:0;">
        Tổng hợp mọi sản phẩm pipeline đã sinh ra trong workspace của dự án <b>@Model.ProjectName</b>
        (UI/UX spec, kiến trúc, code, biên bản review, test report…).
    </p>

    @if (!Model.HasWorkspace || totalFiles == 0)
    {
        <div class="empty-history">
            Chưa có sản phẩm nào. Hãy duyệt requirement và chạy quy trình delivery để pipeline sinh deliverables.
        </div>
    }
    else
    {
        @foreach (var phase in Model.Phases)
        {
            <h3 style="margin-bottom:8px;">@PhaseLabel(phase.Phase) <span class="muted">(@phase.Files.Count)</span></h3>
            <div class="table-card" style="margin-bottom:20px;">
                <table>
                    <thead>
                        <tr><th>File</th><th>Kích thước</th><th>Cập nhật</th><th>Hành động</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var file in phase.Files)
                        {
                            var display = file.RelativePath.StartsWith(phase.Phase + "/")
                                ? file.RelativePath.Substring(phase.Phase.Length + 1)
                                : file.RelativePath;
                            <tr>
                                <td>@display</td>
                                <td>@FormatSize(file.SizeBytes)</td>
                                <td><span class="dl-time" data-utc="@file.ModifiedUtc"></span></td>
                                <td class="actions">
                                    @if (file.TextPreviewable)
                                    {
                                        <a class="btn outline small"
                                           asp-action="DeliverableFile"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-path="@file.RelativePath"
                                           target="_blank">Xem</a>
                                    }
                                    <a class="btn outline small"
                                       asp-action="DeliverableFile"
                                       asp-route-projectId="@Model.ProjectId"
                                       asp-route-path="@file.RelativePath"
                                       asp-route-download="true">Tải</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@section Breadcrumb {
    Projects <span class="sep">&rsaquo;</span> @Model.ProjectName <span class="sep">&rsaquo;</span> <b>Deliverables</b>
}

@section Scripts {
    <script>
        // Thời gian server trả dạng UTC ISO ('...Z') → đổi sang giờ local của người xem.
        document.querySelectorAll('.dl-time').forEach(function (el) {
            var v = el.dataset.utc;
            if (v) el.textContent = new Date(v).toLocaleString();
        });
    </script>
}
