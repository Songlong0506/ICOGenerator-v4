@model Project

@{
    var documents = Model.Documents
        .OrderByDescending(x => x.CreatedAt)
        .ToList();

    var latestDocument = documents.FirstOrDefault();

    var conversations = Model.Conversations
        .OrderBy(x => x.CreatedAt)
        .ToList();

    var draftDocs = Model.Documents
   .Where(x => x.VersionName == "draft")
   .OrderBy(x => x.FileName)
   .ToList();

    var brd = draftDocs.FirstOrDefault(x => x.FileName == "BRD.md");
    var srs = draftDocs.FirstOrDefault(x => x.FileName == "SRS.md");
    var userStories = draftDocs.FirstOrDefault(x => x.FileName == "UserStories.md");
}

<div class="breadcrumb">
    Projects › @Model.Name › <b>Create Document</b>
</div>

<div class="page-head">
    <div>
        <h1>Create Document</h1>
        <p>Chat with BA to define and capture requirements</p>
    </div>

    <div class="card status">
        <span>Requirement Status</span>
        <b>Draft</b>
    </div>
</div>

<div class="grid doc-grid">
    <aside class="card">
        <h3>History</h3>

        <input class="search full" placeholder="Search in history" />

        @if (documents.Any())
        {
            var versions = Model.Documents.GroupBy(x => x.VersionName)
       .OrderByDescending(g => g.Key == "draft" ? int.MaxValue : int.TryParse(g.Key.Replace("V", ""), out var n) ? n : 0)
       .ToList();

            foreach (var version in versions)
            {
                <div class="history @(version.Key == "draft" ? "active" : "")">
                    <span>📄 Requirement @version.Key</span>
                    <button type="button">View</button>
                </div>
            }
        }
        else
        {
            <p class="muted">No requirement history yet.</p>
        }

        <form asp-action="NewChat" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@Model.Id" />
            <button class="btn outline full bottom" type="submit">
                ＋ New Chat
            </button>
        </form>
    </aside>

    <section class="card chat">
        @if (!conversations.Any())
        {
            <div class="msg ba">
                <b>BA</b>
                <p>Xin chào! Tôi là Business Analyst. Bạn có thể mô tả ngắn gọn ý tưởng dự án không?</p>
            </div>
        }
        else
        {
            foreach (var item in conversations)
            {
                if (item.Role == "user")
                {
                    <div class="msg you">
                        <p>@item.Message</p>
                    </div>
                }
                else
                {
                    <div class="msg ba">
                        <b>@item.Agent.Name</b>
                        <pre>@item.Message</pre>
                    </div>
                }
            }
        }

        <form asp-action="Chat" method="post" class="chatbox">
            @Html.AntiForgeryToken()

            <input type="hidden" name="projectId" value="@Model.Id" />

            <input name="message"
                   placeholder="Type your message..."
                   autocomplete="off"
                   required />

            <button class="btn primary" type="submit">➤</button>
        </form>
    </section>

    <aside class="card requirement">
        <h3>Requirement Draft</h3>

        <div class="requirement-tabs">
            <button type="button" onclick="showReqTab('brd')">BRD</button>
            <button type="button" onclick="showReqTab('srs')">SRS</button>
            <button type="button" onclick="showReqTab('stories')">User Stories</button>
        </div>

        <div id="req-brd" class="req-doc">
            <h4>BRD.md</h4>
            <pre>@(brd?.Content ?? "Chưa có BRD.")</pre>
        </div>

        <div id="req-srs" class="req-doc hidden">
            <h4>SRS.md</h4>
            <pre>@(srs?.Content ?? "Chưa có SRS.")</pre>
        </div>

        <div id="req-stories" class="req-doc hidden">
            <h4>UserStories.md</h4>
            <pre>@(userStories?.Content ?? "Chưa có User Stories.")</pre>
        </div>

        <form asp-action="Approve" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@Model.Id" />

            <button class="btn approve full" type="submit">
                I approve this requirement
            </button>
        </form>

        <p>BA chỉ chuyển requirement cho Developer sau khi bạn approve.</p>
    </aside>

    <script>
            function showReqTab(name) {
                document.querySelectorAll('.req-doc').forEach(x => x.classList.add('hidden'));
                document.getElementById('req-' + name).classList.remove('hidden');
            }
    </script>
</div>