@model Project
@using System.IO

@{
    ViewData["Title"] = "Create Document";
    var allDocuments = Model.Documents
    .OrderBy(x => x.FileName)
    .ToList();
    var draftDocuments = Model.Documents
        .Where(x => x.VersionName == "draft")
        .OrderBy(x => x.FileName)
        .ToList();

    var versions = Model.Documents
        .GroupBy(x => x.VersionName)
        .OrderByDescending(g => g.Key == "draft" ? int.MaxValue :
            int.TryParse(g.Key.Replace("V", ""), out var n) ? n : 0)
        .ToList();
    var selectedVersion = ViewBag.SelectedVersion?.ToString() ?? "draft";
    var conversations = Model.Conversations
        .OrderBy(x => x.CreatedAt)
        .ToList();

    string GetPreviewContent(string path)
    {
        try
        {
            if (System.IO.File.Exists(path))
            {
                return System.IO.File.ReadAllText(path)
                    .Replace("\r", "")
                    .Split('\n')
                    .Take(30)
                    .Aggregate("", (a, b) => a + b + "\n");
            }
        }
        catch { }

        return "No preview available.";
    }
}

<div class="breadcrumb">
    Projects › @Model.Name › <b>Create Document</b>
</div>

<div class="page-head">
    <div>
        <h1>Create Document</h1>
        <p>Chat with BA to define and capture requirements</p>
    </div>

    <div class="card status">
        <span>Requirement Status</span>
        <b>@(draftDocuments.Any() ? "Draft" : "Empty")</b>
    </div>
</div>

<div class="grid doc-grid">

    <!-- HISTORY -->
    <aside class="card history-panel">

        <h3>History</h3>

        <input class="search full"
               placeholder="Search in history" />

        @if (versions.Any())
        {
            foreach (var version in versions)
            {
                <div class="history-item">

                    <div class="history-left">
                        <div class="history-icon">📄</div>

                        <div>
                            <div class="history-title">
                                Requirement @version.Key
                            </div>

                            <div class="history-sub">
                                @version.Count() documents
                            </div>
                        </div>
                    </div>

                    <button type="button"
                            class="btn outline small"
                            onclick="openRequirementModal('@version.Key')">
                        View
                    </button>
                </div>
            }
        }
        else
        {
            <div class="empty-history">
                No requirement history yet.
            </div>
        }

        <form asp-action="NewChat"
              method="post"
              class="new-chat-form">

            <input type="hidden"
                   name="projectId"
                   value="@Model.Id" />

            <button class="btn outline full bottom">
                ＋ New Chat
            </button>
        </form>

    </aside>

    <!-- CHAT -->
    <section class="card chat-panel">

        <div id="chatMessages"
             class="chat-messages">

            @if (!conversations.Any())
            {
                <div class="msg ba">
                    <b>BA</b>

                    <p>
                        Xin chào! Tôi là Business Analyst.
                        Bạn có thể mô tả ngắn gọn ý tưởng dự án không?
                    </p>
                </div>
            }

            @foreach (var item in conversations)
            {
                if (item.Role == "user")
                {
                    <div class="msg you">
                        <p>@item.Message</p>
                    </div>
                }
                else
                {
                    <div class="msg ba">
                        <b>BA</b>

                        <p style="white-space: pre-wrap;">
                            @item.Message
                        </p>
                    </div>
                }
            }

            <!-- THINKING -->
            <div id="thinkingBox"
                 class="msg ba thinking"
                 style="display:none;">

                <b>BA</b>

                <div class="thinking-content">

                    <div class="spinner"></div>

                    <span id="thinkingText">
                        BA is analyzing requirements...
                    </span>

                </div>
            </div>

        </div>

        <!-- CHAT INPUT -->
        <form id="chatForm"
              asp-action="Chat"
              method="post"
              class="chatbox">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="projectId"
                   value="@Model.Id" />

            <input type="hidden"
                   id="hiddenMessage"
                   name="message" />

            <input id="messageInput"
                   placeholder="Type your message..."
                   autocomplete="off" />

            <button class="btn primary"
                    type="submit">
                ➤
            </button>
        </form>

    </section>

</div>

<!-- REQUIREMENT MODAL -->
<div id="requirementModal" class="modal-overlay">
    <div class="modal requirement-modal">

        <div class="modal-header">
            <div>
                <h2 id="modalTitle">Requirement</h2>
                <p>Preview generated requirement documents</p>
            </div>

            <button class="modal-close" onclick="closeRequirementModal()">
                ✕
            </button>
        </div>

        <div class="requirement-tabs">
            @foreach (var doc in allDocuments)
            {
                <button class="doc-tab"
                        data-version="@doc.VersionName"
                        onclick="showDocument('@doc.Id')"
                        style="display:none;">
                    @System.IO.Path.GetFileNameWithoutExtension(doc.FileName)
                </button>
            }
        </div>

        <div class="requirement-content">
            @foreach (var doc in allDocuments)
            {
                <div class="doc-preview"
                     id="doc-@doc.Id"
                     data-version="@doc.VersionName"
                     style="display:none;">

                    <h3>@doc.FileName</h3>

                    <pre>@(string.IsNullOrWhiteSpace(doc.Content) ? "No preview available." : doc.Content)</pre>

                    <div class="doc-actions">
                       @*  <a class="btn outline"
                           target="_blank"
                           href="/CreateDocument/DownloadDocument/@doc.Id">
                            Download
                        </a> *@

                        <a class="btn outline"
                           asp-controller="CreateDocument"
                           asp-action="DownloadDocument"
                           asp-route-id="@doc.Id">
                            Download
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="modal-footer">
            @if (selectedVersion == "draft")
            {
                <form asp-action="Approve" method="post">
                    <input type="hidden"
                           name="projectId"
                           value="@Model.Id" />

                    <button class="btn approve">
                        I approve this requirement
                    </button>
                </form>
            }
        </div>

    </div>
</div>
<style>

    .doc-grid {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 20px;
        height: calc(100vh - 180px);
    }

    .history-panel {
        display: flex;
        flex-direction: column;
    }

    .chat-panel {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding-right: 10px;
    }

    .history-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 14px;
        margin-top: 12px;
        background: #faf7ff;
    }

    .history-left {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .history-title {
        font-weight: 600;
    }

    .history-sub {
        font-size: 12px;
        color: #777;
    }

    .history-icon {
        font-size: 20px;
    }

    .empty-history {
        margin-top: 20px;
        color: #999;
    }

    .msg {
        padding: 18px;
        border-radius: 16px;
        margin-bottom: 16px;
        max-width: 75%;
    }

        .msg.you {
            margin-left: auto;
            background: #efe7ff;
        }

        .msg.ba {
            background: #f8f8f8;
        }

    .chatbox {
        display: flex;
        gap: 12px;
        margin-top: 20px;
    }

        .chatbox input {
            flex: 1;
        }

    .thinking {
        border: 1px dashed #8b5cf6;
    }

    .thinking-content {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 10px;
    }

    .spinner {
        width: 18px;
        height: 18px;
        border: 3px solid #ddd;
        border-top: 3px solid #8b5cf6;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal {
        background: white;
        border-radius: 20px;
        width: 1100px;
        max-width: 95%;
        max-height: 90vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .modal-header {
        padding: 24px;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-close {
        border: none;
        background: none;
        font-size: 22px;
        cursor: pointer;
    }

    .requirement-tabs {
        display: flex;
        gap: 10px;
        padding: 20px;
        border-bottom: 1px solid #eee;
    }

    .doc-tab {
        border: 1px solid #8b5cf6;
        background: white;
        color: #8b5cf6;
        border-radius: 8px;
        padding: 8px 14px;
        cursor: pointer;
    }

    .requirement-content {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
    }

    .doc-preview pre {
        white-space: pre-wrap;
        line-height: 1.6;
        background: #fafafa;
        padding: 20px;
        border-radius: 12px;
    }

    .doc-actions {
        margin-top: 20px;
    }

    .modal-footer {
        padding: 20px 24px;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: flex-end;
    }

</style>

<script>

    const chatForm = document.getElementById("chatForm");
    const messageInput = document.getElementById("messageInput");
    const chatMessages = document.getElementById("chatMessages");
    const thinkingBox = document.getElementById("thinkingBox");

     chatForm.addEventListener("submit", function (e) {
        const text = messageInput.value.trim();

        if (!text) {
            e.preventDefault();
            return;
        }

        document.getElementById("hiddenMessage").value = text;

        const html = `
            <div class="msg you">
                <p>${text}</p>
            </div>
        `;

        chatMessages.insertAdjacentHTML("beforeend", html);

        messageInput.value = "";
        thinkingBox.style.display = "block";
        chatMessages.scrollTop = chatMessages.scrollHeight;
    });

     function openRequirementModal(version) {
        document.getElementById("modalTitle").innerText =
            "Requirement " + version;

        document.getElementById("requirementModal").style.display = "flex";

        document.querySelectorAll(".doc-tab")
            .forEach(x => x.style.display = "none");

        document.querySelectorAll(".doc-preview")
            .forEach(x => x.style.display = "none");

        const tabs = document.querySelectorAll(`.doc-tab[data-version="${version}"]`);
        const docs = document.querySelectorAll(`.doc-preview[data-version="${version}"]`);

        tabs.forEach(x => x.style.display = "inline-block");

        if (docs.length > 0) {
            docs[0].style.display = "block";
        }
    }

    function closeRequirementModal() {
        document.getElementById("requirementModal").style.display = "none";
    }

    function showDocument(id) {

        document.querySelectorAll(".doc-preview")
            .forEach(x => x.style.display = "none");

        const target = document.getElementById("doc-" + id);

        if (target)
            target.style.display = "block";
    }

</script>
