@model Project

@{
    var documents = Model.Documents.OrderByDescending(x => x.CreatedAt).ToList();
    var latestDocument = documents.FirstOrDefault();
    var conversations = Model.Conversations.OrderBy(x => x.CreatedAt).ToList();
    var draftDocs = Model.Documents.Where(x => x.VersionName == "draft").OrderBy(x => x.FileName).ToList();
    var selectedVersion = ViewBag.SelectedVersion as string ?? "draft";
    var selectedDocs = Model.Documents.Where(x => x.VersionName == selectedVersion)
    .OrderBy(x => x.FileName)
    .ToList();

    var brd = selectedDocs.FirstOrDefault(x => x.FileName == "BRD.md");
    var srs = selectedDocs.FirstOrDefault(x => x.FileName == "SRS.md");
    var userStories = selectedDocs.FirstOrDefault(x => x.FileName == "UserStories.md");
    var versions = Model.Documents.GroupBy(x => x.VersionName)
    .OrderByDescending(g => g.Key == "draft" ? int.MaxValue :
        int.TryParse(g.Key.Replace("V", ""), out var n) ? n : 0)
    .ToList();
}

<style>
    #chatMessages {
        flex: 1;
        overflow-y: auto;
        padding-right: 8px;
    }

    .chat {
        display: flex;
        flex-direction: column;
    }

    .agent-status {
        margin-top: 12px;
        padding: 12px 16px;
        border: 1px solid #c4b5fd;
        background: #f5f3ff;
        color: #4c1d95;
        border-radius: 10px;
        display: flex;
        gap: 12px;
        align-items: center;
    }

        .agent-status.hidden {
            display: none;
        }
</style>

<div class="breadcrumb">
    Projects › @Model.Name › <b>Create Document</b>
</div>

<div class="page-head">
    <div>
        <h1>Create Document</h1>
        <p>Chat with BA to define and capture requirements</p>
    </div>

    <div class="card status">
        <span>Requirement Status</span>
        <b>Draft</b>
    </div>
</div>

<div class="grid doc-grid">
    <aside class="card">
        <h3>History</h3>

        <input class="search full" placeholder="Search in history" />

        @if (versions.Any())
        {
            foreach (var version in versions)
            {
                <div class="history @(version.Key == selectedVersion ? "active" : "")">
                    <span>📄 Requirement @version.Key</span>

                    <a class="btn small"
                           asp-action="Index"
                           asp-route-projectId="@Model.Id"
                           asp-route-version="@version.Key">
                        View
                    </a>
                </div>
            }
        }
        else
        {
            <p class="muted">No requirement history yet.</p>
        }

        <form asp-action="NewChat" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@Model.Id" />
            <button class="btn outline full bottom" type="submit">
                ＋ New Chat
            </button>
        </form>
    </aside>

    <section class="card chat">
        <div id="chatMessages">
            @if (!conversations.Any())
            {
                <div class="msg ba">
                    <b>BA</b>
                    <p>Xin chào! Tôi là Business Analyst. Bạn có thể mô tả ngắn gọn ý tưởng dự án không?</p>
                </div>
            }
            else
            {
                foreach (var item in conversations)
                {
                    if (item.Role == "user")
                    {
                        <div class="msg you">
                            <p>@item.Message</p>
                        </div>
                    }
                    else
                    {
                        <div class="msg ba">
                            <b>@item.Agent.Name</b>
                            <pre>@item.Message</pre>
                        </div>
                    }
                }
            }
        </div>

        <form id="chatForm" class="chatbox">
            @Html.AntiForgeryToken()

            <input type="hidden" id="projectId" value="@Model.Id" />

            <input id="messageInput"
                   name="message"
                   placeholder="Type your message..."
                   autocomplete="off"
                   required />

            <button id="sendBtn" class="btn primary" type="submit">➤</button>
        </form>

        <div id="agentStatus" class="agent-status hidden">
            <b>BA Agent</b>
            <span id="agentStatusText">Waiting...</span>
        </div>
    </section>

    <aside class="card requirement">
        <h3>Requirement @selectedVersion</h3>

        <div class="requirement-tabs">
            <button type="button" onclick="showReqTab('brd')">BRD</button>
            <button type="button" onclick="showReqTab('srs')">SRS</button>
            <button type="button" onclick="showReqTab('stories')">User Stories</button>
        </div>

        <div id="req-brd" class="req-doc">
            <h4>BRD.md</h4>
            <pre>@(brd?.Content ?? "Chưa có BRD.")</pre>
        </div>

        <div id="req-srs" class="req-doc hidden">
            <h4>SRS.md</h4>
            <pre>@(srs?.Content ?? "Chưa có SRS.")</pre>
        </div>

        <div id="req-stories" class="req-doc hidden">
            <h4>UserStories.md</h4>
            <pre>@(userStories?.Content ?? "Chưa có User Stories.")</pre>
        </div>

        @if (selectedVersion == "draft")
        {
            <form asp-action="Approve" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />

                <button class="btn approve full" type="submit">
                    I approve this requirement
                </button>
            </form>

            <p>BA chỉ chuyển requirement cho Developer sau khi bạn approve.</p>
        }
        else
        {
            <p class="muted">Version này đã được approve, chỉ dùng để xem lại.</p>
        }
    </aside>

    <script>
                        const form = document.getElementById('chatForm');
            const sendBtn = document.getElementById('sendBtn');
            const statusBox = document.getElementById('agentStatus');
            const statusText = document.getElementById('agentStatusText');
            const messageInput = document.getElementById('messageInput');
            const chatMessages = document.getElementById('chatMessages');

            form.addEventListener('submit', async function (e) {
                e.preventDefault();

                const projectId = document.getElementById('projectId').value;
                const message = messageInput.value.trim();
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                if (!message) return;

                appendUserMessage(message);

                messageInput.value = '';
                sendBtn.disabled = true;
                messageInput.disabled = true;

                statusBox.classList.remove('hidden');
                statusText.innerText = 'Sending message to BA...';

                const formData = new FormData();
                formData.append('projectId', projectId);
                formData.append('message', message);
                formData.append('__RequestVerificationToken', token);

                try {
                    const startResponse = await fetch('/CreateDocument/StartChat', {
                        method: 'POST',
                        body: formData
                    });

                    if (!startResponse.ok) {
                        throw new Error('Cannot start agent job.');
                    }

                    const startData = await startResponse.json();

                    appendAgentThinking();

                    pollJob(startData.jobId, projectId);
                }
                catch (err) {
                    statusText.innerText = 'Failed: ' + err.message;
                    sendBtn.disabled = false;
                    messageInput.disabled = false;
                }
            });

            function appendUserMessage(message) {
                const div = document.createElement('div');
                div.className = 'msg you';

                const p = document.createElement('p');
                p.innerText = message;

                div.appendChild(p);
                chatMessages.appendChild(div);

                scrollChatToBottom();
            }

            function appendAgentThinking() {
                const div = document.createElement('div');
                div.className = 'msg ba';
                div.id = 'agentThinkingMessage';

                const b = document.createElement('b');
                b.innerText = 'BA';

                const p = document.createElement('p');
                p.innerText = 'BA is thinking...';

                div.appendChild(b);
                div.appendChild(p);

                chatMessages.appendChild(div);
                scrollChatToBottom();
            }

            function updateAgentThinking(text) {
                const div = document.getElementById('agentThinkingMessage');

                if (!div) return;

                const p = div.querySelector('p');
                p.innerText = text;
            }

            async function pollJob(jobId, projectId) {
                const timer = setInterval(async function () {
                    const response = await fetch(`/CreateDocument/JobStatus?jobId=${jobId}`);
                    const data = await response.json();

                    statusText.innerText = data.currentStep;
                    updateAgentThinking(data.currentStep);

                    if (data.status === 'Completed') {
                        clearInterval(timer);

                        statusText.innerText = 'Done. Reloading requirement draft...';
                        updateAgentThinking('Requirement draft updated.');

                        window.location.href = `/CreateDocument?projectId=${projectId}`;
                    }

                    if (data.status === 'Failed') {
                        clearInterval(timer);

                        statusText.innerText = 'Failed: ' + data.error;
                        updateAgentThinking('Failed: ' + data.error);

                        sendBtn.disabled = false;
                        messageInput.disabled = false;
                    }
                }, 1000);
            }

            function scrollChatToBottom() {
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }

            function showReqTab(name) {
                document.querySelectorAll('.req-doc').forEach(x => x.classList.add('hidden'));
                document.getElementById('req-' + name).classList.remove('hidden');
            }
    </script>
</div>